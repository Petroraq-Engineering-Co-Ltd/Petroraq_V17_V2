msgid "Page Not Found"
msgstr "الصفحة غير موجودة"

#. module: pr_website
#: model_terms:ir.ui.view,arch_db:pr_website.projects_page_template
msgid "Partner with PETRORAQ for reliable solutions and lasting results."
msgstr "تعاون مع بيتروراق لحلول موثوقة ونتائج مستدامة."

#. module: pr_website
