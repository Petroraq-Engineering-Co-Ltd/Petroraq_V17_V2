#: model_terms:ir.ui.view,arch_db:pr_website.service_project_management
msgid "PROJECT DEVELOPMENT"
msgstr "تطوير المشروع"

#. module: pr_website
#: model_terms:ir.ui.view,arch_db:pr_website.service_project_management
msgid "PROJECT MANAGEMENT"
msgstr "إدارة المشاريع"

