<odoo>
    <template id="petroraq_footer" inherit_id="website.layout">

        <xpath expr="//footer" position="replace">

            <footer id="petroraq-footer" class="petroraq-footer o_not_editable">
                <div class="footer-main container">

                    <!-- COLUMN 1: LOGO -->
                    <div class="footer-col footer-logo">
                        <img src="/pr_website/static/images/logo-white.png"
                             alt="Petroraq Logo"
                             class="footer-logo-img"/>
                    </div>

                    <!-- COLUMN 2: OUR SERVICES -->
                    <div class="footer-col">
                        <h3 class="footer-title">Our Services</h3>
                        <ul class="footer-list">
                            <li>Design &amp; Engineering</li>
                            <li>Architecture &amp; Planning</li>
                            <li>Civil &amp; Structural</li>
                            <li>Electrical &amp; Telecommunication</li>
                            <li>Mechanical &amp; Piping</li>
                            <li>Civil &amp; Structural</li>
                            <li>CAD Services</li>
                            <li>Other Services</li>
                        </ul>
                    </div>

                    <!-- COLUMN 3: OUR OFFICE -->
                    <div class="footer-col">
                        <h3 class="footer-title">Our Office</h3>

                        <p class="footer-text">
                            Majd Square Building, King Faisal (West) Rd, AlJubail, KSA.
                        </p>

                        <p class="footer-subtitle">CONTACT US</p>
                        <p class="footer-text">PHONE: (+966) 13-361-4446</p>

                        <p class="footer-subtitle">FOR COMPANIES:</p>
                        <p class="footer-text">
                            (Partnership, Sales, Investments, etc.)<br/>
                            info@petroraq.com<br/>
                            procurement@petroraq.com
                        </p>

                        <hr class="footer-line"/>

                        <p class="footer-subtitle">FOR INDIVIDUALS:</p>
                        <p class="footer-text">
                            (Job Application, Complaint, etc.)<br/>
                            hr@petroraq.com
                        </p>
                    </div>

                    <!-- COLUMN 4: ABOUT US -->
                    <div class="footer-col">
                        <h3 class="footer-title">About Us</h3>
                        <a href="/about-us" class="footer-about-btn">ABOUT</a>
                    </div>

                </div>

                <!-- COPYRIGHT BAR -->
                <div class="footer-bottom">
                    <p>Copyright © 2025 Petroraq Engineering Company. Ltd</p>
                </div>

            </footer>

        </xpath>

    </template>
</odoo>
