<odoo>
    <template id="petroraq_footer" inherit_id="website.layout">
        <xpath expr="//head" position="inside">
            <style>
                footer {
                    background: linear-gradient(135deg, #06264B 0%, #0a3d6e 100%);
                    color: #fff;
                    padding: 70px 40px 20px;
                    position: relative;
                    overflow: hidden;
                }
                footer::before {
                    content: '';
                    position: absolute;
                    top: 0;
                    left: 0;
                    right: 0;
                    height: 3px;
                    background: linear-gradient(90deg, transparent, #e9a23e, transparent);
                    animation: shimmerLine 3s ease-in-out infinite;
                }
                footer::after {
                    content: '';
                    position: absolute;
                    top: -50%;
                    right: -20%;
                    width: 600px;
                    height: 600px;
                    background: radial-gradient(circle, rgba(233,162,62,0.08) 0%, transparent 70%);
                    pointer-events: none;
                }
                @keyframes shimmerLine {
                    0%, 100% { opacity: 0.5; }
                    50% { opacity: 1; }
                }

                .footer-container {
                    max-width: 1200px;
                    margin: 0 auto;
                    display: grid;
                    grid-template-columns: 1.3fr 1fr 1.2fr 1.3fr;
                    gap: 50px;
                    position: relative;
                    z-index: 2;
                }
                .footer-col {
                    animation: fadeInFooter 0.8s ease-out forwards;
                    opacity: 0;
                }
                .footer-col:nth-child(1) { animation-delay: 0.1s; }
                .footer-col:nth-child(2) { animation-delay: 0.2s; }
                .footer-col:nth-child(3) { animation-delay: 0.3s; }
                .footer-col:nth-child(4) { animation-delay: 0.4s; }
                @keyframes fadeInFooter {
                    from { opacity: 0; transform: translateY(20px); }
                    to { opacity: 1; transform: translateY(0); }
                }

                .footer-logo img {
                    height: 55px;
                    margin-bottom: 20px;
                    transition: transform 0.3s ease;
                }
                .footer-logo img:hover {
                    transform: scale(1.05);
                }
                .footer-col p {
                    font-size: 13px;
                    line-height: 1.7;
                    color: #cbd5e1;
                }

                .footer-social {
                    display: flex;
                    gap: 12px;
                    margin-top: 25px;
                }
                .footer-social a {
                    width: 40px;
                    height: 40px;
                    border: 1px solid rgba(233,162,62,0.3);
                    border-radius: 50%;
                    color: #fff;
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    font-size: 15px;
                    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
                    position: relative;
                    overflow: hidden;
                }
                .footer-social a::before {
                    content: '';
                    position: absolute;
                    inset: 0;
                    background: linear-gradient(45deg, #e9a23e, #d8902f);
                    transform: scale(0);
                    transition: transform 0.4s ease;
                    border-radius: 50%;
                }
                .footer-social a i {
                    position: relative;
                    z-index: 2;
                }
                .footer-social a:hover {
                    border-color: #e9a23e;
                    transform: translateY(-5px) rotate(8deg);
                    box-shadow: 0 8px 20px rgba(233,162,62,0.4);
                }
                .footer-social a:hover::before {
                    transform: scale(1);
                }

                .footer-col h4 {
                    font-size: 17px;
                    margin-bottom: 22px;
                    font-weight: 700;
                    position: relative;
                    padding-bottom: 12px;
                    display: inline-block;
                }
                .footer-col h4::after {
                    content: '';
                    position: absolute;
                    bottom: 0;
                    left: 0;
                    width: 40px;
                    height: 2px;
                    background: linear-gradient(90deg, #e9a23e, transparent);
                }

                .footer-col ul li {
                    font-size: 13px;
                    color: #cbd5e1;
                    padding: 7px 0;
                    cursor: pointer;
                    transition: all 0.3s ease;
                    position: relative;
                    padding-left: 0;
                }
                .footer-col ul li::before {
                    content: '›';
                    position: absolute;
                    left: 0;
                    opacity: 0;
                    color: #e9a23e;
                    font-weight: bold;
                    font-size: 16px;
                    transition: all 0.3s ease;
                }
                .footer-col ul li:hover {
                    color: #e9a23e;
                    padding-left: 15px;
                }
                .footer-col ul li:hover::before {
                    opacity: 1;
                }

                .contact-item {
                    display: flex;
                    align-items: center;
                    gap: 12px;
                    font-size: 13px;
                    color: #cbd5e1;
                    margin-bottom: 14px;
                    transition: all 0.3s ease;
                    cursor: pointer;
                }
                .contact-item:hover {
                    color: #fff;
                    transform: translateX(5px);
                }
                .contact-item i {
                    color: #e9a23e;
                    width: 32px;
                    height: 32px;
                    background: rgba(233,162,62,0.1);
                    border-radius: 50%;
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    font-size: 13px;
                    transition: all 0.3s ease;
                    flex-shrink: 0;
                }
                .contact-item:hover i {
                    background: #e9a23e;
                    color: #fff;
                    transform: rotate(360deg);
                }

                .footer-quote p {
                    font-size: 13px;
                    margin-bottom: 20px;
                    line-height: 1.7;
                    color: #cbd5e1;
                }
                .footer-quote .quote-btn {
                    background: linear-gradient(45deg, #e9a23e, #d8902f);
                    border: none;
                    color: #fff;
                    padding: 12px 24px;
                    border-radius: 50px;
                    font-size: 14px;
                    font-weight: 600;
                    cursor: pointer;
                    display: inline-flex;
                    align-items: center;
                    gap: 10px;
                    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
                    text-decoration: none;
                    box-shadow: 0 4px 15px rgba(233,162,62,0.4);
                    position: relative;
                    overflow: hidden;
                }
                .footer-quote .quote-btn::before {
                    content: '';
                    position: absolute;
                    top: 0;
                    left: -100%;
                    width: 100%;
                    height: 100%;
                    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
                    transition: left 0.5s;
                }
                .footer-quote .quote-btn:hover::before { left: 100%; }
                .footer-quote .quote-btn:hover {
                    transform: translateY(-3px);
                    box-shadow: 0 8px 25px rgba(233,162,62,0.6);
                }
                .footer-quote .quote-btn i {
                    transition: transform 0.3s ease;
                }
                .footer-quote .quote-btn:hover i {
                    transform: translateX(5px);
                }

                .footer-bottom {
                    max-width: 1200px;
                    margin: 50px auto 0;
                    border-top: 1px solid rgba(233,162,62,0.2);
                    padding-top: 22px;
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    font-size: 12px;
                    color: #94a3b8;
                    position: relative;
                    z-index: 2;
                }
                .footer-bottom a {
                    color: #94a3b8;
                    margin-left: 20px;
                    transition: color 0.3s ease;
                    position: relative;
                }
                .footer-bottom a::after {
                    content: '';
                    position: absolute;
                    bottom: -2px;
                    left: 0;
                    width: 0;
                    height: 1px;
                    background: #e9a23e;
                    transition: width 0.3s ease;
                }
                .footer-bottom a:hover {
                    color: #e9a23e;
                }
                .footer-bottom a:hover::after {
                    width: 100%;
                }

                /* Scroll to top button */
                .scroll-top-btn {
                    position: fixed;
                    bottom: 30px;
                    right: 30px;
                    width: 50px;
                    height: 50px;
                    background: linear-gradient(45deg, #e9a23e, #d8902f);
                    color: #fff;
                    border: none;
                    border-radius: 50%;
                    cursor: pointer;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    font-size: 18px;
                    box-shadow: 0 4px 20px rgba(233,162,62,0.5);
                    opacity: 0;
                    visibility: hidden;
                    transform: translateY(20px);
                    transition: all 0.4s ease;
                    z-index: 999;
                }
                .scroll-top-btn.visible {
                    opacity: 1;
                    visibility: visible;
                    transform: translateY(0);
                }
                .scroll-top-btn:hover {
                    transform: translateY(-5px) scale(1.1);
                    box-shadow: 0 8px 30px rgba(233,162,62,0.7);
                }

                @media (max-width: 1024px) {
                    .footer-container { grid-template-columns: repeat(2, 1fr); gap: 40px; }
                }
                @media (max-width: 768px) {
                    footer { padding: 50px 20px 20px; }
                    .footer-container { grid-template-columns: 1fr; gap: 35px; }
                    .footer-bottom {
                        flex-direction: column;
                        gap: 12px;
                        text-align: center;
                    }
                    .footer-bottom a { margin: 0 8px; }
                    .scroll-top-btn {
                        bottom: 20px;
                        right: 20px;
                        width: 45px;
                        height: 45px;
                    }
                }
            </style>
        </xpath>
        <xpath expr="//footer" position="replace">
            <footer>
                <div class="footer-container">
                    <div class="footer-col footer-logo">
                        <img src="/pr_website/static/images/logo.png" alt="PETRORAQ Logo"/>
                        <p>We deliver world-class engineering, procurement, and construction solutions that build a stronger tomorrow.</p>
                        <div class="footer-social">
                            <a href="#" aria-label="LinkedIn"><i class="fa fa-linkedin"></i></a>
                            <a href="#" aria-label="Facebook"><i class="fa fa-facebook"></i></a>
                            <a href="#" aria-label="Instagram"><i class="fa fa-instagram"></i></a>
                            <a href="#" aria-label="YouTube"><i class="fa fa-youtube-play"></i></a>
                        </div>
                    </div>
                    <div class="footer-col">
                        <h4>Quick Links</h4>
                        <ul>
                            <li>Home</li>
                            <li>About Us</li>
                            <li>Services</li>
                            <li>Projects</li>
                            <li>Certifications</li>
                            <li>Contact</li>
                        </ul>
                    </div>
                    <div class="footer-col">
                        <h4>Contact Us</h4>
                        <div class="contact-item"><i class="fa fa-map-marker-alt"></i> Al Mansour, Baghdad, Iraq</div>
                        <div class="contact-item"><i class="fa fa-phone-alt"></i> +964 770 123 4567</div>
                        <div class="contact-item"><i class="fa fa-envelope"></i> info@petroraq.com</div>
                        <div class="contact-item"><i class="fa fa-globe"></i> www.petroraq.com</div>
                    </div>
                    <div class="footer-col footer-quote">
                        <h4>Request a Quote</h4>
                        <p>Tell us about your project and our team will get back to you within 24 hours.</p>
                        <button class="quote-btn" type="button">
                            Request a Quote
                            <i class="fa fa-arrow-right"></i>
                        </button>
                    </div>
                </div>
                <div class="footer-bottom">
                    <div>© 2024 PETRORAQ Engineering &amp; Construction. All Rights Reserved.</div>
                    <div>
                        <a href="#">Privacy Policy</a>
                        <a href="#">Terms of Use</a>
                    </div>
                </div>
                <button class="scroll-top-btn" id="scrollTopBtn" aria-label="Scroll to top" type="button">
                    <i class="fa fa-arrow-up"></i>
                </button>
            </footer>

            <script>
                (function() {
                    var scrollBtn = document.getElementById('scrollTopBtn');
                    if (scrollBtn) {
                        window.addEventListener('scroll', function() {
                            if (window.scrollY > 400) {
                                scrollBtn.classList.add('visible');
                            } else {
                                scrollBtn.classList.remove('visible');
                            }
                        });
                        scrollBtn.addEventListener('click', function() {
                            window.scrollTo({ top: 0, behavior: 'smooth' });
                        });
                    }
                })();
            </script>
        </xpath>
    </template>
</odoo>