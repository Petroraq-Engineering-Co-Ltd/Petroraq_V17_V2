<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="careers_jobs" name="Careers Jobs">
        <t t-call="website.layout">
            <div class="container mt-5 mb-5 prq-careers">
                <div class="prq-banner">Careers</div>
                <h5 class="mt-3">Open Positions</h5>
                <div class="row mt-3">
                    <t t-foreach="jobs" t-as="job">
                        <div class="col-md-4 mb-3">
                            <div class="card p-3 h-100 text-center">
                                <h6 class="prq-job-title" t-esc="job.name"/>
                                <a t-att-href="'/job/%s' % job.id" class="btn btn-sm prq-btn mt-3">View Details</a>
                            </div>
                        </div>
                    </t>
                </div>
            </div>
        </t>
    </template>

    <template id="careers_job_detail" name="Career Job Detail">
        <t t-call="website.layout">
            <div class="container mt-5 mb-5 prq-careers-detail">
                <div class="prq-banner">
                    <h2 class="mb-0" t-esc="job.name"/>
                    <div t-esc="job.address_id.city if job.address_id else ''"/>
                </div>
                <div class="mt-3">
                    <a href="#apply-form" class="btn prq-btn">Apply Job</a>
                </div>
                <h3 class="mt-4">Job Description</h3>
                <div t-field="job.description"/>

                <h3 id="apply-form" class="mt-4 text-center">Apply For Job</h3>
                <form t-att-action="'/job/%s/apply' % job.id" method="post" enctype="multipart/form-data"
                      class="row g-3 mt-1">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <div class="col-md-6">
                        <label>Full Name*</label>
                        <input class="form-control" name="partner_name" required="required"/>
                    </div>
                    <div class="col-md-6">
                        <label>Email*</label>
                        <input class="form-control" type="email" name="email_from" required="required"/>
                    </div>
                    <div class="col-md-6">
                        <label>Phone*</label>
                        <input class="form-control" name="partner_phone" required="required"/>
                    </div>
                    <div class="col-md-6">
                        <label>Location*</label>
                        <input class="form-control" name="partner_location" required="required"/>
                    </div>
                    <div class="col-md-6">
                        <label>Total years of experience*</label>
                        <input type="number" class="form-control" required="required" name="experience"/>
                    </div>
                    <div class="col-md-6">
                        <label>Highest Qualification*</label>
                        <input class="form-control" name="type_id" required="required"/>
                    </div>
                    <div class="col-md-6">
                        <label>Expected Salary*</label>
                        <input type="number" class="form-control" required="required" name="salary_expected"/>
                    </div>
                    <div class="col-md-6">
                        <label>Notice Period (in Days)*</label>
                        <input type="number" class="form-control" required="required" name="notice_period"/>
                    </div>
                    <div class="col-md-6">
                        <label>Linkedin Profile*</label>
                        <input class="form-control" name="linkedin_profile" required="required"/>
                    </div>
                    <div class="col-md-6">
                        <label>Will you able to relocate for this position?*</label>
                        <input class="form-control" name="will_relocate"/>
                    </div>

                    <div class="col-md-6">
                        <label>Are you legally authorized to work in KSA?*</label>
                        <input class="form-control" name="legally_required"/>
                    </div>
                    <div class="col-md-12">
                        <label>Resume upload*</label>
                        <input class="form-control" type="file" name="resume" required="required"/>
                    </div>
                    <div class="col-12 text-center">
                        <button class="btn prq-btn" type="submit">Submit</button>
                    </div>
                </form>
            </div>
        </t>
    </template>
</odoo>