                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- ===== Organizations We Work With ===== -->
                    <section class="orgs-section">
                        <div class="pr-container">
                            <h2 class="section-title animate-slide-up">Organizations We Work With</h2>
                            <div class="orgs-grid">
                                <div class="org-card animate-scale-up delay-100">
                                    <img src="/pr_website/static/images/aramco-client.png"
                                         alt="Saudi Aramco"/>
                                </div>
