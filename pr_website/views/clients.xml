                                    <img src="/pr_website/static/images/royal-client.png"
                                         alt="Royal Commission for Al-Ula"/>
                                </div>
                                <div class="org-card animate-scale-up delay-300">
                                    <img src="/pr_website/static/images/neom-client.png"
                                         alt="NEOM"/>
