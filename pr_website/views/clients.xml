<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="petroraq_our_clients" name="PETRORAQ Our Clients">
            <t t-call="website.layout">
                <t t-set="additional_title">Our Clients - PETRORAQ</t>

                <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&amp;display=swap"
                      rel="stylesheet"/>

                <style>
                    .petroraq-clients * {
                    margin: 0;
                    padding: 0;
                    box-sizing: border-box;
                    font-family: 'Poppins', sans-serif;
                    }
                    .petroraq-clients {
                    background: #ffffff;
                    color: #0a2540;
                    overflow-x: hidden;
                    }
                    .petroraq-clients {
                    --blue: #0a2540;
                    --gold: #d89a2b;
                    }
                    .petroraq-clients .pr-container {
                    max-width: 1200px;
                    margin: 0 auto;
                    padding: 0 20px;
                    }

                    /* ===== ANIMATION CLASSES ===== */
                    .animate-slide-up {
                    opacity: 0;
                    transform: translateY(50px);
                    animation: slideUp 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
                    }
                    .animate-fade-in {
                    opacity: 0;
                    animation: fadeIn 1s ease forwards;
                    }
                    .animate-scale-up {
                    opacity: 0;
                    transform: scale(0.9);
                    animation: scaleUp 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
                    }
                    .animate-float {
                    animation: float 6s ease-in-out infinite;
                    }
                    .delay-100 { animation-delay: 0.1s; }
                    .delay-200 { animation-delay: 0.2s; }
                    .delay-300 { animation-delay: 0.3s; }
                    .delay-400 { animation-delay: 0.4s; }
                    .delay-500 { animation-delay: 0.5s; }
                    .delay-600 { animation-delay: 0.6s; }

                    @keyframes slideUp {
                    to { opacity: 1; transform: translateY(0); }
                    }
                    @keyframes fadeIn {
                    to { opacity: 1; }
                    }
                    @keyframes scaleUp {
                    to { opacity: 1; transform: scale(1); }
                    }
                    @keyframes float {
                    0%, 100% { transform: translateY(0px); }
                    50% { transform: translateY(-10px); }
                    }

                    /* ===== Hero Section ===== */
                    .petroraq-clients .clients-hero {
                    position: relative;
                    min-height: 320px;
                    background: url('/pr_website/static/src/img/hero-bg.png')
                    right center/cover no-repeat;
                    overflow: hidden;
                    display: flex;
                    align-items: center;
                    }
                    .petroraq-clients .hero-overlay {
                    position: absolute;
                    inset: 0;
                    background: linear-gradient(90deg, #ffffff 0%, rgba(255,255,255,0.92) 30%, rgba(255,255,255,0.6)
                    50%, rgba(255,255,255,0) 70%);
                    transition: opacity 0.6s ease;
                    }
                    .petroraq-clients .hero-content {
                    position: relative;
                    z-index: 2;
                    padding: 70px 60px;
                    max-width: 550px;
                    }
                    .petroraq-clients .hero-content h1 {
                    font-size: 54px;
                    font-weight: 700;
                    color: var(--blue);
                    margin-bottom: 20px;
                    line-height: 1.1;
                    }
                    .petroraq-clients .hero-content h1 .dot {
                    color: var(--gold);
                    position: relative;
                    }
                    .petroraq-clients .hero-content h1 .dot::after {
                    content: '';
                    position: absolute;
                    bottom: -8px;
                    left: 0;
                    width: 0;
                    height: 3px;
                    background: var(--gold);
                    transition: width 0.5s ease;
                    }
                    .petroraq-clients .clients-hero:hover .dot::after {
                    width: 100%;
                    }
                    .petroraq-clients .hero-content p {
                    font-size: 16px;
                    line-height: 1.7;
                    color: #4a5568;
                    margin-bottom: 25px;
                    max-width: 400px;
                    }
                    .petroraq-clients .hero-accent {
                    width: 70px;
                    height: 3px;
                    background: var(--gold);
                    transform: scaleX(0);
                    transform-origin: left;
                    transition: transform 0.6s ease;
                    }
                    .petroraq-clients .clients-hero:hover .hero-accent {
                    transform: scaleX(1);
                    }

                    /* ===== Partnerships Section ===== */
                    .petroraq-clients .partnerships-section {
                    padding: 80px 0 60px;
                    }
                    .petroraq-clients .partnerships-grid {
                    display: grid;
                    grid-template-columns: 1fr 1fr 1fr 1fr;
                    gap: 25px;
                    align-items: stretch;
                    }
                    .petroraq-clients .partnership-text h2 {
                    font-size: 28px;
                    font-weight: 700;
                    color: var(--blue);
                    margin-bottom: 18px;
                    line-height: 1.3;
                    }
                    .petroraq-clients .partnership-text p {
                    font-size: 15px;
                    color: #6b7a8f;
                    line-height: 1.8;
                    max-width: 320px;
                    }
                    .petroraq-clients .partnership-card {
                    background: #fff;
                    border: 1px solid #e5e8ec;
                    border-radius: 16px;
                    padding: 30px 25px;
                    display: flex;
                    align-items: center;
                    gap: 20px;
                    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
                    position: relative;
                    overflow: hidden;
                    box-shadow: 0 4px 20px rgba(0,0,0,0.05);
                    }
                    .petroraq-clients .partnership-card::before {
                    content: '';
                    position: absolute;
                    top: 0;
                    left: 0;
                    width: 0;
                    height: 4px;
                    background: linear-gradient(90deg, var(--gold), #e5b55b);
                    transition: width 0.4s ease;
                    }
                    .petroraq-clients .partnership-card:hover::before {
                    width: 100%;
                    }
                    .petroraq-clients .partnership-card:hover {
                    transform: translateY(-10px) scale(1.02);
                    box-shadow: 0 25px 50px rgba(0,0,0,0.12);
                    border-color: rgba(216,154,43,0.2);
                    }
                    .petroraq-clients .pc-icon {
                    width: 65px;
                    height: 65px;
                    background: linear-gradient(135deg, #fff, #f8fafc);
                    border: 2px solid rgba(216,154,43,0.1);
                    border-radius: 50%;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    flex-shrink: 0;
                    position: relative;
                    transition: all 0.4s ease;
                    }
                    .petroraq-clients .partnership-card:hover .pc-icon {
                    transform: scale(1.15) rotate(360deg);
                    border-color: var(--gold);
                    box-shadow: 0 10px 25px rgba(216,154,43,0.3);
                    }
                    .petroraq-clients .pc-icon i {
                    color: var(--gold);
                    font-size: 32px;
                    transition: all 0.3s ease;
                    }
                    .petroraq-clients .partnership-card:hover .pc-icon i {
                    transform: scale(1.2);
                    }
                    .petroraq-clients .pc-content h3 {
                    font-size: 28px;
                    font-weight: 800;
                    color: var(--blue);
                    margin-bottom: 5px;
                    line-height: 1.1;
                    transition: color 0.3s ease;
                    }
                    .petroraq-clients .partnership-card:hover .pc-content h3 {
                    color: var(--gold);
                    }
                    .petroraq-clients .pc-content h4 {
                    font-size: 14px;
                    font-weight: 700;
                    color: var(--blue);
                    margin-bottom: 10px;
                    line-height: 1.4;
                    opacity: 0.8;
                    }
                    .petroraq-clients .pc-content p {
                    font-size: 13px;
                    color: #6b7a8f;
                    line-height: 1.6;
                    }

                    /* ===== Organizations We Work With - LARGER LOGOS ===== */
                    .petroraq-clients .orgs-section {
                    padding: 60px 0 80px;
                    background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
                    }
                    .petroraq-clients .section-title {
                    text-align: center;
                    font-size: 32px;
                    font-weight: 700;
                    color: var(--blue);
                    margin-bottom: 50px;
                    position: relative;
                    padding-bottom: 15px;
                    }
                    .petroraq-clients .section-title::after {
                    content: '';
                    position: absolute;
                    left: 50%;
                    bottom: 0;
                    transform: translateX(-50%);
                    width: 80px;
                    height: 3px;
                    background: linear-gradient(90deg, var(--gold), #e5b55b);
                    border-radius: 2px;
                    }
                    .petroraq-clients .orgs-grid {
                    display: grid;
                    grid-template-columns: repeat(4, 1fr);
                    gap: 30px;
                    padding: 20px 0;
                    }
                    .petroraq-clients .org-card {
                    background: linear-gradient(145deg, #fff, #fafbfc);
                    border: 2px solid #e8ecf2;
                    border-radius: 24px;
                    height: 200px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    padding: 35px 25px;
                    transition: all 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
                    position: relative;
                    overflow: hidden;
                    box-shadow: 0 12px 35px rgba(0,0,0,0.08);
                    cursor: pointer;
                    }
                    .petroraq-clients .org-card::before {
                    content: '';
                    position: absolute;
                    top: 0;
                    left: 0;
                    right: 0;
                    height: 0;
                    background: linear-gradient(135deg, var(--gold), #e5b55b, var(--gold));
                    transition: height 0.5s ease;
                    z-index: 1;
                    }
                    .petroraq-clients .org-card:hover::before {
                    height: 6px;
                    }
                    .petroraq-clients .org-card:hover {
                    transform: translateY(-18px) scale(1.08);
                    border-color: var(--gold);
                    box-shadow: 0 45px 90px rgba(216,154,43,0.25);
                    }
                    .petroraq-clients .org-card img {
                    max-width: 160px;
                    max-height: 120px;
                    width: auto;
                    height: auto;
                    object-fit: contain;
                    filter: grayscale(30%) contrast(1.1) brightness(1.05);
                    transition: all 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
                    z-index: 2;
                    position: relative;
                    }
                    .petroraq-clients .org-card:hover img {
                    filter: grayscale(0%) contrast(1.15) brightness(1.1);
                    transform: scale(1.15) rotate(2deg);
                    box-shadow: 0 10px 30px rgba(216,154,43,0.4);
                    }
                    .petroraq-clients .org-card:empty::before {
                    display: none;
                    }
                    .petroraq-clients .org-card[style*="transparent"] {
                    background: transparent;
                    border: 2px dashed #e5e8ec;
                    opacity: 0.3;
                    }
                    .petroraq-clients .org-card[style*="transparent"]:hover {
                    background: linear-gradient(145deg, #fff, #f8fafc);
                    border-color: #d1d5db;
                    opacity: 1;
                    transform: none;
                    }

                    /* ===== Why Leading Clients Choose PETRORAQ ===== */
                    .petroraq-clients .why-section {
                    padding: 80px 0;
                    }
                    .petroraq-clients .why-grid {
                    display: grid;
                    grid-template-columns: repeat(4, 1fr);
                    gap: 30px;
                    }
                    .petroraq-clients .why-card {
                    background: linear-gradient(145deg, #fff, #f8fafc);
                    border: 2px solid #e5e8ec;
                    border-radius: 20px;
                    padding: 35px 25px;
                    text-align: center;
                    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
                    position: relative;
                    overflow: hidden;
                    box-shadow: 0 10px 30px rgba(0,0,0,0.08);
                    }
                    .petroraq-clients .why-card::before {
                    content: '';
                    position: absolute;
                    top: 0;
                    left: -100%;
                    width: 100%;
                    height: 100%;
                    background: linear-gradient(90deg, transparent, rgba(216,154,43,0.1), transparent);
                    transition: left 0.6s ease;
                    }
                    .petroraq-clients .why-card:hover::before {
                    left: 100%;
                    }
                    .petroraq-clients .why-card:hover {
                    transform: translateY(-15px) rotateX(5deg);
                    border-color: var(--gold);
                    box-shadow: 0 35px 70px rgba(0,0,0,0.15);
                    }
                    .petroraq-clients .why-icon {
                    font-size: 48px;
                    color: var(--gold);
                    margin-bottom: 20px;
                    transition: all 0.4s ease;
                    display: block;
                    }
                    .petroraq-clients .why-card:hover .why-icon {
                    transform: scale(1.2) rotateY(360deg);
                    }
                    .petroraq-clients .why-card h4 {
                    font-size: 18px;
                    font-weight: 700;
                    color: var(--blue);
                    margin-bottom: 15px;
                    transition: color 0.3s ease;
                    }
                    .petroraq-clients .why-card:hover h4 {
                    color: var(--gold);
                    }
                    .petroraq-clients .why-card p {
                    font-size: 14px;
                    color: #6b7a8f;
                    line-height: 1.7;
                    }

                    /* ===== CTA Banner ===== */
                    .petroraq-clients .cta-section {
                    padding: 60px 0 80px;
                    }
                    .petroraq-clients .cta-banner {
                    background: linear-gradient(135deg, var(--blue) 0%, #071a2f 100%);
                    background-image:
                    radial-gradient(circle at 20% 80%, rgba(216,154,43,0.15) 0%, transparent 50%),
                    radial-gradient(circle at 80% 20%, rgba(216,154,43,0.1) 0%, transparent 50%);
                    border: 2px solid rgba(216,154,43,0.3);
                    border-radius: 24px;
                    padding: 45px 50px;
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    flex-wrap: wrap;
                    gap: 30px;
                    position: relative;
                    overflow: hidden;
                    }
                    .petroraq-clients .cta-banner::before {
                    content: '';
                    position: absolute;
                    top: -50%;
                    left: -50%;
                    width: 200%;
                    height: 200%;
                    background: conic-gradient(from 0deg, transparent, rgba(216,154,43,0.05), transparent);
                    animation: rotateGlow 15s linear infinite;
                    z-index: 0;
                    }
                    .petroraq-clients .cta-left {
                    display: flex;
                    align-items: center;
                    gap: 25px;
                    position: relative;
                    z-index: 2;
                    }
                    .petroraq-clients .hex-icon {
                    width: 70px;
                    height: 70px;
                    background: rgba(216,154,43,0.1);
                    border: 3px solid var(--gold);
                    clip-path: polygon(25% 5%, 75% 5%, 100% 50%, 75% 95%, 25% 95%, 0% 50%);
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    flex-shrink: 0;
                    transition: all 0.4s ease;
                    position: relative;
                    z-index: 2;
                    }
                    .petroraq-clients .cta-banner:hover .hex-icon {
                    transform: rotate(360deg) scale(1.1);
                    box-shadow: 0 15px 35px rgba(216,154,43,0.4);
                    }
                    .petroraq-clients .hex-icon i {
                    color: var(--gold);
                    font-size: 26px;
                    }
                    .petroraq-clients .cta-text h3 {
                    color: #fff;
                    font-size: 24px;
                    font-weight: 700;
                    margin-bottom: 8px;
                    }
                    .petroraq-clients .cta-text p {
                    color: #b8c5d6;
                    font-size: 15px;
                    }
                    .petroraq-clients .cta-buttons {
                    display: flex;
                    gap: 15px;
                    position: relative;
                    z-index: 2;
                    }
                    .petroraq-clients .btn-cta-primary,
                    .petroraq-clients .btn-cta-outline {
                    padding: 15px 32px;
                    border-radius: 12px;
                    font-size: 14px;
                    font-weight: 700;
                    text-decoration: none;
                    display: inline-flex;
                    align-items: center;
                    gap: 12px;
                    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
                    position: relative;
                    overflow: hidden;
                    }
                    .petroraq-clients .btn-cta-primary {
                    background: linear-gradient(135deg, var(--gold), #e5b55b);
                    color: #fff;
                    box-shadow: 0 8px 25px rgba(216,154,43,0.4);
                    }
                    .petroraq-clients .btn-cta-primary:hover {
                    transform: translateY(-4px);
                    box-shadow: 0 15px 40px rgba(216,154,43,0.6);
                    background: linear-gradient(135deg, #e5b55b, var(--gold));
                    }
                    .petroraq-clients .btn-cta-outline {
                    background: transparent;
                    color: #fff;
                    border: 2px solid rgba(255,255,255,0.4);
                    backdrop-filter: blur(20px);
                    }
                    .petroraq-clients .btn-cta-outline:hover {
                    background: rgba(255,255,255,0.15);
                    border-color: var(--gold);
                    color: var(--gold);
                    transform: translateY(-4px);
                    box-shadow: 0 10px 30px rgba(216,154,43,0.3);
                    }
                    .petroraq-clients .btn-cta-primary i,
                    .petroraq-clients .btn-cta-outline i {
                    transition: margin-left 0.3s ease;
                    }
                    .petroraq-clients .btn-cta-primary:hover i,
                    .petroraq-clients .btn-cta-outline:hover i {
                    margin-left: 8px;
                    }

                    @keyframes rotateGlow {
                    0% { transform: rotate(0deg); }
                    100% { transform: rotate(360deg); }
                    }

                    /* ===== Responsive ===== */
                    @media (max-width: 992px) {
                    .petroraq-clients .hero-content { padding: 50px 30px; }
                    .petroraq-clients .hero-content h1 { font-size: 42px; }
                    .petroraq-clients .partnerships-grid,
                    .petroraq-clients .orgs-grid,
                    .petroraq-clients .why-grid { grid-template-columns: repeat(2, 1fr); }
                    .petroraq-clients .section-title { font-size: 26px; }
                    .petroraq-clients .orgs-grid { gap: 25px; }
                    .petroraq-clients .org-card { height: 180px; padding: 30px 20px; }
                    .petroraq-clients .org-card img { max-width: 140px; max-height: 100px; }
                    }
                    @media (max-width: 600px) {
                    .petroraq-clients .hero-content h1 { font-size: 36px; }
                    .petroraq-clients .partnerships-grid,
                    .petroraq-clients .orgs-grid,
                    .petroraq-clients .why-grid { grid-template-columns: 1fr; }
                    .petroraq-clients .cta-banner {
                    flex-direction: column;
                    text-align: center;
                    padding: 40px 30px;
                    }
                    .petroraq-clients .cta-left { flex-direction: column; }
                    .petroraq-clients .cta-buttons {
                    width: 100%;
                    flex-direction: column;
                    }
                    .petroraq-clients .btn-cta-primary,
                    .petroraq-clients .btn-cta-outline {
                    justify-content: center;
                    width: 100%;
                    }
                    .petroraq-clients .orgs-grid { gap: 20px; }
                    .petroraq-clients .org-card {
                    height: 160px;
                    padding: 25px 20px;
                    }
                    .petroraq-clients .org-card img {
                    max-width: 120px;
                    max-height: 90px;
                    }
                    .petroraq-clients .org-card:hover,
                    .petroraq-clients .partnership-card:hover,
                    .petroraq-clients .why-card:hover {
                    transform: translateY(-10px) scale(1.05);
                    }
                    }
                </style>
                <div class="petroraq-clients">

                    <!-- ===== Hero Section ===== -->
                    <section class="clients-hero animate-fade-in">
                        <div class="hero-overlay"></div>
                        <div class="hero-content animate-slide-up">
                            <h1>Our Clients
                                <span class="dot">.</span>
                            </h1>
                            <p>Trusted by leading organizations across Saudi Arabia's industrial, infrastructure, and
                                development sectors.
                            </p>
                            <div class="hero-accent"></div>
                        </div>
                    </section>

                    <!-- ===== Partnerships Built on Trust ===== -->
                    <section class="partnerships-section">
                        <div class="pr-container">
                            <div class="partnerships-grid">
                                <div class="partnership-text animate-slide-up">
                                    <h2>Partnerships Built on Trust</h2>
                                    <p>We are proud to collaborate with visionary organizations who share our commitment
                                        to excellence, safety, and sustainable development across the Kingdom.
                                    </p>
                                </div>

                                <div class="partnership-card animate-scale-up delay-100">
                                    <div class="pc-icon">
