                                <div class="org-card animate-scale-up delay-400">
                                    <img src="/pr_website/static/images/downtown-client.png"
                                         alt="Saudi Downtown Company"/>
                                </div>

                                <div class="org-card animate-scale-up delay-500">
                                    <img src="/pr_website/static/images/roshin-client.png"
                                         alt="ROSHN"/>
                                </div>
                                <div class="org-card animate-scale-up delay-600">
                                    <img src="/pr_website/static/images/qiddiya-client.png"
                                         alt="Qiddiya"/>
                                </div>
                                <div class="org-card animate-scale-up delay-100">
                                    <img src="/pr_website/static/images/diriyah-client.png"
                                         alt="Diriyah Gate Development Authority"/>
                                </div>
                                <div class="org-card animate-scale-up delay-200">
                                    <img src="/pr_website/static/images/tahakom-client.png"
                                         alt="TAHAKOM"/>
                                </div>

                                <div class="org-card animate-scale-up delay-300">
                                    <img src="/pr_website/static/images/sepco-client.png"
                                         alt="SEPCO III"/>
                                </div>
                                <div class="org-card animate-scale-up delay-400">
                                    <img src="/pr_website/static/images/sabic-client.png"
                                         alt="SABIC"/>
