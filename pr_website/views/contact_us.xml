<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="petroraq_contact_us" name="PETRORAQ Contact Us">
        <t t-call="website.layout">
            <t t-set="additional_title">Contact Us - PETRORAQ</t>

            <!-- Font Awesome & Google Fonts -->
            <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
            <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&amp;display=swap"
                  rel="stylesheet"/>

            <style>
                .petroraq-contact * {
                    margin: 0;
                    padding: 0;
                    box-sizing: border-box;
                    font-family: 'Poppins', sans-serif;
                }

                .petroraq-contact {
                    --blue: #0a2540;
                    --gold: #d89a2b;
                    background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
                    color: var(--blue);
                    overflow-x: hidden;
                }

                .petroraq-contact .pr-container {
                    max-width: 1200px;
                    margin: 0 auto;
                    padding: 0 20px;
                }

                /* ===== ANIMATION CLASSES ===== */
                .animate-slide-up {
                    opacity: 0;
                    transform: translateY(60px);
                    animation: slideUp 0.9s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
                }
                .animate-fade-in {
                    opacity: 0;
                    animation: fadeIn 1.2s ease forwards;
                }
                .animate-scale-up {
                    opacity: 0;
                    transform: scale(0.85);
                    animation: scaleUp 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
                }
                .animate-float {
                    animation: float 4s ease-in-out infinite;
                }
                .delay-100 { animation-delay: 0.1s; }
                .delay-200 { animation-delay: 0.2s; }
                .delay-300 { animation-delay: 0.3s; }
                .delay-400 { animation-delay: 0.4s; }
                .delay-500 { animation-delay: 0.5s; }

                @keyframes slideUp {
                    to { opacity: 1; transform: translateY(0); }
                }
                @keyframes fadeIn {
                    to { opacity: 1; }
                }
                @keyframes scaleUp {
                    to { opacity: 1; transform: scale(1); }
                }
                @keyframes float {
                    0%, 100% { transform: translateY(0px); }
                    50% { transform: translateY(-12px); }
                }

                /* ===== Hero Section ===== */
                .petroraq-contact .contact-hero {
                    position: relative;
                    min-height: 500px;
                    background: url('/pr_website/static/images/hero-bg.png') center/cover no-repeat;
                    display: flex;
                    align-items: center;
                    overflow: hidden;
                }
                .petroraq-contact .hero-overlay {
                    position: absolute;
                    inset: 0;
                    background: linear-gradient(135deg, rgba(10,37,64,0.95) 0%, rgba(10,37,64,0.8) 50%, rgba(10,37,64,0.4) 100%);
                    transition: all 0.6s ease;
                }
                .petroraq-contact .contact-hero:hover .hero-overlay {
                    background: linear-gradient(135deg, rgba(10,37,64,0.9) 0%, rgba(10,37,64,0.75) 50%, rgba(10,37,64,0.35) 100%);
                }
                .petroraq-contact .hero-content {
                    position: relative;
                    z-index: 2;
                    padding: 100px 80px;
                    color: #fff;
                    max-width: 700px;
                }
                .petroraq-contact .hero-content h1 {
                    font-size: 58px;
                    font-weight: 800;
                    line-height: 1.15;
                    margin-bottom: 25px;
                    color: #fff;
                }
                .petroraq-contact .hero-content h1 .dot {
                    color: var(--gold);
                    position: relative;
                }
                .petroraq-contact .hero-content h1 .dot::after {
                    content: '';
                    position: absolute;
                    bottom: -10px;
                    left: 0;
                    width: 0;
                    height: 4px;
                    background: var(--gold);
                    transition: width 0.6s ease;
                    border-radius: 2px;
                }
                .petroraq-contact .contact-hero:hover .dot::after {
                    width: 100%;
                }
                .petroraq-contact .hero-content p {
                    font-size: 18px;
                    line-height: 1.8;
                    color: #d8dfe8;
                    margin-bottom: 35px;
                    max-width: 550px;
                }
                .petroraq-contact .hero-line {
                    width: 100px;
                    height: 4px;
                    background: linear-gradient(90deg, var(--gold), #e5b55b);
                    border-radius: 2px;
                    box-shadow: 0 4px 15px rgba(216,154,43,0.4);
                }

                /* ===== Contact Cards ===== */
                .petroraq-contact .contact-section {
                    padding: 120px 0;
                }
                .petroraq-contact .contact-grid {
                    display: grid;
                    grid-template-columns: 1fr 1fr;
                    gap: 50px;
                    margin-bottom: 60px;
                }
                .petroraq-contact .contact-card {
                    background: linear-gradient(145deg, #fff, #f8fafc);
                    border: 2px solid #e8ecf2;
                    border-radius: 30px;
                    padding: 50px;
                    box-shadow: 0 20px 60px rgba(0,0,0,0.08);
                    transition: all 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
                    position: relative;
                    overflow: hidden;
                }
                .petroraq-contact .contact-card::before {
                    content: '';
                    position: absolute;
                    top: 0;
                    left: 0;
                    width: 0;
                    height: 6px;
                    background: linear-gradient(90deg, var(--gold), #e5b55b);
                    transition: width 0.6s ease;
                }
                .petroraq-contact .contact-card:hover::before {
                    width: 100%;
                }
                .petroraq-contact .contact-card:hover {
                    transform: translateY(-20px) scale(1.02);
                    box-shadow: 0 50px 100px rgba(0,0,0,0.15);
                    border-color: rgba(216,154,43,0.3);
                }
                .petroraq-contact .contact-card h2 {
                    font-size: 32px;
                    font-weight: 800;
                    color: var(--blue);
                    margin-bottom: 20px;
                    line-height: 1.3;
                }
                .petroraq-contact .card-subtitle {
                    color: #6b7a8f;
                    font-size: 16px;
                    line-height: 1.8;
                    margin-bottom: 40px;
                }

                /* ===== Form Styles ===== */
                .petroraq-contact .form-row {
                    display: grid;
                    grid-template-columns: 1fr 1fr;
                    gap: 25px;
                    margin-bottom: 25px;
                }
                .petroraq-contact .input-group {
                    position: relative;
                }
                .petroraq-contact .input-group.full {
                    grid-column: 1 / -1;
                    margin-bottom: 25px;
                }
                .petroraq-contact .input-group i {
                    position: absolute;
                    left: 22px;
                    top: 22px;
                    color: #6b7a8f;
                    font-size: 16px;
                    z-index: 2;
                    transition: all 0.3s ease;
                }
                .petroraq-contact .input-group input,
                .petroraq-contact .input-group textarea,
                .petroraq-contact .input-group select {
                    width: 100%;
                    padding: 22px 22px 22px 55px;
                    border: 2px solid #e8ecf2;
                    border-radius: 20px;
                    font-size: 16px;
                    background: linear-gradient(145deg, #fff, #f8fafc);
                    transition: all 0.4s ease;
                    font-family: inherit;
                    color: var(--blue);
                    backdrop-filter: blur(10px);
                }
                .petroraq-contact .input-group textarea {
                    resize: vertical;
                    min-height: 160px;
                    padding-top: 22px;
                }
                .petroraq-contact .input-group input::placeholder,
                .petroraq-contact .input-group textarea::placeholder {
                    color: #9ca3af;
                }
                .petroraq-contact .input-group:focus-within {
                    border-color: var(--gold);
                    box-shadow: 0 15px 40px rgba(216,154,43,0.2);
                    transform: translateY(-3px);
                }
                .petroraq-contact .input-group:focus-within i {
                    color: var(--gold);
                    transform: scale(1.1);
                }
                .petroraq-contact .form-footer {
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    margin-top: 20px;
                    padding-top: 30px;
                    border-top: 2px solid #e8ecf2;
                }
                .petroraq-contact .btn-send {
                    background: linear-gradient(135deg, var(--gold), #e5b55b);
                    color: #fff;
                    padding: 18px 40px;
                    border: none;
                    border-radius: 20px;
                    font-size: 16px;
                    font-weight: 700;
                    cursor: pointer;
                    transition: all 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
                    box-shadow: 0 15px 45px rgba(216,154,43,0.4);
                    display: inline-flex;
                    align-items: center;
                    gap: 12px;
                    text-transform: uppercase;
                    letter-spacing: 0.5px;
                    position: relative;
                    overflow: hidden;
                }
                .petroraq-contact .btn-send:hover {
                    transform: translateY(-6px) scale(1.05);
                    box-shadow: 0 25px 60px rgba(216,154,43,0.6);
                    background: linear-gradient(135deg, #e5b55b, var(--gold));
                }
                .petroraq-contact .secure-note {
                    display: flex;
                    align-items: center;
                    gap: 10px;
                    color: #6b7a8f;
                    font-size: 14px;
                    font-weight: 500;
                }
                .petroraq-contact .secure-note i {
                    color: var(--gold);
                    font-size: 16px;
                }

                /* ===== Info List ===== */
                .petroraq-contact .info-list {
                    display: flex;
                    flex-direction: column;
                    gap: 30px;
                }
                .petroraq-contact .info-item {
                    display: flex;
                    gap: 25px;
                    align-items: flex-start;
                    padding: 25px;
                    background: linear-gradient(145deg, rgba(216,154,43,0.05), rgba(216,154,43,0.02));
                    border: 2px solid rgba(216,154,43,0.1);
                    border-radius: 20px;
                    transition: all 0.4s ease;
                    cursor: pointer;
                }
                .petroraq-contact .info-item:hover {
                    transform: translateY(-8px);
                    box-shadow: 0 25px 60px rgba(216,154,43,0.2);
                    border-color: var(--gold);
                }
                .petroraq-contact .info-icon {
                    width: 65px;
                    height: 65px;
                    background: linear-gradient(135deg, var(--blue), #1a3a6a);
                    border-radius: 20px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    flex-shrink: 0;
                    box-shadow: 0 15px 40px rgba(10,37,64,0.3);
                    transition: all 0.4s ease;
                }
                .petroraq-contact .info-item:hover .info-icon {
                    transform: scale(1.1) rotateY(360deg);
                }
                .petroraq-contact .info-icon i {
                    color: var(--gold);
                    font-size: 24px;
                }
                .petroraq-contact .info-text h4 {
                    font-size: 18px;
                    font-weight: 700;
                    color: var(--blue);
                    margin-bottom: 8px;
                    transition: color 0.3s ease;
                }
                .petroraq-contact .info-item:hover .info-text h4 {
                    color: var(--gold);
                }
                .petroraq-contact .info-text p,
                .petroraq-contact .info-text a {
                    color: #6b7a8f;
                    font-size: 15px;
                    line-height: 1.7;
                    margin: 0;
                    transition: color 0.3s ease;
                }
                .petroraq-contact .info-item:hover .info-text p,
                .petroraq-contact .info-text a:hover {
                    color: var(--blue);
                }
                .petroraq-contact .info-text a {
                    text-decoration: none;
                }

                /* ===== Map Section ===== */
                .petroraq-contact .map-section {
                    position: relative;
                    border-radius: 30px;
                    overflow: hidden;
                    height: 450px;
                    margin-bottom: 80px;
                    box-shadow: 0 25px 70px rgba(0,0,0,0.1);
                    transition: all 0.5s ease;
                }
                .petroraq-contact .map-section:hover {
                    transform: translateY(-10px);
                    box-shadow: 0 40px 100px rgba(0,0,0,0.15);
                }
                .petroraq-contact .map-section iframe {
                    width: 100%;
                    height: 100%;
                    border: 0;
                    transition: transform 0.6s ease;
                }
                .petroraq-contact .map-section:hover iframe {
                    transform: scale(1.02);
                }
                .petroraq-contact .map-card {
                    position: absolute;
                    top: 30px;
                    left: 30px;
                    background: linear-gradient(145deg, #fff, #f8fafc);
                    backdrop-filter: blur(20px);
                    border: 2px solid rgba(255,255,255,0.3);
                    padding: 30px;
                    border-radius: 24px;
                    box-shadow: 0 20px 50px rgba(0,0,0,0.15);
                    z-index: 10;
                    max-width: 320px;
                    transition: all 0.4s ease;
                }
                .petroraq-contact .map-card:hover {
                    transform: translateY(-8px) scale(1.02);
                }
                .petroraq-contact .map-card h3 {
                    font-size: 20px;
                    font-weight: 700;
                    color: var(--blue);
                    margin-bottom: 12px;
                }
                .petroraq-contact .map-card p {
                    color: #6b7a8f;
                    font-size: 15px;
                    line-height: 1.7;
                    margin-bottom: 15px;
                }
                .petroraq-contact .map-link {
                    color: var(--gold);
                    font-size: 15px;
                    font-weight: 600;
                    text-decoration: none;
                    display: inline-flex;
                    align-items: center;
                    gap: 8px;
                    transition: all 0.3s ease;
                }
                .petroraq-contact .map-link:hover {
                    color: #e5b55b;
                    transform: translateX(5px);
                }

                /* ===== Assistance Banner ===== */
                .petroraq-contact .assistance-banner {
                    background: linear-gradient(135deg, var(--blue) 0%, #071a2f 100%);
                    background-image: radial-gradient(circle at 20% 80%, rgba(216,154,43,0.15) 0%, transparent 50%),
                                      radial-gradient(circle at 80% 20%, rgba(216,154,43,0.1) 0%, transparent 50%);
                    border: 3px solid rgba(216,154,43,0.4);
                    border-radius: 30px;
                    padding: 60px 80px;
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    flex-wrap: wrap;
                    gap: 40px;
                    position: relative;
                    overflow: hidden;
                    box-shadow: 0 30px 90px rgba(10,37,64,0.3);
                }
                .petroraq-contact .assistance-banner::before {
                    content: '';
                    position: absolute;
                    top: -50%;
                    left: -50%;
                    width: 200%;
                    height: 200%;
                    background: conic-gradient(from 0deg, transparent, rgba(216,154,43,0.08), transparent);
                    animation: rotateGlow 15s linear infinite;
                    z-index: 0;
                }
                .petroraq-contact .assistance-left {
                    display: flex;
                    align-items: center;
                    gap: 30px;
                    position: relative;
                    z-index: 2;
                    flex: 1;
                }
                .petroraq-contact .hex-icon {
                    width: 85px;
                    height: 85px;
                    background: linear-gradient(135deg, var(--gold), #e5b55b);
                    clip-path: polygon(25% 5%, 75% 5%, 100% 50%, 75% 95%, 25% 95%, 0% 50%);
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    flex-shrink: 0;
                    box-shadow: 0 20px 50px rgba(216,154,43,0.4);
                    transition: all 0.5s ease;
                }
                .petroraq-contact .assistance-banner:hover .hex-icon {
                    transform: rotate(360deg) scale(1.1);
                }
                .petroraq-contact .hex-icon i {
                    color: #fff;
                    font-size: 32px;
                }
                .petroraq-contact .assistance-text h3 {
                    color: #fff;
                    font-size: 32px;
                    font-weight: 800;
                    margin-bottom: 10px;
                    line-height: 1.3;
                }
                .petroraq-contact .assistance-text p {
                    color: #b8c5d6;
                    font-size: 18px;
                    margin: 0;
                }
                .petroraq-contact .assistance-buttons {
                    display: flex;
                    gap: 20px;
                    position: relative;
                    z-index: 2;
                }
                .petroraq-contact .btn-call,
                .petroraq-contact .btn-email {
                    padding: 20px 40px;
                    border-radius: 20px;
                    font-size: 16px;
                    font-weight: 700;
                    text-decoration: none;
                    display: inline-flex;
                    align-items: center;
                    gap: 12px;
                    transition: all 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
                    position: relative;
                    overflow: hidden;
                }
                .petroraq-contact .btn-call {
                    background: linear-gradient(135deg, var(--gold), #e5b55b);
                    color: #fff;
                    box-shadow: 0 15px 45px rgba(216,154,43,0.5);
                }
                .petroraq-contact .btn-call:hover {
                    transform: translateY(-8px) scale(1.05);
                    box-shadow: 0 25px 60px rgba(216,154,43,0.7);
                }
                .petroraq-contact .btn-email {
                    background: transparent;
                    color: #fff;
                    border: 3px solid rgba(255,255,255,0.3);
                    backdrop-filter: blur(20px);
                }
                .petroraq-contact .btn-email:hover {
                    background: rgba(255,255,255,0.15);
                    border-color: var(--gold);
                    color: var(--gold);
                    transform: translateY(-8px) scale(1.05);
                }

                @keyframes rotateGlow {
                    0% { transform: rotate(0deg); }
                    100% { transform: rotate(360deg); }
                }

                /* ===== Responsive ===== */
                @media (max-width: 992px) {
                    .petroraq-contact .contact-grid {
                        grid-template-columns: 1fr;
                        gap: 40px;
                    }
                    .petroraq-contact .hero-content {
                        padding: 60px 40px;
                        text-align: center;
                    }
                    .petroraq-contact .hero-content h1 {
                        font-size: 42px;
                    }
                }
                @media (max-width: 768px) {
                    .petroraq-contact .pr-container { padding: 0 15px; }
                    .petroraq-contact .contact-card {
                        padding: 40px 30px;
                        margin: 0 10px;
                    }
                    .petroraq-contact .contact-card:hover,
                    .petroraq-contact .info-item:hover {
                        transform: translateY(-10px);
                    }
                    .petroraq-contact .form-row {
                        grid-template-columns: 1fr;
                        gap: 20px;
                    }
                    .petroraq-contact .assistance-banner {
                        flex-direction: column;
                        text-align: center;
                        padding: 50px 40px;
                    }
                    .petroraq-contact .assistance-buttons {
                        flex-direction: column;
                        width: 100%;
                    }
                    .petroraq-contact .btn-call,
                    .petroraq-contact .btn-email {
                        width: 100%;
                        justify-content: center;
                    }
                    .petroraq-contact .map-card {
                        position: static;
                        margin: 20px;
                        max-width: none;
                    }
                }
            </style>

            <div class="petroraq-contact">
                <!-- ===== Hero Section ===== -->
                <section class="contact-hero animate-fade-in">
                    <div class="hero-overlay"></div>
                    <div class="pr-container">
                        <div class="hero-content animate-slide-up">
                            <h1>Let's Connect
                                <span class="dot">.</span>
                            </h1>
                            <p>Ready to start your next project? Our team is here to bring your vision to life with engineering excellence.</p>
                            <div class="hero-line animate-scale-up delay-200"></div>
                        </div>
                    </div>
                </section>

                <!-- ===== Main Contact Section ===== -->
                <section class="contact-section">
                    <div class="pr-container">
                        <div class="contact-grid">
                            <!-- Send Message Form -->
                            <div class="contact-card form-card animate-slide-up delay-100">
                                <h2>Send a Message</h2>
                                <p class="card-subtitle">Share your project details and our experts will respond within 24 hours.</p>

                                <form class="contact-form" action="/website/mail/contact" method="post">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                                    <div class="form-row">
                                        <div class="input-group">
                                            <i class="fa fa-user"></i>
                                            <input type="text" name="name" placeholder="Full Name *" required="required"/>
                                        </div>
                                        <div class="input-group">
                                            <i class="fa fa-envelope"></i>
                                            <input type="email" name="email" placeholder="Email Address *" required="required"/>
                                        </div>
                                    </div>

                                    <div class="form-row">
                                        <div class="input-group">
                                            <i class="fa fa-phone"></i>
                                            <input type="tel" name="phone" placeholder="Phone Number"/>
                                        </div>
                                        <div class="input-group">
                                            <i class="fa fa-building"></i>
                                            <input type="text" name="company" placeholder="Company Name"/>
                                        </div>
                                    </div>

                                    <div class="input-group full">
                                        <i class="fa fa-file-text"></i>
                                        <input type="text" name="subject" placeholder="Subject *" required="required"/>
                                    </div>

                                    <div class="input-group full">
                                        <i class="fa fa-comment"></i>
                                        <textarea name="message" placeholder="Tell us about your project..." required="required"></textarea>
                                    </div>

                                    <div class="form-footer">
                                        <button type="submit" class="btn-send">
                                            <i class="fa fa-paper-plane"></i>
                                            Send Message
                                        </button>
                                        <div class="secure-note">
                                            <i class="fa fa-lock"></i>
                                            100% Secure
                                        </div>
                                    </div>
                                </form>
                            </div>

                            <!-- Contact Information -->
                            <div class="contact-card info-card animate-slide-up delay-200">
                                <h2>Get In Touch</h2>
                                <p class="card-subtitle">Multiple ways to connect with our team for project discussions and support.</p>

                                <div class="info-list">
                                    <div class="info-item animate-scale-up delay-100">
                                        <div class="info-icon">
                                            <i class="fa fa-map-marker-alt"></i>
                                        </div>
                                        <div class="info-text">
                                            <h4>Head Office</h4>
                                            <p>Majd Square, King Faisal (West) Rd<br/>Al Jubail City, Kingdom of Saudi Arabia</p>
                                        </div>
                                    </div>

                                    <div class="info-item animate-scale-up delay-200">
                                        <div class="info-icon">
                                            <i class="fa fa-phone-alt"></i>
                                        </div>
                                        <div class="info-text">
                                            <h4>Main Line</h4>
                                            <p><a href="tel:+966133614446">+966 13 361 4446</a></p>
                                        </div>
                                    </div>

                                    <div class="info-item animate-scale-up delay-300">
                                        <div class="info-icon">
                                            <i class="fa fa-envelope"></i>
                                        </div>
                                        <div class="info-text">
                                            <h4>Email</h4>
                                            <p><a href="mailto:info@petroraq.com">info@petroraq.com</a></p>
                                        </div>
                                    </div>

                                    <div class="info-item animate-scale-up delay-400">
                                        <div class="info-icon">
                                            <i class="fa fa-clock"></i>
                                        </div>
                                        <div class="info-text">
                                            <h4>Business Hours</h4>
                                            <p>Sun-Thu: 8:00 AM - 5:00 PM<br/>Fri-Sat: Closed</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Map Section -->
                        <t t-set="company" t-value="request.website.company_id"/>
                        <t t-set="exact_map_url" t-value="'https://maps.app.goo.gl/WEeertLQtkuy27dr6'"/>
                        <div class="map-section animate-slide-up delay-300">
                            <div class="map-card">
                                <h3>PETRORAQ Engineering &amp; Construction</h3>
                                <p>Majd Square, King Faisal (West) Rd<br/>Al Jubail City, KSA</p>
                                <a t-att-href="exact_map_url" target="_blank" class="map-link">
                                    <i class="fa fa-map-marker-alt"></i>
                                    Open in Google Maps
                                </a>
                            </div>
