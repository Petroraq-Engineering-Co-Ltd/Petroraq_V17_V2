<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="petroraq_homepage_custom" name="Petroraq Homepage">
        <t t-call="website.layout">
            <div id="wrap">
                <style>
                    /* Base animations */
                    @keyframes fadeInUp {
                        from { opacity: 0; transform: translateY(40px); }
                        to { opacity: 1; transform: translateY(0); }
                    }
                    @keyframes fadeInLeft {
                        from { opacity: 0; transform: translateX(-40px); }
                        to { opacity: 1; transform: translateX(0); }
                    }
                    @keyframes fadeInRight {
                        from { opacity: 0; transform: translateX(40px); }
                        to { opacity: 1; transform: translateX(0); }
                    }
                    @keyframes float {
                        0%, 100% { transform: translateY(0px); }
                        50% { transform: translateY(-8px); }
                    }

                    /* Scroll-triggered animations */
                    .scroll-animate {
                        opacity: 0;
                        transform: translateY(40px);
                        transition: opacity 0.8s ease-out, transform 0.8s ease-out;
                    }
                    .scroll-animate.visible {
                        opacity: 1;
                        transform: translateY(0);
                    }
                    .scroll-animate-left {
                        opacity: 0;
                        transform: translateX(-40px);
                        transition: opacity 0.8s ease-out, transform 0.8s ease-out;
                    }
                    .scroll-animate-left.visible {
                        opacity: 1;
                        transform: translateX(0);
                    }
                    .scroll-animate-right {
                        opacity: 0;
                        transform: translateX(40px);
                        transition: opacity 0.8s ease-out, transform 0.8s ease-out;
                    }
                    .scroll-animate-right.visible {
                        opacity: 1;
                        transform: translateX(0);
                    }
                    .delay-1 { transition-delay: 0.1s; }
                    .delay-2 { transition-delay: 0.2s; }
                    .delay-3 { transition-delay: 0.3s; }
                    .delay-4 { transition-delay: 0.4s; }
                    .delay-5 { transition-delay: 0.5s; }

                    /* Hero Section - Background more visible, no shimmer */
                    .hero {
                        position: relative;
                        height: 100vh;
                        min-height: 400px;
                        background: linear-gradient(90deg, rgba(6,38,75,0.75) 0%, rgba(6,38,75,0.4) 60%, rgba(6,38,75,0.15) 100%),
                                    url('pr_website/static/images/hero-bg.png') center/cover no-repeat;
                        color: #fff;
                        overflow: hidden;
                    }
                    .hero-content {
                        position: relative;
                        max-width: 1200px;
                        margin: 0 auto;
                        padding: 100px 10px;
                        z-index: 2;
                        text-align: left;
                    }
                    .hero-content h1 {
                        font-size: clamp(40px, 7vw, 68px);
                        font-weight: 800;
                        line-height: 1.1;
                        margin-bottom: 30px;
                        color: #fff;
                        max-width: 600px;
                        animation: fadeInLeft 1s ease-out;
                    }
                    .hero-content h1 span {
                        color: #e9a23e;
                    }
                    .hero-content p {
                        font-size: 18px;
                        line-height: 1.6;
                        margin-bottom: 40px;
                        max-width: 480px;
                        opacity: 0.95;
                        animation: fadeInLeft 1s ease-out 0.2s both;
                    }
                    .hero-btn {
                        background: linear-gradient(45deg, #e9a23e, #d8902f);
                        border: none;
                        color: #fff;
                        padding: 16px 32px;
                        border-radius: 50px;
                        font-size: 16px;
                        font-weight: 600;
                        cursor: pointer;
                        display: inline-flex;
                        align-items: center;
                        gap: 12px;
                        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
                        box-shadow: 0 8px 25px rgba(233,162,62,0.4);
                        animation: fadeInLeft 1s ease-out 0.4s both;
                    }
                    .hero-btn:hover {
                        transform: translateY(-3px) scale(1.05);
                        box-shadow: 0 15px 35px rgba(233,162,62,0.6);
                    }

                    /* Services Section */
                    .services {
                        max-width: 1200px;
                        margin: -100px auto 80px;
                        padding: 0 40px;
                        display: grid;
                        grid-template-columns: repeat(5, 1fr);
                        gap: 24px;
                        position: relative;
                        z-index: 3;
                    }
                    .service-card {
                        background: #fff;
                        border-radius: 20px;
                        padding: 32px 24px;
                        text-align: center;
                        box-shadow: 0 10px 40px rgba(0,0,0,0.1);
                        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
                        position: relative;
                        overflow: hidden;
                    }
                    .service-card::before {
                        content: '';
                        position: absolute;
                        top: 0;
                        left: 0;
                        right: 0;
                        height: 4px;
                        background: linear-gradient(90deg, #e9a23e, transparent);
                        transform: scaleX(0);
                        transition: transform 0.4s ease;
                    }
                    .service-card:hover::before { transform: scaleX(1); }
                    .service-card:hover {
                        transform: translateY(-12px);
                        box-shadow: 0 25px 60px rgba(0,0,0,0.2);
                    }
                    .service-card .icon {
                        width: 60px;
                        height: 60px;
                        margin: 0 auto 20px;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                    }
                    .service-card .icon img {
                        width: 100%;
                        height: 100%;
                        object-fit: contain;
                        transition: all 0.3s ease;
                    }
                    .service-card:hover .icon img {
                        transform: scale(1.15) rotate(5deg);
                    }
                    .service-card h3 {
                        font-size: 20px;
                        color: #06264B;
                        margin-bottom: 12px;
                        font-weight: 700;
                    }
                    .service-card p {
                        font-size: 14px;
                        color: #6b7280;
                        line-height: 1.6;
                        margin-bottom: 20px;
                    }
                    .service-card .arrow {
                        color: #e9a23e;
                        font-size: 18px;
                        transition: transform 0.3s ease;
                    }
                    .service-card:hover .arrow {
                        transform: translateX(8px);
                    }

                    /* Stats Section - Fixed icon alignment */
                    .stats {
                        background: linear-gradient(135deg, #06264B 0%, #0a3d6e 100%);
                        padding: 60px 40px;
                        max-width: 1200px;
                        margin: 0 auto 80px;
                        border-radius: 24px;
                        display: grid;
                        grid-template-columns: repeat(5, 1fr);
                        gap: 30px;
                        color: #fff;
                        text-align: center;
                    }
                    .stat-item {
                        display: flex;
                        flex-direction: column;
                        align-items: center;
                        justify-content: center;
                        text-align: center;
                    }
                    .stat-item img {
                        width: 50px;
                        height: 50px;
                        object-fit: contain;
                        margin: 0 auto 16px;
                        display: block;
                        transition: all 0.4s ease;
                    }
                    .stat-item:hover img {
                        transform: scale(1.2) translateY(-5px);
                    }
                    .stat-item h2 {
                        font-size: 42px;
                        font-weight: 800;
                        margin-bottom: 8px;
                        color: #e9a23e;
                        text-align: center;
                        width: 100%;
                    }
                    .stat-item p {
                        font-size: 14px;
                        opacity: 0.9;
                        font-weight: 500;
                        text-align: center;
                        width: 100%;
                        margin: 0;
                    }

                    /* Featured Projects */
                    .featured {
                        max-width: 1200px;
                        margin: 0 auto 80px;
                        padding: 0 40px;
                    }
                    .featured-header {
                        display: flex;
                        justify-content: space-between;
                        align-items: center;
                        margin-bottom: 40px;
                        position: relative;
                    }
                    .featured-header::after {
                        content: '';
                        position: absolute;
                        bottom: -8px;
                        left: 0;
                        width: 60px;
                        height: 3px;
                        background: linear-gradient(90deg, #e9a23e, transparent);
                    }
                    .featured-header h2 {
                        font-size: 32px;
                        color: #06264B;
                        font-weight: 700;
                    }
                    .featured-header a {
                        color: #e9a23e;
                        font-size: 15px;
                        font-weight: 600;
                        display: inline-flex;
                        align-items: center;
                        gap: 8px;
                        transition: all 0.3s ease;
                        text-decoration: none;
                    }
                    .featured-header a:hover {
                        color: #d8902f;
                        transform: translateX(5px);
                    }
                    .projects-grid {
                        display: grid;
                        grid-template-columns: repeat(4, 1fr);
                        gap: 24px;
                    }
                    .project-card {
                        background: #fff;
                        border-radius: 16px;
                        overflow: hidden;
                        box-shadow: 0 8px 30px rgba(0,0,0,0.08);
                        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
                        position: relative;
                    }
                    .project-card::before {
                        content: '';
                        position: absolute;
                        top: 0;
                        left: 0;
                        right: 0;
                        height: 4px;
                        background: linear-gradient(90deg, #e9a23e, transparent);
                        transform: scaleX(0);
                        transition: transform 0.4s ease;
                        z-index: 2;
                    }
                    .project-card:hover::before { transform: scaleX(1); }
                    .project-card:hover {
                        transform: translateY(-10px);
                        box-shadow: 0 25px 60px rgba(0,0,0,0.15);
                    }
                    .project-card img {
                        width: 100%;
                        height: 200px;
                        object-fit: cover;
                        transition: transform 0.6s ease;
                    }
                    .project-card:hover img {
                        transform: scale(1.1);
                    }
                    .project-body {
                        padding: 20px;
                    }
                    .project-body h4 {
                        font-size: 16px;
                        color: #06264B;
                        margin-bottom: 8px;
                        font-weight: 700;
                    }
                    .project-body p {
                        font-size: 14px;
                        color: #6b7280;
                        margin-bottom: 12px;
                    }
                    .project-body span {
                        font-size: 13px;
                        color: #e9a23e;
                        font-weight: 700;
                        padding: 4px 12px;
                        background: rgba(233,162,62,0.1);
                        border-radius: 20px;
                    }

                    /* Certifications */
                    .certifications {
                        background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
                        padding: 80px 40px;
                        text-align: center;
                        position: relative;
                    }
                    .certifications h2 {
                        color: #06264B;
                        font-size: 30px;
                        margin-bottom: 50px;
                        font-weight: 700;
                    }
                    .cert-grid {
                        max-width: 1200px;
                        margin: 0 auto;
                        display: grid;
                        grid-template-columns: repeat(3, 1fr);
                        gap: 30px;
                        align-items: center;
                    }
                    .cert-item {
                        text-align: center;
                        font-size: 13px;
                        color: #06264B;
                        padding: 30px 20px;
                        transition: all 0.3s ease;
                        border-radius: 12px;
                        background: rgba(255,255,255,0.6);
                    }
                    .cert-item:hover {
                        transform: translateY(-8px);
                        box-shadow: 0 15px 40px rgba(0,0,0,0.1);
                        background: #fff;
                    }
                    .cert-item img {
                        height: 70px;
                        margin: 0 auto 15px;
                        object-fit: contain;
                        transition: all 0.3s ease;
                    }
                    .cert-item:hover img {
                        transform: scale(1.1);
                    }

                    /* Responsive */
                    @media (max-width: 1024px) {
                        .services, .stats, .projects-grid {
                            grid-template-columns: repeat(3, 1fr);
                        }
                        .hero-content h1 { font-size: 48px; }
                        .services { margin-top: -60px; }
                    }
                    @media (max-width: 768px) {
                        .hero { height: auto; min-height: 70vh; }
                        .hero-content { padding: 80px 20px; text-align: left; }
                        .hero-content h1 { font-size: 36px; }
                        .services, .stats, .projects-grid, .cert-grid { grid-template-columns: repeat(2, 1fr); }
                        .services { margin-top: -40px; padding: 0 20px; }
                        .stats { padding: 40px 20px; }
                        .featured { padding: 0 20px; }
                        .certifications { padding: 60px 20px; }
                    }
                    @media (max-width: 480px) {
                        .services, .stats, .projects-grid, .cert-grid { grid-template-columns: 1fr; }
                        .hero-content h1 { font-size: 28px; }
                    }
                </style>

                <section class="hero">
                    <div class="hero-content">
                        <h1>Engineering<span>.</span><br/>Procurement<span>.</span><br/>Construction<span>.</span></h1>
                        <p>Delivering industrial and infrastructure projects with precision, safety, and excellence.</p>
                        <button class="hero-btn">Explore Our Services
                            <i class="fa fa-arrow-right"></i>
                        </button>
                    </div>
                </section>

                <section class="services">
                    <div class="service-card scroll-animate delay-1">
                        <div class="icon">
                            <img src="pr_website/static/images/civil-icon-home.png"/>
                        </div>
                        <h3>Civil</h3>
                        <p>Structural works, foundations, infrastructure and site development.</p>
                        <i class="fa fa-arrow-right arrow"></i>
                    </div>
                    <div class="service-card scroll-animate delay-2">
                        <div class="icon">
                            <img src="pr_website/static/images/home-mechanical-icon.png"/>
                        </div>
                        <h3>Mechanical</h3>
                        <p>Piping, equipment installation, fabrication and mechanical systems.</p>
                        <i class="fa fa-arrow-right arrow"></i>
                    </div>
                    <div class="service-card scroll-animate delay-3">
                        <div class="icon">
                            <img src="pr_website/static/images/home-electrical-icon.png"/>
                        </div>
                        <h3>Electrical</h3>
                        <p>Power systems, instrumentation, lighting, and electrical installations.</p>
                        <i class="fa fa-arrow-right arrow"></i>
                    </div>
                    <div class="service-card scroll-animate delay-4">
                        <div class="icon">
                            <img src="pr_website/static/images/home-industrial-icon.png"/>
                        </div>
                        <h3>Industrial Projects</h3>
                        <p>End-to-end solutions for industrial plants and process facilities.</p>
                        <i class="fa fa-arrow-right arrow"></i>
                    </div>
                    <div class="service-card scroll-animate delay-5">
                        <div class="icon">
                            <img src="pr_website/static/images/project-home-icon.png"/>
                        </div>
                        <h3>Project Management</h3>
                        <p>Planning, coordination, and control to deliver projects on time and on budget.</p>
                        <i class="fa fa-arrow-right arrow"></i>
                    </div>
                </section>

                <section class="stats scroll-animate">
                    <div class="stat-item">
                        <img src="pr_website/static/images/labors.png" alt="Skilled Professionals"/>
                        <h2>250+</h2>
                        <p>Skilled Professionals</p>
                    </div>
                    <div class="stat-item">
                        <img src="pr_website/static/images/building.png" alt="Projects Completed"/>
                        <h2>150+</h2>
                        <p>Projects Completed</p>
                    </div>
                    <div class="stat-item">
                        <img src="pr_website/static/images/globe.png" alt="Years of Experience"/>
                        <h2>12+</h2>
                        <p>Years of Experience</p>
                    </div>
                    <div class="stat-item">
                        <img src="pr_website/static/images/check_box.png" alt="Lost Time Injury"/>
                        <h2>0</h2>
                        <p>Lost Time Injury (LTI)</p>
                    </div>
                    <div class="stat-item">
                        <img src="pr_website/static/images/hand_shake.png" alt="Client Satisfaction"/>
                        <h2>98%</h2>
                        <p>Client Satisfaction</p>
                    </div>
                </section>

                <section class="featured">
                    <div class="featured-header scroll-animate">
                        <h2>Featured Projects</h2>
                        <a href="/projects">View All Projects
                            <i class="fa fa-arrow-right"></i>
                        </a>
                    </div>
                    <div class="projects-grid">
                        <div class="project-card scroll-animate-left delay-1">
                            <img src="pr_website/static/images/basra.png" alt="Al Basrah Refinery Upgrade"/>
                            <div class="project-body">
                                <h4>Industrial Plant Upgrade – Jubail</h4>
                                <p> Jubail, Saudi Arabia</p>
                                <span>Industrial</span>
                            </div>
                        </div>
                        <div class="project-card scroll-animate delay-2">
                            <img src="pr_website/static/images/missan.png" alt="South Gas Compression Project"/>
                            <div class="project-body">
                                <h4>Commercial Building Fit-Out – Khobar</h4>
                                <p>Khobar, Saudi Arabia</p>
                                <span>Buildings</span>
                            </div>
                        </div>
                        <div class="project-card scroll-animate delay-3">
                            <img src="pr_website/static/images/dhiqar.png" alt="132kV Substation Construction"/>
                            <div class="project-body">
                                <h4>Substation &amp; Electrical Works – Jeddah</h4>
                                <p>Jeddah, Saudi Arabia</p>
                                <span>MEP Work</span>
                            </div>
                        </div>
                        <div class="project-card scroll-animate-right delay-4">
                            <img src="pr_website/static/images/najaf.png" alt="Water Treatment Plant"/>
                            <div class="project-body">
                                <h4>Water Treatment Facility – Dammam</h4>
                                <p>Dammam, Saudi Arabia</p>
                                <span>Infrastructure</span>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="certifications">
                    <h2 class="scroll-animate">Certifications &amp; Compliance</h2>
                    <div class="cert-grid">
                        <div class="cert-item scroll-animate delay-1">
                            <img src="pr_website/static/images/iso-9001.png" alt="ISO 9001"/>
                            <p>9001:2015<br/>Quality Management</p>
                        </div>
                        <div class="cert-item scroll-animate delay-2">
                            <img src="pr_website/static/images/iso-14100.png" alt="ISO 14001"/>
                            <p>14001:2015<br/>Environmental Management</p>
                        </div>
                        <div class="cert-item scroll-animate delay-3">
                            <img src="pr_website/static/images/iso-45001.png" alt="ISO 45001"/>
                            <p>45001:2018<br/>Occupational Health &amp; Safety</p>
                        </div>
                    </div>
                </section>

                <script type="text/javascript">
                    document.addEventListener('DOMContentLoaded', function() {
                        const observerOptions = {
                            threshold: 0.15,
                            rootMargin: '0px 0px -50px 0px'
                        };

                        const observer = new IntersectionObserver(function(entries) {
                            entries.forEach(function(entry) {
                                if (entry.isIntersecting) {
                                    entry.target.classList.add('visible');
                                    observer.unobserve(entry.target);
                                }
                            });
                        }, observerOptions);

                        const animatedElements = document.querySelectorAll('.scroll-animate, .scroll-animate-left, .scroll-animate-right');
                        animatedElements.forEach(function(el) {
                            observer.observe(el);
                        });
                    });
                </script>
            </div>
        </t>
    </template>
</odoo>