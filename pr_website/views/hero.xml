<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Replace the entire homepage content -->
    <template id="petroraq_homepage" inherit_id="website.homepage">

        <!-- REMOVE ALL existing builder content inside the homepage -->
        <xpath expr="//div[@id='wrap']" position="replace">

            <!-- REPLACE WITH CUSTOM CODE -->
            <div id="wrap">

                <!-- ================= HERO SECTION ================= -->
                <section id="petroraq-hero" class="petroraq-hero-carousel">

                    <div id="heroCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel">
                        <div class="carousel-inner">

                            <div class="carousel-item active">
                                <img src="/pr_website/static/images/hero-bg1.jpg" class="hero-img"/>
                            </div>

                            <div class="carousel-item">
                                <img src="/pr_website/static/images/hero-bg2.jpg" class="hero-img"/>
                            </div>

                            <div class="carousel-item">
                                <img src="/pr_website/static/images/hero-bg3.jpg" class="hero-img"/>
                            </div>

                        </div>
                    </div>

                    <div class="hero-overlay">
                        <h1 class="hero-title">YOUR LIFE TIME PARTNER FOR</h1>
                        <h2 class="hero-sub">ENGINEERING - PROCUREMENT - PROJECT MANAGEMENT</h2>
                        <a class="hero-btn" href="/contactus">CONTACT US</a>
                    </div>

                </section>


                <!-- ================= SUCCESS SECTION ================= -->
                <section class="success-section">

                    <!-- YELLOW TOP BLOCK -->
                    <div class="success-yellow">
                        <h5 class="success-small-title">Build Your Dream</h5>
                        <h2 class="success-big-title">+10 Years Of Undefeated Success</h2>

                        <p class="success-desc">
                            PETRORAQ Engineering Co. Ltd. provides comprehensive engineering,
                            design and consultancy services. When required, PETRORAQ teams-up
                            with international affiliates to execute large-scale projects.
                        </p>
                    </div>

                    <!-- FLOATING STATS CARDS -->
                    <div class="success-stats-wrapper">

                        <div class="stat-card">
                            <h1>300+</h1>
                            <p>Successfully Projects Finished.</p>
                        </div>

                        <div class="stat-card">
                            <h1>10+</h1>
                            <p>Years of experience with proud</p>
                        </div>

                    </div>

                </section>
                <!-- ================= ABOUT SECTION ================= -->
                <section id="about-intro-section" class="about-intro">

                    <div class="about-container">

                        <h2 class="about-title">
                            PETRORAQ is a globally
                            <br/>
                            recognized multidisciplinary
                            <br/>
                            engineering and construction
                            <br/>
                            enterprise
                        </h2>

                        <p class="about-text">
                            Delivering end-to-end solutions across the architectural and infrastructure
                            sectors. With a steadfast commitment to innovation and excellence, we
                            provide comprehensive services encompassing engineering consultancy,
                            construction, procurement, and project management. Our expertise spans a
                            diverse portfolio, including urban planning, architectural design,
                            structural engineering, and systems integration for lighting, power,
                            HVAC, telecommunications, and utility networks.
                        </p>

                        <p class="about-text">
                            As a leader in environmental sustainability, PETRORAQ specializes in critical
                            areas such as water and wastewater treatment, air quality management,
                            and ecological landscape development. Our multidisciplinary approach also
                            extends to healthcare infrastructure, plant maintenance, and construction
                            supervision — ensuring holistic project execution that meets the highest
                            international standards.
                        </p>

                        <!-- Buttons -->
                        <div class="about-buttons">
                            <a href="/about-us" class="about-btn yellow-btn">READ MORE ABOUT US</a>
                            <a href="/company-profile.pdf" class="about-btn outline-btn">
                                <i class="fa fa-download"></i>
                                DOWNLOAD COMPANY PROFILE
                            </a>
                        </div>

                    </div>

                </section>
                <!-- ================= ISO CERTIFICATES SECTION ================= -->
                <section id="iso-certificates-section" class="iso-section">

                    <div class="iso-overlay">
                        <div class="iso-content">

                            <h2 class="iso-title">OUR ISO CERTIFICATES</h2>

                            <div class="iso-cert-row">

                                <div class="iso-cert-card">
                                    <img src="/pr_website/static/images/cf-1.jpg" alt="ISO 9001 Certificate"/>
                                </div>

                                <div class="iso-cert-card">
                                    <img src="/pr_website/static/images/cf-2.jpg" alt="ISO 14001 Certificate"/>
                                </div>

                                <div class="iso-cert-card">
                                    <img src="/pr_website/static/images/cf-3.jpg" alt="ISO 45001 Certificate"/>
                                </div>

                            </div>

                        </div>
                    </div>

                </section>
                <!-- ========================= -->
                <!-- OUR SERVICES SECTION -->
                <!-- ========================= -->
                <section id="services-section" class="services-wrapper">

                    <h2 class="services-title">Our Services</h2>

                    <div class="services-grid">

                        <!-- 1: Design & Engineering -->
                        <div class="service-card">
                            <img src="/pr_website/static/images/design.jpg" class="service-img"/>
                            <h3 class="service-title">Design &amp; Engineering</h3>
                            <p class="service-desc">
                                PETRORAQ Engineering Co. Ltd. provides comprehensive multi-disciplinary engineering,
                                design and consultancy services...
                            </p>
                            <a href="#" class="service-btn">KNOW MORE</a>
                        </div>

                        <!-- 2: Architecture & Planning -->
                        <div class="service-card">
                            <img src="/pr_website/static/images/arch.jpeg" class="service-img"/>
                            <h3 class="service-title">Architecture &amp; Planning</h3>
                            <p class="service-desc">
                                PETRORAQ Architectural team comprises qualified architects with expertise in community
                                planning &amp; site development...
                            </p>
                            <a href="#" class="service-btn">KNOW MORE</a>
                        </div>

                        <!-- 3: Civil & Structural -->
                        <div class="service-card">
                            <img src="/pr_website/static/images/civil.png" class="service-img"/>
                            <h3 class="service-title">Civil and Structural</h3>
                            <p class="service-desc">
                                Expertise in reinforced concrete and steel structures using advanced engineering
                                tools...
                            </p>
                            <a href="#" class="service-btn">KNOW MORE</a>
                        </div>

                        <!-- 4: Electrical -->
                        <div class="service-card">
                            <img src="/pr_website/static/images/elec.jpg" class="service-img"/>
                            <h3 class="service-title">Electrical</h3>
                            <p class="service-desc">
                                Experienced engineers delivering lighting, power distribution and control systems...
                            </p>
                            <a href="#" class="service-btn">KNOW MORE</a>
                        </div>

                        <!-- 5: Mechanical & Piping -->
                        <div class="service-card">
                            <img src="/pr_website/static/images/mech.png" class="service-img"/>
                            <h3 class="service-title">Mechanical &amp; Piping</h3>
                            <p class="service-desc">
                                Fully qualified engineers for tanks, piping systems, mechanical equipment and more...
                            </p>
                            <a href="#" class="service-btn">KNOW MORE</a>
                        </div>

                        <!-- 6: CAD Services -->
                        <div class="service-card">
                            <img src="/pr_website/static/images/cad.png" class="service-img"/>
                            <h3 class="service-title">CAD Services</h3>
                            <p class="service-desc">
                                Professional CAD services using BIM, Revit, Tekla, AutoCAD, SketchUp and more...
                            </p>
                            <a href="#" class="service-btn">KNOW MORE</a>
                        </div>

                    </div>

                </section>

                <!-- ========================= -->
                <!-- PROVIDE + SUSTAINABILITY SECTION -->
                <!-- ========================= -->
                <section id="provide-sustain-section" class="provide-sustain-wrapper">

                    <!-- ===== ROW 1: We Also Provide ===== -->
                    <div class="provide-row" style="background-image: url('/pr_website/static/images/hero-bg1.jpg');">
                        <div class="provide-content">
                            <h3 class="provide-title">WE ALSO PROVIDE</h3>
                            <ul class="provide-list">
                                <li>ENVIRONMENTAL ENGINEERING</li>
                                <li>CONSTRUCTION MANAGEMENT</li>
                                <li>PROJECT MANAGEMENT</li>
                            </ul>

                            <a href="#" class="provide-btn">READ MORE</a>
                        </div>
                    </div>

                    <!-- ===== ROW 2: Two Columns ===== -->
                    <div class="two-col-row">

                        <!-- LEFT COLUMN -->
                        <div class="left-col" style="background-image: url('/pr_website/static/images/hero-bg2.jpg');">
                            <div class="left-col-content">
                                <span class="small-yellow">Sustainability</span>

                                <h2 class="left-title">Committed To fulfill<br/>clients needs
                                </h2>

                                <p class="left-desc">
                                    Cultivate high standards of ethics and responsibility amongst staff as a corporate
                                    culture to deliver the best services required.
                                </p>

                                <a href="/contactus" class="left-btn">GET IN TOUCH</a>
                            </div>
                        </div>

                        <!-- RIGHT COLUMN -->
                        <div class="right-col">
                            <div class="right-inner-overlay">

                                <h3 class="right-title">We Follow Best Practices</h3>
                                <p class="right-sub">Customer satisfaction is our priority</p>

                                <ul class="practice-list">
                                    <li>♻️ Sustainability</li>
                                    <li>⏱ Project On Time</li>
                                    <li>💻 Modern Technology</li>
                                    <li>🛠 Latest Designs</li>
                                </ul>

                            </div>
                        </div>

                    </div>

                </section>

                <section id="pr-request-quote-section" class="pr-quote-wrapper">

                    <div class="pr-quote-container">

                        <!-- LEFT FORM -->
                        <div class="pr-quote-form">
                            <h2>Request a Quote</h2>
                            <p class="pr-quote-sub">Ready to Work Together? Build a project with us!</p>

                            <form>
                                <input type="text" placeholder="Enter your name" required="1"/>
                                <input type="email" placeholder="Enter your email address" required="1"/>
                                <input type="text" placeholder="Subject" required="1"/>
                                <textarea placeholder="Message"></textarea>

                                <button type="submit" class="pr-quote-btn">SEND MESSAGE</button>
                            </form>
                        </div>

                        <!-- RIGHT INFO -->
                        <div class="pr-quote-info">
                            <h4 class="pr-quote-label">Contact Us</h4>
                            <h2 class="pr-quote-title">Reach us at.</h2>

                            <p class="pr-info-item">
                                <strong>Phone:</strong>
                                +966 13 361 4446
                            </p>
                            <p class="pr-info-item">
                                <strong>Email:</strong>
                                info@petroraq.com
                            </p>
                            <p class="pr-info-item">Jubail, KSA</p>
                        </div>

                    </div>

                </section>


            </div>

        </xpath>

    </template>
</odoo>
