<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- The sale template is already branded; use its matching report sheet. -->
    <record id="sale.action_report_saleorder" model="ir.actions.report">
        <field name="paperformat_id" ref="pr_tax_Invoice_report_custom.paperformat_petroraq_invoice_report_sheet"/>
    </record>

    <!--
        Replace the invoice bridge so CSS is emitted as CSS, not as visible
        text above the invoice preview.
    -->
    <template id="pr_tax_Invoice_report_custom.custom_invoice_bridge_layout"
              name="Petroraq Invoice Bridge Layout">
        <style>
            .header, .footer {
                margin: 0 !important;
                padding: 0 !important;
            }
        </style>
        <t t-if="not o and doc">
            <t t-set="o" t-value="doc"/>
        </t>
        <t t-if="o and 'company_id' in o">
            <t t-set="company" t-value="o.company_id.sudo()"/>
        </t>
        <t t-if="not o or not 'company_id' in o">
            <t t-set="company" t-value="res_company"/>
        </t>
        <t t-call="pr_tax_Invoice_report_custom.custom_invoice_header_layout"/>
        <div class="article">
            <t t-raw="0"/>
        </div>
        <t t-call="pr_tax_Invoice_report_custom.custom_invoice_footer_layout"/>
    </template>
</odoo>
