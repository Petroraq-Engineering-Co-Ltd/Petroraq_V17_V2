<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_vendor_invoice_reviewer" model="res.groups">
        <field name="name">Vendor Invoice Reviewer</field>
        <field name="category_id" ref="base.module_category_accounting"/>
    </record>

    <record id="vendor_invoice_portal_rule" model="ir.rule">
        <field name="name">Portal Vendor: Own Uploaded Invoices</field>
        <field name="model_id" ref="model_pr_portal_vendor_invoice"/>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="domain_force">[('partner_id', 'child_of', [user.commercial_partner_id.id])]</field>
    </record>

    <record id="vendor_invoice_internal_rule" model="ir.rule">
        <field name="name">Internal Users: Vendor Portal Invoices</field>
        <field name="model_id" ref="model_pr_portal_vendor_invoice"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="sale.sale_order_rule_portal" model="ir.rule">
        <field name="domain_force">[('id', '=', 0)]</field>
    </record>

    <record id="sale.sale_order_line_rule_portal" model="ir.rule">
        <field name="domain_force">[('id', '=', 0)]</field>
    </record>

    <record id="account.account_invoice_rule_portal" model="ir.rule">
        <field name="domain_force">[
            ('state', 'not in', ('cancel', 'draft')),
            ('move_type', 'in', ('in_invoice', 'in_refund')),
            '|', '|',
            ('message_partner_ids', 'child_of', [user.commercial_partner_id.id]),
            ('partner_id', 'child_of', [user.commercial_partner_id.id]),
            ('commercial_partner_id', '=', user.commercial_partner_id.id)
        ]</field>
    </record>

    <record id="account.account_invoice_line_rule_portal" model="ir.rule">
        <field name="domain_force">[
            ('parent_state', 'not in', ('cancel', 'draft')),
            ('move_id.move_type', 'in', ('in_invoice', 'in_refund')),
            '|', '|',
            ('move_id.message_partner_ids', 'child_of', [user.commercial_partner_id.id]),
            ('move_id.partner_id', 'child_of', [user.commercial_partner_id.id]),
            ('move_id.commercial_partner_id', '=', user.commercial_partner_id.id)
        ]</field>
    </record>
</odoo>
