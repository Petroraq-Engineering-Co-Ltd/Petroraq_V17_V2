<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Odoo's standard sale, purchase, and account modules add broad portal
        cards. This module replaces them with role-aware customer/vendor cards.
    -->
    <template id="portal_my_home_remove_standard_sale_card"
              inherit_id="sale.portal_my_home_sale"
              priority="100">
        <xpath expr="//div[@id='portal_client_category']/t[@t-call='portal.portal_docs_entry'][t[@t-set='url' and @t-value=&quot;'/my/orders'&quot;]]"
               position="replace"/>
    </template>

    <template id="portal_my_home_remove_standard_account_cards"
              inherit_id="account.portal_my_home_invoice"
              priority="100">
        <xpath expr="//div[@id='portal_client_category']/t[@t-call='portal.portal_docs_entry'][t[@t-set='url' and @t-value=&quot;'/my/invoices?filterby=invoices'&quot;]]"
               position="replace"/>
        <xpath expr="//div[@id='portal_vendor_category']/t[@t-call='portal.portal_docs_entry'][t[@t-set='url' and @t-value=&quot;'/my/invoices?filterby=bills'&quot;]]"
               position="replace"/>
    </template>

    <template id="portal_my_home_remove_standard_purchase_cards"
              inherit_id="purchase.portal_my_home_purchase"
              priority="100">
        <xpath expr="//div[@id='portal_vendor_category']/t[@t-call='portal.portal_docs_entry'][t[@t-set='url' and @t-value=&quot;'/my/rfq'&quot;]]"
               position="replace"/>
        <xpath expr="//div[@id='portal_vendor_category']/t[@t-call='portal.portal_docs_entry'][t[@t-set='url' and @t-value=&quot;'/my/purchase'&quot;]]"
               position="replace"/>
    </template>

    <template id="portal_breadcrumbs_delivery_vendor_invoice" inherit_id="portal.portal_breadcrumbs" priority="35">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <li t-if="page_name == 'delivery'" t-attf-class="breadcrumb-item #{'active ' if not picking else ''}">
                <a t-if="picking" href="/my/deliveries">Deliveries</a>
                <t t-else="">Deliveries</t>
            </li>
            <li t-if="page_name == 'delivery' and picking" class="breadcrumb-item active">
                <t t-out="picking.name"/>
            </li>
            <li t-if="page_name == 'vendor_invoice_upload'" class="breadcrumb-item active">
                Upload Invoice
            </li>
            <li t-if="page_name == 'statement'" class="breadcrumb-item active">
                Statement of Account
            </li>
        </xpath>
    </template>

    <template id="portal_my_home_vendor_customer" inherit_id="portal.portal_my_home" customize_show="True" priority="35">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="before">
            <t t-set="portal_client_category_enable"
               t-value="request.env.user.partner_id.commercial_partner_id.customer_rank &gt; 0"/>
            <t t-set="portal_vendor_category_enable"
               t-value="request.env.user.partner_id.commercial_partner_id.supplier_rank &gt; 0"/>
            <div class="o_pr_portal_intro">
                <h4>Portal Workspace</h4>
                <p t-if="request.env.user.partner_id.commercial_partner_id.customer_rank and request.env.user.partner_id.commercial_partner_id.supplier_rank">
                    Use the customer area for quotations, orders, invoices, and deliveries. Use the vendor area for RFQs, purchase orders, bills, and invoice submissions.
                </p>
                <p t-elif="request.env.user.partner_id.commercial_partner_id.customer_rank">
                    Review your quotations, confirmed sale orders, invoices, and outbound deliveries from one place.
                </p>
                <p t-elif="request.env.user.partner_id.commercial_partner_id.supplier_rank">
                    Review RFQs and purchase orders, view posted bills, and submit invoice PDFs to Accounts.
                </p>
                <p t-else="">
                    Your available documents and account settings are shown below.
                </p>
            </div>
        </xpath>
        <div id="portal_client_category" position="inside">
            <t t-if="request.env.user.partner_id.commercial_partner_id.customer_rank">
                <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/sale/static/description/icon.png'"/>
                    <t t-set="title">Quotations</t>
                    <t t-set="url" t-value="'/my/quotes'"/>
                    <t t-set="text">View your quotations</t>
                    <t t-set="placeholder_count" t-value="'quotation_count'"/>
                </t>
                <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/sale/static/description/icon.png'"/>
                    <t t-set="title">Sale Orders</t>
                    <t t-set="url" t-value="'/my/orders'"/>
                    <t t-set="text">View your confirmed sale orders</t>
                    <t t-set="placeholder_count" t-value="'order_count'"/>
                </t>
                <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/account/static/src/img/Bill.svg'"/>
                    <t t-set="title">Invoices</t>
                    <t t-set="url" t-value="'/my/invoices?filterby=invoices'"/>
                    <t t-set="text">View and download your invoices</t>
                    <t t-set="placeholder_count" t-value="'invoice_count'"/>
                </t>
                <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/stock/static/description/icon.png'"/>
                    <t t-set="title">Deliveries</t>
                    <t t-set="url" t-value="'/my/deliveries'"/>
                    <t t-set="text">View your delivery orders</t>
                    <t t-set="placeholder_count" t-value="'delivery_count'"/>
                </t>
                <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/account/static/src/img/Bill.svg'"/>
                    <t t-set="title">Statement of Account</t>
                    <t t-set="url" t-value="'/my/statement'"/>
                    <t t-set="text">Review receivable, payable, and ledger activity</t>
                    <t t-set="placeholder_count" t-value="'statement_count'"/>
                </t>
            </t>
        </div>
        <div id="portal_vendor_category" position="inside">
            <t t-if="request.env.user.partner_id.commercial_partner_id.supplier_rank">
                <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/purchase/static/description/icon.png'"/>
                    <t t-set="title">RFQs</t>
                    <t t-set="url" t-value="'/my/rfq'"/>
                    <t t-set="text">View requests for quotation</t>
                    <t t-set="placeholder_count" t-value="'rfq_count'"/>
                </t>
                <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/purchase/static/description/icon.png'"/>
                    <t t-set="title">Purchase Orders</t>
                    <t t-set="url" t-value="'/my/purchase'"/>
                    <t t-set="text">View purchase orders issued to you</t>
                    <t t-set="placeholder_count" t-value="'purchase_count'"/>
                </t>
                <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/account/static/src/img/Bill.svg'"/>
                    <t t-set="title">Bills</t>
                    <t t-set="url" t-value="'/my/invoices?filterby=bills'"/>
                    <t t-set="text">View vendor bills</t>
                    <t t-set="placeholder_count" t-value="'bill_count'"/>
                </t>
                <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/account/static/src/img/Bill.svg'"/>
                    <t t-set="title">Upload Invoice</t>
                    <t t-set="url" t-value="'/vendor/invoice/upload'"/>
                    <t t-set="text">Submit an invoice against a purchase order</t>
                    <t t-set="config_card" t-value="True"/>
                </t>
                <t t-if="not request.env.user.partner_id.commercial_partner_id.customer_rank"
                   t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/account/static/src/img/Bill.svg'"/>
                    <t t-set="title">Statement of Account</t>
                    <t t-set="url" t-value="'/my/statement'"/>
                    <t t-set="text">Review payable balance and ledger activity</t>
                    <t t-set="placeholder_count" t-value="'statement_count'"/>
                </t>
            </t>
        </div>
    </template>

    <template id="portal_purchase_order_vendor_invoice_upload"
              inherit_id="purchase.portal_my_purchase_order"
              priority="40">
        <xpath expr="//div[hasclass('o_download_pdf')]" position="after">
            <div t-if="order.state in ['purchase', 'done']" class="mt-2">
                <a class="btn btn-primary w-100"
                   t-att-href="'/vendor/invoice/upload?po_id=%s' % order.id">
                    <i class="fa fa-upload me-1"/>
                    Upload Invoice
                </a>
            </div>
        </xpath>
        <xpath expr="//div[@id='portal_purchase_content']" position="before">
            <div t-if="request.params.get('invoice_uploaded')"
                 class="alert alert-success d-print-none"
                 role="alert">
                <strong>Invoice attached successfully.</strong>
                The PDF is now attached to this purchase order and Accounts has been notified.
            </div>
        </xpath>
    </template>

    <template id="portal_my_statement" name="Portal Statement of Account">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Statement of Account</t>
            </t>

            <div class="o_pr_portal_intro">
                <h5>Account activity for <t t-out="statement['partner_name']"/></h5>
                <p>
                    Posted invoices, bills, payments, journal entries, and entries from your configured ledger account are shown below in company currency.
                </p>
            </div>

            <div t-foreach="statement_errors" t-as="error" class="alert alert-warning" role="alert">
                <t t-out="error"/>
            </div>
            <div t-if="statement['shared_ledger_account']" class="alert alert-info" role="alert">
                The configured ledger account is shared. For privacy, direct ledger entries are restricted to entries explicitly posted against your company.
            </div>
            <div t-if="not statement['mapped_account_id']" class="alert alert-secondary" role="alert">
                No dedicated ledger account is configured. This statement currently includes your posted receivable and payable entries.
            </div>

            <div class="o_pr_statement_toolbar">
                <form action="/my/statement" method="get" class="row g-3 align-items-end">
                    <div class="col-sm-5 col-lg-3">
                        <label class="form-label" for="statement_date_from">From</label>
                        <input id="statement_date_from" name="date_from" type="date"
                               class="form-control" t-att-value="date_from"/>
                    </div>
                    <div class="col-sm-5 col-lg-3">
                        <label class="form-label" for="statement_date_to">To</label>
                        <input id="statement_date_to" name="date_to" type="date"
                               class="form-control" t-att-value="date_to"/>
                    </div>
                    <div class="col-sm-2 col-lg-auto">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fa fa-filter me-1"/>
                            Apply
                        </button>
                    </div>
                    <div class="col-lg-auto ms-lg-auto">
                        <a class="btn btn-secondary w-100"
                           t-att-href="'/my/statement/download?date_from=%s&amp;date_to=%s' % (date_from, date_to)">
                            <i class="fa fa-download me-1"/>
                            Download PDF
                        </a>
                    </div>
                </form>
            </div>

            <div class="row g-3 o_pr_statement_summary">
                <div class="col-md-4">
                    <div class="o_pr_statement_card o_pr_statement_receivable">
                        <span>Receivable</span>
                        <strong t-out="statement['amount_receivable']"
                                t-options="{'widget': 'monetary', 'display_currency': statement_currency}"/>
                        <small>Amount due to Petroraq</small>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="o_pr_statement_card o_pr_statement_payable">
                        <span>Payable</span>
                        <strong t-out="statement['amount_payable']"
                                t-options="{'widget': 'monetary', 'display_currency': statement_currency}"/>
                        <small>Amount payable to you</small>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="o_pr_statement_card">
                        <span>Net Balance</span>
                        <strong t-out="statement['net_balance']"
                                t-options="{'widget': 'monetary', 'display_currency': statement_currency}"/>
                        <small><t t-out="statement['entry_count']"/> transaction(s) in this period</small>
                    </div>
                </div>
            </div>

            <div t-if="not statement['entry_count'] and not statement['opening_balance']"
                 class="alert alert-warning mt-3" role="alert">
                There are no posted account entries for the selected period.
            </div>

            <div t-foreach="statement['accounts']" t-as="account_group"
                 class="o_pr_statement_account">
                <div class="o_pr_statement_account_header">
                    <div>
                        <strong>
                            <t t-out="account_group['code']"/> -
                            <t t-out="account_group['name']"/>
                        </strong>
                        <span t-if="account_group['is_mapped']" class="badge text-bg-primary ms-2">
                            Configured Ledger Account
                        </span>
                    </div>
                    <div>
                        Closing:
                        <strong t-out="account_group['closing_balance']"
                                t-options="{'widget': 'monetary', 'display_currency': statement_currency}"/>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Document</th>
                                <th class="d-none d-lg-table-cell">Reference</th>
                                <th>Description</th>
                                <th class="text-end">Debit</th>
                                <th class="text-end">Credit</th>
                                <th class="text-end">Balance</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="o_pr_statement_opening">
                                <td><t t-out="date_from"/></td>
                                <td colspan="3">Opening Balance</td>
                                <td/>
                                <td/>
                                <td class="text-end">
                                    <span t-out="account_group['opening_balance']"
                                          t-options="{'widget': 'monetary', 'display_currency': statement_currency}"/>
                                </td>
                            </tr>
                            <tr t-foreach="account_group['entries']" t-as="entry">
                                <td><span t-out="entry['date_display']"/></td>
                                <td>
                                    <a t-if="entry['is_invoice']"
                                       t-att-href="'/my/invoices/%s' % entry['move_id']">
                                        <t t-out="entry['move_name']"/>
                                    </a>
                                    <t t-else="" t-out="entry['move_name']"/>
                                </td>
                                <td class="d-none d-lg-table-cell"><t t-out="entry['reference']"/></td>
                                <td><t t-out="entry['description']"/></td>
                                <td class="text-end">
                                    <span t-out="entry['debit']"
                                          t-options="{'widget': 'monetary', 'display_currency': statement_currency}"/>
                                </td>
                                <td class="text-end">
                                    <span t-out="entry['credit']"
                                          t-options="{'widget': 'monetary', 'display_currency': statement_currency}"/>
                                </td>
                                <td class="text-end">
                                    <strong t-out="entry['balance']"
                                            t-options="{'widget': 'monetary', 'display_currency': statement_currency}"/>
                                </td>
                            </tr>
                        </tbody>
                        <tfoot>
                            <tr>
                                <th colspan="4">Period Total</th>
                                <th class="text-end">
                                    <span t-out="account_group['period_debit']"
                                          t-options="{'widget': 'monetary', 'display_currency': statement_currency}"/>
                                </th>
                                <th class="text-end">
                                    <span t-out="account_group['period_credit']"
                                          t-options="{'widget': 'monetary', 'display_currency': statement_currency}"/>
                                </th>
                                <th class="text-end">
                                    <span t-out="account_group['closing_balance']"
                                          t-options="{'widget': 'monetary', 'display_currency': statement_currency}"/>
                                </th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </t>
    </template>

    <template id="portal_my_deliveries" name="My Deliveries">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Deliveries</t>
            </t>
            <div class="o_pr_portal_intro">
                <h5>Customer Deliveries</h5>
                <p>
                    This page shows outbound deliveries linked to your customer account. Open a delivery to review its items and download the official Petroraq Delivery Note PDF.
                </p>
            </div>
            <div t-if="not deliveries" class="alert alert-warning" role="alert">
                There are currently no deliveries for your account.
            </div>
            <t t-if="deliveries" t-call="portal.portal_table">
                <thead>
                    <tr>
                        <th>Delivery</th>
                        <th>Source</th>
                        <th class="text-end">Scheduled Date</th>
                        <th class="text-end">Status</th>
                    </tr>
                </thead>
                <tbody>
                    <tr t-foreach="deliveries" t-as="delivery">
                        <td>
                            <a t-att-href="'/my/deliveries/%s' % delivery.id">
                                <t t-out="delivery.name"/>
                            </a>
                        </td>
                        <td>
                            <t t-out="delivery.origin or delivery.sale_id.name or ''"/>
                        </td>
                        <td class="text-end">
                            <span t-field="delivery.scheduled_date"/>
                        </td>
                        <td class="text-end">
                            <span t-field="delivery.state"/>
                        </td>
                    </tr>
                </tbody>
            </t>
        </t>
    </template>

    <template id="portal_delivery_page" name="Delivery Details">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Delivery Details</t>
            </t>
            <div class="o_pr_portal_intro">
                <h5>Delivery Note</h5>
                <p>
                    Quantities and status come from the linked warehouse delivery. Use Download to obtain the branded Delivery Note PDF.
                </p>
            </div>
            <div class="d-flex flex-wrap gap-3 justify-content-between align-items-center mb-3">
                <div>
                    <h3 class="mb-1">
                        <t t-out="picking.name"/>
                    </h3>
                    <div class="text-muted">
                        <t t-out="picking.origin or picking.sale_id.name or ''"/>
                    </div>
                </div>
                <a class="btn btn-secondary" t-att-href="'/my/deliveries/%s/download' % picking.id">
                    <i class="fa fa-download me-1"/>
                    Download
                </a>
            </div>

            <div class="row mb-4">
                <div class="col-md-6">
                    <strong>Delivery Address</strong>
                    <div t-if="picking.delivery_note_ship_to_address" style="white-space: pre-line;" t-esc="picking.delivery_note_ship_to_address"/>
                    <div t-elif="picking.partner_id" t-field="picking.partner_id" t-options="{'widget': 'contact', 'fields': ['address', 'name'], 'no_marker': True}"/>
                </div>
                <div class="col-md-6 text-md-end">
                    <div>
                        <strong>Scheduled Date:</strong>
                        <span t-field="picking.scheduled_date"/>
                    </div>
                    <div>
                        <strong>Status:</strong>
                        <span t-field="picking.state"/>
                    </div>
                </div>
            </div>

            <t t-call="portal.portal_table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Product</th>
                        <th>Description</th>
                        <th class="text-end">Demand</th>
                        <th class="text-end">Done</th>
                        <th>UoM</th>
                    </tr>
                </thead>
                <tbody>
                    <tr t-foreach="picking.move_ids_without_package" t-as="move">
                        <td>
                            <t t-out="move_index + 1"/>
                        </td>
                        <td>
                            <t t-out="move.product_id.display_name"/>
                        </td>
                        <td>
                            <t t-out="move.description_picking or move.name"/>
                        </td>
                        <td class="text-end">
                            <span t-field="move.product_uom_qty"/>
                        </td>
                        <td class="text-end">
                            <t t-out="move.quantity if 'quantity' in move._fields else move.quantity_done"/>
                        </td>
                        <td>
                            <span t-field="move.product_uom"/>
                        </td>
                    </tr>
                </tbody>
            </t>
        </t>
    </template>

    <template id="portal_vendor_invoice_upload" name="Upload Vendor Invoice">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Upload Invoice</t>
            </t>
            <div class="row justify-content-center">
                <div class="col-lg-8 col-xl-7">
                    <div class="o_pr_portal_workflow">
                        <strong>Attach your invoice to the purchase order</strong>
                        <ul>
                            <li>Select the confirmed purchase order this invoice belongs to.</li>
                            <li>Use your supplier invoice number; it must be unique for your company.</li>
                            <li>Attach a valid PDF no larger than 10 MB and enter an amount greater than zero.</li>
                            <li>The PDF and invoice details will be stored directly on the purchase order and Accounts will be notified.</li>
                        </ul>
                    </div>
                    <div t-if="error_message" class="alert alert-danger" role="alert">
                        <t t-foreach="error_message" t-as="message">
                            <div t-out="message"/>
                        </t>
                    </div>
                    <form action="/vendor/invoice/upload" method="post" enctype="multipart/form-data" class="o_portal_form">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <div class="mb-3">
                            <label class="form-label" for="po_id">Purchase Order</label>
                            <select id="po_id" name="po_id" class="form-select" required="required">
                                <option value="">Select a purchase order</option>
                                <t t-foreach="purchase_orders" t-as="po">
                                    <option t-att-value="po.id" t-att-selected="po.id == selected_po_id">
                                        <t t-out="po.name"/>
                                        <t t-if="po.partner_ref"> - <t t-out="po.partner_ref"/></t>
                                    </option>
                                </t>
                            </select>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label" for="vendor_invoice_number">Invoice Number</label>
                                <input id="vendor_invoice_number" name="vendor_invoice_number" type="text" class="form-control" required="required" t-att-value="form_data.get('vendor_invoice_number')"/>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label" for="invoice_date">Invoice Date</label>
                                <input id="invoice_date" name="invoice_date" type="date" class="form-control" required="required" t-att-value="form_data.get('invoice_date')"/>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label" for="amount_total">Invoice Amount</label>
                                <input id="amount_total" name="amount_total" type="number" step="0.01" min="0.01" class="form-control" required="required" t-att-value="form_data.get('amount_total')"/>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label" for="invoice_file">Invoice PDF</label>
                                <input id="invoice_file"
                                       name="invoice_file"
                                       type="file"
                                       accept=".pdf,application/pdf"
                                       class="form-control"
                                       required="required"
                                       aria-describedby="invoice_file_help"/>
                                <div id="invoice_file_help" class="form-text">PDF only, maximum 10 MB.</div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="notes">Notes</label>
                            <textarea id="notes" name="notes" class="form-control" rows="4"><t t-out="form_data.get('notes')"/></textarea>
                        </div>
                        <div class="d-flex gap-2 justify-content-end">
                            <a class="btn btn-secondary"
                               t-att-href="'/my/purchase/%s' % selected_po_id if selected_po_id else '/my/purchase'">
                                Cancel
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fa fa-upload me-1"/>
                                Attach to Purchase Order
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </t>
    </template>
</odoo>
