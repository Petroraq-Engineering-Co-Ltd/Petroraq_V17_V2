<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Odoo's standard sale, purchase, and account modules add broad portal
        cards. This module replaces them with a focused vendor portal.
    -->
    <template id="portal_my_home_remove_standard_sale_card"
              inherit_id="sale.portal_my_home_sale"
              priority="100">
        <xpath expr="//div[@id='portal_client_category']/t[@t-call='portal.portal_docs_entry'][t[@t-set='url' and @t-value=&quot;'/my/quotes'&quot;]]"
               position="replace"/>
        <xpath expr="//div[@id='portal_client_category']/t[@t-call='portal.portal_docs_entry'][t[@t-set='url' and @t-value=&quot;'/my/orders'&quot;]]"
               position="replace"/>
    </template>

    <template id="portal_record_sidebar_remove_odoo_branding"
              inherit_id="portal.portal_record_sidebar"
              priority="100">
        <xpath expr="//div[@id='sidebar_content']/div[hasclass('d-none', 'd-lg-block', 'mt-5', 'text-center', 'text-muted')]"
               position="replace"/>
    </template>

    <template id="portal_sale_order_remove_last_invoices"
              inherit_id="sale.sale_order_portal_content"
              priority="100">
        <xpath expr="//div[@id='sale_invoices']" position="replace"/>
    </template>

    <template id="portal_sale_order_remove_last_deliveries"
              inherit_id="sale.sale_order_portal_content"
              priority="110">
        <xpath expr="//div[@t-if='delivery_orders']" position="replace"/>
    </template>

    <template id="portal_my_sales_order_status_column"
              inherit_id="sale.portal_my_orders"
              priority="100">
        <xpath expr="//thead/tr/th[3]" position="replace">
            <th class="text-center">Status</th>
        </xpath>
        <xpath expr="//t[@t-foreach='orders']/tr/td[3]" position="replace">
            <td class="text-center">
                <span t-if="order.state == 'cancel'"
                      class="badge rounded-pill text-bg-danger">
                    <i class="fa fa-fw fa-times" role="img" aria-label="Cancelled" title="Cancelled"/>
                    Cancelled
                </span>
                <span t-elif="order.locked or order.state == 'done'"
                      class="badge rounded-pill text-bg-success">
                    <i class="fa fa-fw fa-check" role="img" aria-label="Done" title="Done"/>
                    Done
                </span>
                <span t-elif="order.state == 'sale'"
                      class="badge rounded-pill text-bg-primary">
                    <i class="fa fa-fw fa-check-circle" role="img" aria-label="Confirmed" title="Confirmed"/>
                    Confirmed
                </span>
                <span t-elif="order.state == 'sent'"
                      class="badge rounded-pill text-bg-info">
                    <i class="fa fa-fw fa-paper-plane" role="img" aria-label="Sent" title="Sent"/>
                    Sent
                </span>
                <span t-else=""
                      class="badge rounded-pill text-bg-secondary">
                    <i class="fa fa-fw fa-file-o" role="img" aria-label="Draft" title="Draft"/>
                    Draft
                </span>
            </td>
        </xpath>
    </template>

    <template id="portal_my_home_remove_standard_account_cards"
              inherit_id="account.portal_my_home_invoice"
              priority="100">
        <xpath expr="//div[@id='portal_client_category']/t[@t-call='portal.portal_docs_entry'][t[@t-set='url' and @t-value=&quot;'/my/invoices?filterby=invoices'&quot;]]"
               position="replace"/>
        <xpath expr="//div[@id='portal_vendor_category']/t[@t-call='portal.portal_docs_entry'][t[@t-set='url' and @t-value=&quot;'/my/invoices?filterby=bills'&quot;]]"
               position="replace"/>
    </template>

    <template id="portal_my_home_remove_standard_purchase_cards"
              inherit_id="purchase.portal_my_home_purchase"
              priority="100">
        <xpath expr="//div[@id='portal_vendor_category']/t[@t-call='portal.portal_docs_entry'][t[@t-set='url' and @t-value=&quot;'/my/rfq'&quot;]]"
               position="replace"/>
        <xpath expr="//div[@id='portal_vendor_category']/t[@t-call='portal.portal_docs_entry'][t[@t-set='url' and @t-value=&quot;'/my/purchase'&quot;]]"
               position="replace"/>
    </template>

    <template id="portal_breadcrumbs_delivery_vendor_invoice" inherit_id="portal.portal_breadcrumbs" priority="35">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <li t-if="page_name == 'vendor_invoice_upload'" class="breadcrumb-item active">
                Upload Invoice
            </li>
            <li t-if="page_name == 'vendor_document_upload'" class="breadcrumb-item active">
                Upload DN / SES
            </li>
            <li t-if="page_name == 'vendor_delivery'" t-attf-class="breadcrumb-item #{'active ' if not picking else ''}">
                <a t-if="picking" href="/vendor/delivery-notes">Delivery Notes</a>
                <t t-else="">Delivery Notes</t>
            </li>
            <li t-if="page_name == 'vendor_delivery' and picking" class="breadcrumb-item active">
                <t t-out="picking.name"/>
            </li>
            <li t-if="page_name == 'vendor_srn'" t-attf-class="breadcrumb-item #{'active ' if not srn else ''}">
                <a t-if="srn" href="/vendor/srns">SRNs</a>
                <t t-else="">SRNs</t>
            </li>
            <li t-if="page_name == 'vendor_srn' and srn" class="breadcrumb-item active">
                <t t-out="srn.name"/>
            </li>
        </xpath>
    </template>

    <template id="portal_my_home_vendor_customer" inherit_id="portal.portal_my_home" customize_show="True" priority="35">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="before">
            <t t-set="portal_client_category_enable"
               t-value="False"/>
            <t t-set="portal_vendor_category_enable"
               t-value="request.env.user.partner_id.commercial_partner_id.supplier_rank &gt; 0"/>
        </xpath>
        <div id="portal_vendor_category" position="inside">
            <t t-if="request.env.user.partner_id.commercial_partner_id.supplier_rank">
                <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/purchase/static/description/icon.png'"/>
                    <t t-set="title">RFQs</t>
                    <t t-set="url" t-value="'/my/rfq'"/>
                    <t t-set="text">View requests for quotation</t>
                </t>
                <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/purchase/static/description/icon.png'"/>
                    <t t-set="title">Purchase Orders</t>
                    <t t-set="url" t-value="'/my/purchase'"/>
                    <t t-set="text">View purchase orders issued to you</t>
                    <t t-set="placeholder_count" t-value="'purchase_count'"/>
                </t>
                <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/account/static/src/img/Bill.svg'"/>
                    <t t-set="title">Vendor Invoices</t>
                    <t t-set="url" t-value="'/my/invoices?filterby=bills'"/>
                    <t t-set="text">View posted vendor invoices</t>
                    <t t-set="placeholder_count" t-value="'bill_count'"/>
                </t>
                <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/account/static/src/img/Bill.svg'"/>
                    <t t-set="title">Upload Invoice</t>
                    <t t-set="url" t-value="'/vendor/invoice/upload'"/>
                    <t t-set="text">Submit an invoice against a purchase order</t>
                    <t t-set="config_card" t-value="True"/>
                </t>
                <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/stock/static/description/icon.png'"/>
                    <t t-set="title">Delivery Notes</t>
                    <t t-set="url" t-value="'/vendor/delivery-notes'"/>
                    <t t-set="text">View PO delivery receipts</t>
                    <t t-set="placeholder_count" t-value="'vendor_delivery_count'"/>
                </t>
                <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/purchase/static/description/icon.png'"/>
                    <t t-set="title">SRNs</t>
                    <t t-set="url" t-value="'/vendor/srns'"/>
                    <t t-set="text">View service receipt notes</t>
                    <t t-set="placeholder_count" t-value="'srn_count'"/>
                </t>
                <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/account/static/src/img/Bill.svg'"/>
                    <t t-set="title">Upload DN / SES</t>
                    <t t-set="url" t-value="'/vendor/document/upload'"/>
                    <t t-set="text">Submit delivery note or service entry sheet against a PO</t>
                    <t t-set="config_card" t-value="True"/>
                </t>
            </t>
        </div>
    </template>

    <template id="portal_purchase_order_vendor_invoice_upload"
              inherit_id="purchase.portal_my_purchase_order"
              priority="40">
        <xpath expr="//div[hasclass('o_download_pdf')]" position="after">
            <div t-if="order.state in ['purchase', 'done']" class="mt-2">
                <a class="btn btn-primary w-100"
                   t-att-href="'/vendor/invoice/upload?po_id=%s' % order.id">
                    <i class="fa fa-upload me-1"/>
                    Upload Invoice
                </a>
            </div>
            <div t-if="order.state in ['purchase', 'done']" class="mt-2">
                <a class="btn btn-secondary w-100"
                   t-att-href="'/vendor/document/upload?po_id=%s' % order.id">
                    <i class="fa fa-paperclip me-1"/>
                    Upload DN / SES
                </a>
            </div>
        </xpath>
        <xpath expr="//div[@id='portal_purchase_content']" position="before">
            <div t-if="request.params.get('invoice_uploaded')"
                 class="alert alert-success d-print-none"
                 role="alert">
                <strong>Invoice attached successfully.</strong>
                The PDF is now attached to this purchase order and Accounts has been notified.
            </div>
            <div t-if="request.params.get('vendor_document_uploaded')"
                 class="alert alert-success d-print-none"
                 role="alert">
                <strong>Document attached successfully.</strong>
                The DN/SES file is now attached to this purchase order and the internal team has been notified.
            </div>
        </xpath>
    </template>

    <template id="portal_purchase_rfqs_vendor_reference"
              inherit_id="purchase.portal_my_purchase_rfqs"
              priority="80">
        <xpath expr="//thead/tr/th[1]" position="before">
            <th>Vendor Reference</th>
        </xpath>
        <xpath expr="//t[@t-foreach='rfqs']/tr/td[1]" position="before">
            <td>
                <t t-out="rfq.partner_ref or '-'"/>
            </td>
        </xpath>
    </template>

    <template id="portal_purchase_orders_vendor_reference"
              inherit_id="purchase.portal_my_purchase_orders"
              priority="80">
        <xpath expr="//thead/tr/th[1]" position="before">
            <th>Vendor Reference</th>
        </xpath>
        <xpath expr="//t[@t-foreach='orders']/tr/td[1]" position="before">
            <td>
                <t t-out="order.partner_ref or '-'"/>
            </td>
        </xpath>
    </template>

    <template id="portal_purchase_order_detail_vendor_reference"
              inherit_id="purchase.purchase_order_portal_content"
              priority="80">
        <xpath expr="//div[@id='informations']/div[@id='po_date']" position="before">
            <div t-if="order.partner_ref" class="row" id="po_vendor_reference">
                <div class="mb-3 col-6">
                    <strong>Vendor Reference:</strong>
                    <span t-field="order.partner_ref"/>
                </div>
            </div>
        </xpath>
    </template>

    <template id="portal_vendor_delivery_notes" name="Vendor Delivery Notes">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Delivery Notes</t>
            </t>
            <div t-if="not delivery_notes" class="alert alert-warning" role="alert">
                There are currently no delivery notes for your account.
            </div>
            <t t-if="delivery_notes" t-call="portal.portal_table">
                <thead>
                    <tr>
                        <th>Delivery Note</th>
                        <th>Purchase Order</th>
                        <th class="text-end">Scheduled Date</th>
                        <th class="text-end">Status</th>
                    </tr>
                </thead>
                <tbody>
                    <tr t-foreach="delivery_notes" t-as="delivery">
                        <td>
                            <a t-att-href="'/vendor/delivery-notes/%s' % delivery.id">
                                <t t-out="delivery.name"/>
                            </a>
                        </td>
                        <td>
                            <t t-out="delivery.purchase_id.name or delivery.origin or ''"/>
                        </td>
                        <td class="text-end">
                            <span t-field="delivery.scheduled_date"/>
                        </td>
                        <td class="text-end">
                            <span t-field="delivery.state"/>
                        </td>
                    </tr>
                </tbody>
            </t>
        </t>
    </template>

    <template id="portal_vendor_delivery_note_page" name="Vendor Delivery Note Details">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Delivery Note Details</t>
            </t>
            <div class="d-flex flex-wrap gap-3 justify-content-between align-items-center mb-3">
                <div>
                    <h3 class="mb-1">
                        <t t-out="picking.name"/>
                    </h3>
                    <div class="text-muted">
                        <t t-out="picking.purchase_id.name or picking.origin or ''"/>
                    </div>
                </div>
                <a class="btn btn-secondary" t-att-href="'/vendor/delivery-notes/%s/download' % picking.id">
                    <i class="fa fa-download me-1"/>
                    Download
                </a>
            </div>

            <div class="row mb-4">
                <div class="col-md-6">
                    <strong>Vendor</strong>
                    <div t-if="picking.partner_id" t-field="picking.partner_id" t-options="{'widget': 'contact', 'fields': ['address', 'name'], 'no_marker': True}"/>
                </div>
                <div class="col-md-6 text-md-end">
                    <div>
                        <strong>Scheduled Date:</strong>
                        <span t-field="picking.scheduled_date"/>
                    </div>
                    <div>
                        <strong>Status:</strong>
                        <span t-field="picking.state"/>
                    </div>
                </div>
            </div>

            <t t-call="portal.portal_table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Product</th>
                        <th>Description</th>
                        <th class="text-end">Demand</th>
                        <th class="text-end">Done</th>
                        <th>UoM</th>
                    </tr>
                </thead>
                <tbody>
                    <tr t-foreach="picking.move_ids_without_package" t-as="move">
                        <td>
                            <t t-out="move_index + 1"/>
                        </td>
                        <td>
                            <t t-out="move.product_id.display_name"/>
                        </td>
                        <td>
                            <t t-out="move.description_picking or move.name"/>
                        </td>
                        <td class="text-end">
                            <span t-field="move.product_uom_qty"/>
                        </td>
                        <td class="text-end">
                            <t t-out="move.quantity if 'quantity' in move._fields else move.quantity_done"/>
                        </td>
                        <td>
                            <span t-field="move.product_uom"/>
                        </td>
                    </tr>
                </tbody>
            </t>
        </t>
    </template>

    <template id="portal_vendor_srns" name="Vendor SRNs">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">SRNs</t>
            </t>
            <div t-if="not srns" class="alert alert-warning" role="alert">
                There are currently no service receipt notes for your account.
            </div>
            <t t-if="srns" t-call="portal.portal_table">
                <thead>
                    <tr>
                        <th>SRN</th>
                        <th>Purchase Order</th>
                        <th class="text-end">Receipt Date</th>
                        <th class="text-end">Approval</th>
                        <th class="text-end">Status</th>
                    </tr>
                </thead>
                <tbody>
                    <tr t-foreach="srns" t-as="receipt">
                        <td>
                            <a t-att-href="'/vendor/srns/%s' % receipt.id">
                                <t t-out="receipt.name"/>
                            </a>
                        </td>
                        <td>
                            <t t-out="receipt.purchase_id.name"/>
                        </td>
                        <td class="text-end">
                            <span t-field="receipt.date"/>
                        </td>
                        <td class="text-end">
                            <span t-field="receipt.approval_state"/>
                        </td>
                        <td class="text-end">
                            <span t-field="receipt.state"/>
                        </td>
                    </tr>
                </tbody>
            </t>
        </t>
    </template>

    <template id="portal_vendor_srn_page" name="Vendor SRN Details">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">SRN Details</t>
            </t>
            <div class="d-flex flex-wrap gap-3 justify-content-between align-items-center mb-3">
                <div>
                    <h3 class="mb-1">
                        <t t-out="srn.name"/>
                    </h3>
                    <div class="text-muted">
                        <t t-out="srn.purchase_id.name"/>
                    </div>
                </div>
                <div class="text-md-end">
                    <div>
                        <strong>Approval:</strong>
                        <span t-field="srn.approval_state"/>
                    </div>
                    <div>
                        <strong>Status:</strong>
                        <span t-field="srn.state"/>
                    </div>
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-6">
                    <strong>Vendor</strong>
                    <div t-if="srn.partner_id" t-field="srn.partner_id" t-options="{'widget': 'contact', 'fields': ['address', 'name'], 'no_marker': True}"/>
                </div>
                <div class="col-md-6 text-md-end">
                    <div>
                        <strong>Receipt Date:</strong>
                        <span t-field="srn.date"/>
                    </div>
                    <div t-if="srn.work_order_id">
                        <strong>Work Order:</strong>
                        <span t-field="srn.work_order_id"/>
                    </div>
                </div>
            </div>

            <t t-call="portal.portal_table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Product</th>
                        <th>Description</th>
                        <th class="text-end">Ordered</th>
                        <th class="text-end">Already Received</th>
                        <th class="text-end">Done</th>
                        <th class="text-end">Balance</th>
                        <th>UoM</th>
                    </tr>
                </thead>
                <tbody>
                    <tr t-foreach="srn.line_ids" t-as="line">
                        <td>
                            <t t-out="line_index + 1"/>
                        </td>
                        <td>
                            <t t-out="line.product_id.display_name"/>
                        </td>
                        <td>
                            <t t-out="line.name"/>
                        </td>
                        <td class="text-end">
                            <span t-field="line.ordered_qty"/>
                        </td>
                        <td class="text-end">
                            <span t-field="line.already_received_qty"/>
                        </td>
                        <td class="text-end">
                            <span t-field="line.done_qty"/>
                        </td>
                        <td class="text-end">
                            <span t-field="line.balance_qty"/>
                        </td>
                        <td>
                            <span t-field="line.uom_id"/>
                        </td>
                    </tr>
                </tbody>
            </t>
        </t>
    </template>

    <template id="portal_vendor_document_upload" name="Upload Vendor DN or SES">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Upload DN / SES</t>
            </t>
            <div class="row justify-content-center">
                <div class="col-lg-8 col-xl-7">
                    <div class="o_pr_portal_workflow">
                        <strong>Attach a delivery note or SES to a purchase order</strong>
                        <ul>
                            <li>Select the confirmed purchase order this document belongs to.</li>
                            <li>Attach a PDF, JPG, or PNG no larger than 10 MB.</li>
                            <li>The file will be stored on the purchase order and the internal receiving team will be notified.</li>
                        </ul>
                    </div>
                    <div t-if="error_message" class="alert alert-danger" role="alert">
                        <t t-foreach="error_message" t-as="message">
                            <div t-out="message"/>
                        </t>
                    </div>
                    <form action="/vendor/document/upload" method="post" enctype="multipart/form-data" class="o_portal_form">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <div class="mb-3">
                            <label class="form-label" for="document_type">Document Type</label>
                            <select id="document_type" name="document_type" class="form-select" required="required">
                                <t t-foreach="document_types.items()" t-as="document_type_item">
                                    <option t-att-value="document_type_item[0]"
                                            t-att-selected="document_type_item[0] == selected_document_type">
                                        <t t-out="document_type_item[1]['label']"/>
                                    </option>
                                </t>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="po_id">Purchase Order</label>
                            <select id="po_id" name="po_id" class="form-select" required="required">
                                <option value="">Select a purchase order</option>
                                <t t-foreach="purchase_orders" t-as="po">
                                    <option t-att-value="po.id" t-att-selected="po.id == selected_po_id">
                                        <t t-out="po.name"/>
                                        <t t-if="po.partner_ref"> - <t t-out="po.partner_ref"/></t>
                                    </option>
                                </t>
                            </select>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label" for="document_number">Document Number</label>
                                <input id="document_number" name="document_number" type="text" class="form-control" required="required" t-att-value="form_data.get('document_number')"/>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label" for="document_date">Document Date</label>
                                <input id="document_date" name="document_date" type="date" class="form-control" required="required" t-att-value="form_data.get('document_date')"/>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="document_file">Document File</label>
                            <input id="document_file"
                                   name="document_file"
                                   type="file"
                                   accept=".pdf,.jpg,.jpeg,.png,application/pdf,image/jpeg,image/png"
                                   class="form-control"
                                   required="required"
                                   aria-describedby="document_file_help"/>
                            <div id="document_file_help" class="form-text">PDF, JPG, or PNG only, maximum 10 MB.</div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="notes">Notes</label>
                            <textarea id="notes" name="notes" class="form-control" rows="4"><t t-out="form_data.get('notes')"/></textarea>
                        </div>
                        <div class="d-flex gap-2 justify-content-end">
                            <a class="btn btn-secondary"
                               t-att-href="'/my/purchase/%s' % selected_po_id if selected_po_id else '/my/purchase'">
                                Cancel
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fa fa-upload me-1"/>
                                Attach to Purchase Order
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </t>
    </template>

    <template id="portal_vendor_invoice_upload" name="Upload Vendor Invoice">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Upload Invoice</t>
            </t>
            <div class="row justify-content-center">
                <div class="col-lg-8 col-xl-7">
                    <div class="o_pr_portal_workflow">
                        <strong>Attach your invoice to the purchase order</strong>
                        <ul>
                            <li>Select the confirmed purchase order this invoice belongs to.</li>
                            <li>Use your supplier invoice number; it must be unique for your company.</li>
                            <li>Attach a valid PDF no larger than 10 MB and enter an amount greater than zero.</li>
                            <li>The PDF and invoice details will be stored directly on the purchase order and Accounts will be notified.</li>
                        </ul>
                    </div>
                    <div t-if="error_message" class="alert alert-danger" role="alert">
                        <t t-foreach="error_message" t-as="message">
                            <div t-out="message"/>
                        </t>
                    </div>
                    <form action="/vendor/invoice/upload" method="post" enctype="multipart/form-data" class="o_portal_form">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <div class="mb-3">
                            <label class="form-label" for="po_id">Purchase Order</label>
                            <select id="po_id" name="po_id" class="form-select" required="required">
                                <option value="">Select a purchase order</option>
                                <t t-foreach="purchase_orders" t-as="po">
                                    <option t-att-value="po.id" t-att-selected="po.id == selected_po_id">
                                        <t t-out="po.name"/>
                                        <t t-if="po.partner_ref"> - <t t-out="po.partner_ref"/></t>
                                    </option>
                                </t>
                            </select>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label" for="vendor_invoice_number">Invoice Number</label>
                                <input id="vendor_invoice_number" name="vendor_invoice_number" type="text" class="form-control" required="required" t-att-value="form_data.get('vendor_invoice_number')"/>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label" for="invoice_date">Invoice Date</label>
                                <input id="invoice_date" name="invoice_date" type="date" class="form-control" required="required" t-att-value="form_data.get('invoice_date')"/>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label" for="amount_total">Invoice Amount</label>
                                <input id="amount_total" name="amount_total" type="number" step="0.01" min="0.01" class="form-control" required="required" t-att-value="form_data.get('amount_total')"/>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label" for="invoice_file">Invoice PDF</label>
                                <input id="invoice_file"
                                       name="invoice_file"
                                       type="file"
                                       accept=".pdf,application/pdf"
                                       class="form-control"
                                       required="required"
                                       aria-describedby="invoice_file_help"/>
                                <div id="invoice_file_help" class="form-text">PDF only, maximum 10 MB.</div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="notes">Notes</label>
                            <textarea id="notes" name="notes" class="form-control" rows="4"><t t-out="form_data.get('notes')"/></textarea>
                        </div>
                        <div class="d-flex gap-2 justify-content-end">
                            <a class="btn btn-secondary"
                               t-att-href="'/my/purchase/%s' % selected_po_id if selected_po_id else '/my/purchase'">
                                Cancel
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fa fa-upload me-1"/>
                                Attach to Purchase Order
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </t>
    </template>
</odoo>
