<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="de_hr_workspace_overtime_approvals_view_action" model="ir.actions.act_window">
        <field name="name">Overtime Approvals</field>
        <field name="res_model">hr.attendance</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('overtime_approval_state', '=', 'pending'), ('overtime_for_approval', '>', 0)]</field>
        <field name="context">{'create': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Pending overtime approvals.
            </p>
        </field>
    </record>

    <menuitem id="de_hr_workspace_overtime_approvals_menu"
              parent="de_hr_workspace.hr_approvals_menu_root"
              name="Overtime Approvals"
              action="de_hr_workspace_overtime_approvals_view_action"
              sequence="3"
              groups="hr.group_hr_manager"
    />
</odoo>