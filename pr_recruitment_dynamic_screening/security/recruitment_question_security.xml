<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Internal requesters can only maintain questions on requests they own. -->
    <record id="rule_recruitment_question_request_owner" model="ir.rule">
        <field name="name">Recruitment questions: own requests</field>
        <field name="model_id" ref="model_pr_recruitment_question"/>
        <field name="domain_force">[('request_id.requested_by_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="rule_recruitment_option_request_owner" model="ir.rule">
        <field name="name">Recruitment question options: own requests</field>
        <field name="model_id" ref="model_pr_recruitment_question_option"/>
        <field name="domain_force">[('question_id.request_id.requested_by_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="rule_recruitment_column_request_owner" model="ir.rule">
        <field name="name">Recruitment repeating columns: own requests</field>
        <field name="model_id" ref="model_pr_recruitment_question_column"/>
        <field name="domain_force">[('question_id.request_id.requested_by_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="rule_recruitment_column_option_request_owner" model="ir.rule">
        <field name="name">Recruitment repeating column options: own requests</field>
        <field name="model_id" ref="model_pr_recruitment_question_column_option"/>
        <field name="domain_force">[('column_id.question_id.request_id.requested_by_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Recruitment staff and the existing request approvers need all questions. -->
    <record id="rule_recruitment_question_staff_all" model="ir.rule">
        <field name="name">Recruitment questions: recruitment staff and approvers</field>
        <field name="model_id" ref="model_pr_recruitment_question"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[
            (4, ref('hr_recruitment.group_hr_recruitment_user')),
            (4, ref('pr_hr_recruitment_request.group_onboarding_supervisor')),
            (4, ref('pr_hr_recruitment_request.group_onboarding_manager')),
            (4, ref('pr_hr_recruitment_request.group_onboarding_md'))
        ]"/>
    </record>

    <record id="rule_recruitment_option_staff_all" model="ir.rule">
        <field name="name">Recruitment question options: recruitment staff and approvers</field>
        <field name="model_id" ref="model_pr_recruitment_question_option"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[
            (4, ref('hr_recruitment.group_hr_recruitment_user')),
            (4, ref('pr_hr_recruitment_request.group_onboarding_supervisor')),
            (4, ref('pr_hr_recruitment_request.group_onboarding_manager')),
            (4, ref('pr_hr_recruitment_request.group_onboarding_md'))
        ]"/>
    </record>

    <record id="rule_recruitment_column_staff_all" model="ir.rule">
        <field name="name">Recruitment repeating columns: recruitment staff and approvers</field>
        <field name="model_id" ref="model_pr_recruitment_question_column"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[
            (4, ref('hr_recruitment.group_hr_recruitment_user')),
            (4, ref('pr_hr_recruitment_request.group_onboarding_supervisor')),
            (4, ref('pr_hr_recruitment_request.group_onboarding_manager')),
            (4, ref('pr_hr_recruitment_request.group_onboarding_md'))
        ]"/>
    </record>

    <record id="rule_recruitment_column_option_staff_all" model="ir.rule">
        <field name="name">Recruitment repeating column options: recruitment staff and approvers</field>
        <field name="model_id" ref="model_pr_recruitment_question_column_option"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[
            (4, ref('hr_recruitment.group_hr_recruitment_user')),
            (4, ref('pr_hr_recruitment_request.group_onboarding_supervisor')),
            (4, ref('pr_hr_recruitment_request.group_onboarding_manager')),
            (4, ref('pr_hr_recruitment_request.group_onboarding_md'))
        ]"/>
    </record>
</odoo>
