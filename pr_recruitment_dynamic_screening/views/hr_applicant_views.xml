<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_applicant_form_dynamic_screening" model="ir.ui.view">
        <field name="name">hr.applicant.form.dynamic.screening</field>
        <field name="model">hr.applicant</field>
        <field name="inherit_id" ref="hr_recruitment.hr_applicant_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/header" position="inside">
                <button name="action_rescreen_dynamic_answers"
                        string="Re-run Screening"
                        type="object"
                        class="btn-secondary"
                        groups="hr_recruitment.group_hr_recruitment_user"
                        invisible="not dynamic_answer_ids and dynamic_screening_status == 'not_screened'"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Application Answers" name="dynamic_application_answers">
                    <group>
                        <group string="Screening Result">
                            <field name="dynamic_screening_status" readonly="1"/>
                            <field name="dynamic_screened_on" readonly="1"/>
                        </group>
                        <group string="Automatic Refusal"
                               col="1"
                               class="pr_screening_refusal_group"
                               invisible="dynamic_screening_status != 'auto_refused'">
                            <field name="dynamic_screening_failure_reason"
                                   readonly="1"
                                   nolabel="1"
                                   class="pr_screening_refusal_reason"/>
                        </group>
                    </group>
                    <field name="dynamic_answer_ids" nolabel="1" readonly="1">
                        <tree create="0" delete="0" edit="0">
                            <field name="question_id"/>
                            <field name="display_value"/>
                        </tree>
                        <form string="Application Answer">
                            <sheet>
                                <group>
                                    <field name="question_id" readonly="1"/>
                                    <field name="answer_type" invisible="1"/>
                                    <field name="display_value" readonly="1"/>
                                </group>
                                <field name="line_ids" readonly="1"
                                       invisible="answer_type != 'one2many'">
                                    <tree create="0" delete="0" edit="0">
                                        <field name="display_value"/>
                                    </tree>
                                </field>
                            </sheet>
                        </form>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_hr_applicant_search_dynamic_screening" model="ir.ui.view">
        <field name="name">hr.applicant.search.dynamic.screening</field>
        <field name="model">hr.applicant</field>
        <field name="inherit_id" ref="hr_recruitment.hr_applicant_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <separator/>
                <filter name="automatically_refused"
                        string="Automatically Refused"
                        domain="[('dynamic_screening_status', '=', 'auto_refused')]"
                        context="{'active_test': False}"/>
            </xpath>
        </field>
    </record>

    <record id="view_hr_applicant_search_bis_dynamic_screening" model="ir.ui.view">
        <field name="name">hr.applicant.search.bis.dynamic.screening</field>
        <field name="model">hr.applicant</field>
        <field name="inherit_id" ref="hr_recruitment.hr_applicant_view_search_bis"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='refused']" position="after">
                <filter name="automatically_refused"
                        string="Automatically Refused"
                        domain="[('active', '=', False), ('dynamic_screening_status', '=', 'auto_refused')]"
                        context="{'active_test': False}"/>
            </xpath>
        </field>
    </record>
</odoo>
