<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_picking_form" model="ir.ui.view">
        <field name="name">
            stock.picking.view.form.inherit.order.line.sequences
        </field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='move_ids_without_package']//tree//field[@name='product_id']"
                   position="before">
                <field name="sequence_number"/>
                <field name="product_internal_reference"
                       string="Product Code"
                       readonly="(state != 'draft' and not additional) or move_lines_count &gt; 0"
                       optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
