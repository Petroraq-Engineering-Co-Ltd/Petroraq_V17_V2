<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_move_form_invoice_internal_ref" model="ir.ui.view">
        <field name="name">account.move.form.invoice.internal.ref</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_line_ids']//tree//field[@name='product_id']"
                   position="before">
                <field name="product_internal_reference"
                       string="Product Code"
                       domain="context.get('default_move_type') in ('out_invoice', 'out_refund', 'out_receipt') and [('sale_ok', '=', True)] or [('purchase_ok', '=', True)]"
                       optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
