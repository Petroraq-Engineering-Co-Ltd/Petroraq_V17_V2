<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    Inherited form view of purchase order -->
    <record id="purchase_order_form" model="ir.ui.view">
        <field name="name">
            purchase.order.view.form.inherit.order.line.sequences
        </field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']//tree//field[@name='product_id']"
                   position="before">
                <field name="sequence_number"/>
                <field name="product_internal_reference"
                       string="Product Code"
                       domain="[('purchase_ok', '=', True), '|', ('company_id', '=', False), ('company_id', 'parent_of', parent.company_id)]"
                       readonly="state in ('purchase', 'to approve', 'done', 'cancel')"
                       optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
