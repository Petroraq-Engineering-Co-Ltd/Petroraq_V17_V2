<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_pr_work_order_form_inherit_service_receipts" model="ir.ui.view">
        <field name="name">pr.work.order.form.inherit.service.receipts</field>
        <field name="model">pr.work.order</field>
        <field name="inherit_id" ref="pr_work_order.view_pr_work_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_service_receipt_notes"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-file-text-o"
                        invisible="service_receipt_note_count == 0">
                    <field name="service_receipt_note_count" widget="statinfo" string="Service Receipts"/>
                </button>
            </xpath>
        </field>
    </record>

</odoo>