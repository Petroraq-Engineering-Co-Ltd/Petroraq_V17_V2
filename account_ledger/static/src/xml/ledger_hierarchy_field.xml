<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
  <t t-name="account_ledger.LedgerHierarchyField">
    <div class="o_ledger_hierarchy">
      <t t-if="!state.loaded">
        <div class="p-2">Loading...</div>
      </t>

        <t t-else="">
        <t t-if="state.error">
          <div class="alert alert-danger m-2">
            <t t-esc="state.error"/>
          </div>
        </t>

            <table class="table table-sm table-hover o_list_table">
          <thead class="position-sticky top-0 bg-white" style="z-index: 1;">
            <tr>
                <th>Code</th>
                <th>Main Head</th>
                <th>Category</th>
                <th>Sub-Category</th>
                <th>Account</th>
                <th>Account Type</th>
                <th class="text-end">Balance</th>
            </tr>
          </thead>

                <tbody>
            <t t-foreach="state.rows" t-as="r" t-key="r.id">
              <t t-if="isVisible(r)">
                <tr t-att-class="rowClass(r)">
                    <td>
                    <div t-att-style="indentStyle(r)" class="d-flex align-items-center gap-1">
                      <a href="#"
                         t-on-click.prevent="() => this.toggle(r)"
                         t-att-class="r._children and r._children.length and 'text-decoration-none' or 'invisible'">
  <t t-esc="state.expanded[r.id] ? '▾' : '▸'"/>
</a>
                        <span t-esc="r.code || ''"/>
                    </div>
                  </td>
                    <td><t t-esc="r.main_head_label || ''"/></td>
                    <td><t t-esc="r.category_label || ''"/></td>
                    <td><t t-esc="r.subcategory_label || ''"/></td>
                    <td><t t-esc="r.account_label || ''"/></td>
                    <td><t t-esc="r.account_type_label || ''"/></td>
                    <td class="text-end">
                    <span t-att-class="r.balance &lt; 0 ? 'text-danger' : ''">
                      <t t-esc="fmt(r.balance)"/>


                    </span>
                  </td>
                </tr>
              </t>
            </t>
          </tbody>
        </table>
      </t>
    </div>
  </t>
</templates>
