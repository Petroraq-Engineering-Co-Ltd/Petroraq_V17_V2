<odoo>
    <record id="view_partner_form_title_case" model="ir.ui.view">
        <field name="name">res.partner.form.title.case</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="priority">9999</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name' and @id='company']" position="attributes">
                <attribute name="widget">title_case</attribute>
                <attribute name="class" add="o_title_case_field" separator=" "/>
            </xpath>
            <xpath expr="//field[@name='name' and @id='individual']" position="attributes">
                <attribute name="widget">title_case</attribute>
                <attribute name="class" add="o_title_case_field" separator=" "/>
            </xpath>
            <xpath expr="//field[@name='display_name']" position="attributes">
                <attribute name="widget">title_case</attribute>
                <attribute name="class" add="o_title_case_field" separator=" "/>
            </xpath>
            <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="widget">title_case</attribute>
                <attribute name="class" add="o_title_case_field" separator=" "/>
            </xpath>
        </field>
    </record>

