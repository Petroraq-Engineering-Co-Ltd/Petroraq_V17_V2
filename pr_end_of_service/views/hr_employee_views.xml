<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_hr_employee_form_inherit_pr_eos" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.pr.eos</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_pr_eos" type="object" class="oe_stat_button" icon="fa-file-text-o"
                        invisible="pr_eos_count == 0">
                    <field name="pr_eos_count" widget="statinfo" string="End of Service"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
