<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_pr_employee_payment_request_form_inherit_pr_eos" model="ir.ui.view">
        <field name="name">pr.employee.payment.request.form.inherit.pr.eos</field>
        <field name="model">pr.employee.payment.request</field>
        <field name="inherit_id" ref="pr_employee_service_requests.view_pr_employee_payment_request_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='service_request_id']" position="after">
                <field name="eos_id" readonly="1" invisible="not eos_id"/>
            </xpath>
        </field>
    </record>

    <record id="view_pr_account_bank_payment_form_inherit_pr_eos" model="ir.ui.view">
        <field name="name">pr.account.bank.payment.form.inherit.pr.eos</field>
        <field name="model">pr.account.bank.payment</field>
        <field name="inherit_id" ref="pr_account.pr_account_bank_payment_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='description']" position="after">
                <field name="eos_id" readonly="1" invisible="not eos_id"/>
            </xpath>
        </field>
    </record>

    <record id="view_pr_account_cash_payment_form_inherit_pr_eos" model="ir.ui.view">
        <field name="name">pr.account.cash.payment.form.inherit.pr.eos</field>
        <field name="model">pr.account.cash.payment</field>
        <field name="inherit_id" ref="pr_account.pr_account_cash_payment_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='description']" position="after">
                <field name="eos_id" readonly="1" invisible="not eos_id"/>
            </xpath>
        </field>
    </record>
</odoo>
