<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_res_config_settings_form_inherit_pr_eos" model="ir.ui.view">
        <field name="name">res.config.settings.form.inherit.pr.eos</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="End of Service" string="End of Service" name="pr_end_of_service">
                    <block title="End of Service Accounting">
                        <setting help="Debit account used on the generated EOS bank payment line.">
                            <field name="pr_eos_expense_account_id"/>
                        </setting>
                        <setting help="Credit account used on the generated EOS bank payment voucher.">
                            <field name="pr_eos_payment_account_id"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
