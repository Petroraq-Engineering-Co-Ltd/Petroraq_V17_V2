<?xml version="1.0" encoding="UTF-8"?>

<odoo>
    <record id="account_invoice_form_view" model="ir.ui.view">
        <field name="name">account.invoice.form.view</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">


            <field name="payment_reference" position="after">
                <field name="amount_tax" invisible="1" force_save="1"/>
                <field name="custom_qr_image" widget="image" style="width:100px;height:100px;" invisible="1"/>
            </field>
            <field name="invoice_origin" position="after">
                <field name="po_number" string="PO Name" readonly="1"
                       invisible="move_type not in ('out_invoice', 'out_refund')"/>
                <field name="po_date" readonly="1"
                       invisible="move_type not in ('out_invoice', 'out_refund')"/>
            </field>
            <xpath expr="//group[@id='header_left_group']/label[@for='partner_id'][1]" position="before">
                <xpath expr="//field[@name='po_number']" position="move"/>
            </xpath>
        </field>
    </record>

    <record id="account_invoice_tree_po_name" model="ir.ui.view">
        <field name="name">account.invoice.tree.po.name</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree/field[@name='name']" position="before">
                <field name="po_number"
                       string="PO Name"
                       optional="show"
                       column_invisible="context.get('default_move_type') not in ('out_invoice', 'out_refund', 'out_receipt')"/>
            </xpath>
        </field>
    </record>
</odoo>
