<?xml version="1.0"?>
<odoo>

    <record id="pr_hr_payroll_hr_salary_rule_form_inherit" model="ir.ui.view">
        <field name="name">pr.hr.payroll.hr.salary.rule.form.inherit</field>
        <field name="model">hr.salary.rule</field>
        <field name="inherit_id" ref="hr_payroll.hr_salary_rule_form"/>
        <field name="arch" type="xml">

            <notebook position="inside">
                <page name="attendance_eligibility" string="Attendance Eligibility">
                    <group>
                        <group>
                            <field name="attendance_based_eligibility"/>
                            <field name="attendance_min_worked_hours"
                                   invisible="not attendance_based_eligibility" required="attendance_based_eligibility"
                            />
                            <field name="attendance_require_presence"
                                   invisible="not attendance_based_eligibility"
                            />
                        </group>
                    </group>
                </page>
                <page name="accounting_settings" string="Accounting Settings">
                    <group>
                        <group>
                            <label for="account_id" string="Account Code"/>
                            <div class="o_row">
                                <field name="account_id" width="40%"
                                       class="oe_inline"
                                       options="{'no_create':True, 'no_create_edit':True, 'no_quick_create':True}"
                                       style="font-size:16;font-weight:bold;color:green;" string="Code"/>
                                <span>
                                    <strong>Account Name</strong>
                                </span>
                                <field name="account_name" width="40%"
                                       class="oe_inline" string="Account Name"
                                       style="font-size:16;font-weight:bold;color:green;"/>
                            </div>
                        </group>
                    </group>
                </page>
            </notebook>


        </field>
    </record>

</odoo>