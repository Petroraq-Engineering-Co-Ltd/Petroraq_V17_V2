<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="portal_employee_leaves_dashboard" name="Leaves Dashboard" customize_show="True"
              inherit_id="portal.portal_my_home">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="before">
            <t t-set="portal_employee_user" t-value="request.env['hr.employee'].sudo().search_count([('user_id', '=', request.env.user.id), ('active', '=', True)])"/>
            <t t-if="portal_employee_user" t-set="portal_service_category_enable" t-value="True"/>
        </xpath>
        <div id="portal_service_category" position="inside">
            <t t-if="portal_employee_user" t-call="portal.portal_docs_entry">
                <t t-set="icon" t-value="'/de_hr_workspace_timeoff/static/src/img/leave_dashboard.png'"/>
                <t t-set="title">Leaves Dashboard</t>
                <t t-set="url" t-value="'/my/leaves_dashboard'"/>
                <t t-set="text">Follow your leaves</t>
                <t t-set="placeholder_count" t-value="'my_leave_dashboard_count'"/>
            </t>
        </div>
    </template>

    <template id="portal_my_leaves_dashboard" name="Leaves Dashboard">
        <t t-call="portal.portal_layout">

            <style>
                #pr_leave_dashboard {
                --pr-blue: #06264B;
                --pr-blue-light: #0a3d6e;
                --pr-gold: #e9a23e;
                --pr-gold-dark: #d8902f;
                --pr-ink: #222;
                --pr-muted: #657385;
                --pr-border: #dce5ef;
                --pr-soft: #f6f8fb;
                color: var(--pr-ink);
                padding: 24px 0 40px;
                }

                #pr_leave_dashboard .main-content {
                background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
                border: 1px solid var(--pr-border);
                border-radius: 8px;
                min-height: auto;
                padding: 24px;
                }

                #pr_leave_dashboard .card {
                background: #fff;
                border: 1px solid var(--pr-border);
                border-radius: 8px;
                box-shadow: 0 6px 18px rgba(6, 38, 75, 0.08);
                color: var(--pr-ink);
                cursor: default;
                padding: 20px;
                transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;
                }

                #pr_leave_dashboard .card:hover {
                border-color: rgba(233, 162, 62, 0.7);
                box-shadow: 0 12px 28px rgba(6, 38, 75, 0.14);
                transform: translateY(-2px);
                }

                #pr_leave_dashboard .leave-summary-card {
                border-top: 3px solid var(--pr-gold);
                min-height: 124px;
                text-align: center;
                }

                #pr_leave_dashboard .card h6 {
                color: var(--pr-blue);
                font-size: 0.95rem;
                font-weight: 700;
                margin-bottom: 12px;
                }

                #pr_leave_dashboard .leave-summary-card .fs-5 {
                color: var(--pr-gold-dark) !important;
                font-size: 1.45rem;
                font-weight: 800;
                }

                #pr_leave_dashboard .leave-panel-card h6 {
                align-items: center;
                border-bottom: 1px solid var(--pr-border);
                display: flex;
                gap: 8px;
                padding-bottom: 12px;
                text-align: left;
                }

                #pr_leave_dashboard .leave-panel-card h6::before {
                background: var(--pr-gold);
                border-radius: 2px;
                content: "";
                display: inline-block;
                height: 18px;
                width: 4px;
                }

                #pr_leave_dashboard table.table {
                border-collapse: separate;
                border-spacing: 0;
                margin-bottom: 0;
                width: 100%;
                }

                #pr_leave_dashboard .table-responsive {
                border: 1px solid var(--pr-border);
                border-radius: 8px;
                max-height: 350px;
                overflow-y: auto;
                scrollbar-color: var(--pr-gold) var(--pr-soft);
                scrollbar-width: thin;
                }

                #pr_leave_dashboard .table-responsive::-webkit-scrollbar {
                width: 8px;
                }

                #pr_leave_dashboard .table-responsive::-webkit-scrollbar-track {
                background: var(--pr-soft);
                }

                #pr_leave_dashboard .table-responsive::-webkit-scrollbar-thumb {
                background-color: var(--pr-gold);
                border: 2px solid var(--pr-soft);
                border-radius: 8px;
                }

                #pr_leave_dashboard thead tr {
                background: linear-gradient(135deg, var(--pr-blue) 0%, var(--pr-blue-light) 100%);
                color: #fff;
                }

                #pr_leave_dashboard th,
                #pr_leave_dashboard td {
                padding: 12px 14px;
                text-align: left;
                vertical-align: middle;
                }

                #pr_leave_dashboard th {
                border-bottom: 3px solid var(--pr-gold);
                font-size: 0.78rem;
                font-weight: 700;
                letter-spacing: 0.3px;
                text-transform: uppercase;
                }

                #pr_leave_dashboard tbody tr {
                background: #fff;
                color: var(--pr-ink);
                transition: background-color 0.2s ease, box-shadow 0.2s ease;
                }

                #pr_leave_dashboard tbody tr:nth-child(even) {
                background: #f8fafc;
                }

                #pr_leave_dashboard tbody tr:hover {
                background: #fff7ec;
                box-shadow: inset 3px 0 0 var(--pr-gold);
                }

                #pr_leave_dashboard tbody td {
                border-bottom: 1px solid #edf1f6;
                color: #344052;
                font-size: 0.92rem;
                }

                #pr_leave_dashboard .badge {
                border-radius: 999px;
                font-size: 0.74rem;
                font-weight: 700;
                padding: 6px 10px;
                }

                #pr_leave_dashboard .badge.bg-warning.text-dark {
                background: #fff3df !important;
                border: 1px solid rgba(233, 162, 62, 0.45);
                color: #915f13 !important;
                }

                #pr_leave_dashboard .badge.bg-success {
                background: #198754 !important;
                color: #fff !important;
                }

                #pr_leave_dashboard .badge.bg-danger {
                background: #dc3545 !important;
                color: #fff !important;
                }

                #pr_leave_dashboard .badge.bg-secondary {
                background: #667085 !important;
                color: #fff !important;
                }

                #pr_leave_dashboard p {
                color: var(--pr-muted);
                margin: 8px 0 0;
                }

                @media (max-width: 768px) {
                #pr_leave_dashboard {
                padding-top: 12px;
                }

                #pr_leave_dashboard .main-content {
                padding: 16px;
                }

                #pr_leave_dashboard th,
                #pr_leave_dashboard td {
                padding: 10px;
                }
                }

            </style>

            <div class="container-fluid" id="pr_leave_dashboard">
                <div class="row">
                    <!-- Main Content -->
                    <main class="col-12 main-content">
                        <!-- Summary Cards -->
                        <div class="row g-4 mb-4">
                            <t t-if="leaves_dashboard_summary">
                                <t t-foreach="leaves_dashboard_summary" t-as="summ">
                                    <div class="col-md-3">
                                        <div class="card leave-summary-card p-3">
                                            <h6>
                                                <t t-esc="summ['leave_name']"/>
                                            </h6>

                                            <div class="fs-5 fw-bold text-primary">
                                                <t t-if="summ['requires_allocation'] == 'yes'">
                                                    <t t-esc="summ['leave_days']"/>
                                                    /
                                                    <t t-esc="summ['allocation_days']"/>
                                                </t>
                                                <t t-else="">
                                                    <t t-esc="summ['leave_days']"/>
                                                </t>
                                            </div>

                                            <t t-if="summ['requires_allocation'] == 'yes'">
                                                <div class="mt-2 small text-muted">
                                                    <div>
                                                        <strong>Taken:</strong>
                                                        <t t-esc="summ['leave_days']"/>
                                                    </div>
                                                    <div>
                                                        <strong>Remaining:</strong>
                                                        <t t-esc="round(summ['allocation_days'] - summ['leave_days'],3)"/>
                                                    </div>
                                                </div>
                                            </t>
                                        </div>
                                    </div>
                                </t>
                            </t>
                            <t t-else="">
                                <p>
                                    <strong>There Are No Leave Types</strong>
                                </p>
                            </t>
                        </div>
                        <!-- Pending Leaves -->
                        <div class="row g-4 mb-4">
                            <div class="col-md-12">
                                <div class="card leave-panel-card">
                                    <h6>Pending Leaves</h6>
                                    <t t-if="leaves_dashboard_pending and leaves_dashboard_pending">
                                        <div class="table-responsive">
                                            <table class="table table-sm mt-3">
                                                <thead>
                                                    <tr style="width: 100%;">
                                                        <th>Leave Type</th>
                                                        <th>From</th>
                                                        <th>To</th>
                                                        <th>Days</th>
                                                        <th>Status</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr t-foreach="leaves_dashboard_pending" t-as="pending_l">
                                                        <td>
                                                            <t t-esc="pending_l['leave_type']"/>
                                                        </td>
                                                        <td>
                                                            <t t-esc="pending_l['from']"/>
                                                        </td>
                                                        <td>
                                                            <t t-esc="pending_l['to']"/>
                                                        </td>
                                                        <td>
                                                            <t t-esc="pending_l['days']"/>
                                                        </td>
                                                        <td>
                                                            <span class="badge bg-warning text-dark">
                                                                <t t-esc="pending_l['status']"/>
                                                            </span>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </t>
                                    <t t-else="">
                                        <p>No Pending Leaves.</p>
                                    </t>
                                </div>
                            </div>
                        </div>

                        <!-- Leave History -->
                        <div class="card leave-panel-card mb-4">
                            <h6>Leave History</h6>
                            <t t-if="leaves_dashboard_all_leaves">
                                <div class="table-responsive">
                                    <table class="table table-hover mt-3">
                                        <thead>
                                            <tr style="width: 100%;">
                                                <th>Leave Type</th>
                                                <th>From</th>
                                                <th>To</th>
                                                <th>Days</th>
                                                <th>Status</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr t-foreach="leaves_dashboard_all_leaves" t-as="all_leave">
                                                <td>
                                                    <t t-esc="all_leave['leave_type']"/>
                                                </td>
                                                <td>
                                                    <t t-esc="all_leave['from']"/>
                                                </td>
                                                <td>
                                                    <t t-esc="all_leave['to']"/>
                                                </td>
                                                <td>
                                                    <t t-esc="all_leave['days']"/>
                                                </td>
                                                <td>
                                                    <span t-attf-class="badge #{'bg-success' if all_leave['status'] == 'Approved' else ('bg-danger' if all_leave['status'] in ['Refused', 'Cancelled'] else 'bg-secondary')}">
                                                        <t t-esc="all_leave['status']"/>
                                                    </span>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </t>
                            <t t-else="">
                                <p>No Taken Leaves Founded.</p>
                            </t>
                        </div>
                    </main>
                </div>
            </div>

        </t>
    </template>
</odoo>
