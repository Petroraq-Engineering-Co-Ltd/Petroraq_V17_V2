<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="thanks_template">
        <style>
            * {
            padding: 0;
            margin: 0;
            font-family: sans-serif;
            }

            body {
            /* background: url('/bof_hr_holidays/static/src/images/back.jpg') no-repeat; */
            /* background-size: cover; */
            background-color: #292929;
            }

            .thank {
            width: 600px;
            top: 40%;
            left: 50%;
            transform: translate(-50%, -50%);
            position: absolute;
            text-align: center;
            }

            .thank h1 {
            font-size: 60px;
            text-transform: uppercase;
            margin: 20px 0;
            color: #AF9B60;
            width: 100%;
            }

            .thank p {
            font-size: 22px;
            color: #fff;
            width: 100%;
            margin-bottom: 10px;
            }

            .home-btn {
            display: inline-block;
            margin-top: 25px;
            padding: 12px 24px;
            background-color: #AF9B60;
            color: #fff;
            text-decoration: none;
            border-radius: 6px;
            font-size: 18px;
            transition: 0.3s;
            }

            .home-btn:hover {
            background-color: #8f7d4d;
            }

            .home-btn i {
            margin-right: 8px;
            }

        </style>

        <div class="thank">
            <p>
                <i class="fa fa-check"/>
            </p>

            <h1>Thank You</h1>

            <p>Your request has been sent</p>
            <p>We will get back to you soon with any update on this</p>

            <a href="/my" class="home-btn">
                <i class="fa fa-home"></i>
                Home
            </a>
        </div>

    </template>
</odoo>