<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_offboarding_reject_wizard_form" model="ir.ui.view">
        <field name="name">pr.hr.offboarding.reject.wizard.form</field>
        <field name="model">pr.hr.offboarding.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Offboarding Request">
                <group>
                    <field name="request_id" invisible="1"/>
                    <field name="rejection_reason"
                           placeholder="Explain why this request is being rejected..."
                           required="1"/>
                </group>
                <footer>
                    <button name="action_reject"
                            string="Reject"
                            type="object"
                            class="btn-danger"/>
                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
