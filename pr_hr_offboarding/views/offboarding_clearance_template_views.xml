<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_offboarding_clearance_template_tree" model="ir.ui.view">
        <field name="name">pr.hr.offboarding.clearance.template.tree</field>
        <field name="model">pr.hr.offboarding.clearance.template</field>
        <field name="arch" type="xml">
            <tree string="Offboarding Clearance Templates">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="applies_to"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="view_offboarding_clearance_template_form" model="ir.ui.view">
        <field name="name">pr.hr.offboarding.clearance.template.form</field>
        <field name="model">pr.hr.offboarding.clearance.template</field>
        <field name="arch" type="xml">
            <form string="Offboarding Clearance Template">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="sequence"/>
                            <field name="applies_to"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Checklist Items">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="category"/>
                                    <field name="name"/>
                                    <field name="applies_to"/>
                                    <field name="responsible_user_id"/>
                                    <field name="required"/>
                                    <field name="settlement_effect"/>
                                    <field name="reminder_delay_days"/>
                                    <field name="reminder_activity_type_id"/>
                                    <field name="active" widget="boolean_toggle"/>
                                </tree>
                                <form>
                                    <group>
                                        <group>
                                            <field name="sequence"/>
                                            <field name="category"/>
                                            <field name="name"/>
                                            <field name="applies_to"/>
                                            <field name="active"/>
                                        </group>
                                        <group>
                                            <field name="responsible_user_id"/>
                                            <field name="required"/>
                                            <field name="settlement_effect"/>
                                            <field name="reminder_delay_days"/>
                                            <field name="reminder_activity_type_id"/>
                                        </group>
                                    </group>
                                    <group string="Description">
                                        <field name="description" nolabel="1"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_offboarding_clearance_templates" model="ir.actions.act_window">
        <field name="name">Clearance Checklist Templates</field>
        <field name="res_model">pr.hr.offboarding.clearance.template</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create reusable offboarding checklist templates.
            </p>
        </field>
    </record>

    <menuitem id="menu_offboarding_configuration"
              name="Configuration"
              parent="menu_hr_offboarding_root"
              sequence="90"
              groups="pr_hr_recruitment_request.group_onboarding_supervisor,base.group_system"/>

    <menuitem id="menu_offboarding_clearance_templates"
              name="Clearance Checklist Templates"
              parent="menu_offboarding_configuration"
              action="action_offboarding_clearance_templates"
              sequence="10"
              groups="pr_hr_recruitment_request.group_onboarding_supervisor,base.group_system"/>
</odoo>
