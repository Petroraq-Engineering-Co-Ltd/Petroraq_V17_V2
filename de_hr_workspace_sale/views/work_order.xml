<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <record id="pr_sale_work_order_ops_approval_action" model="ir.actions.act_window">
        <field name="name">Work Orders (Operations)</field>
        <field name="res_model">pr.work.order</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state','=','ops_approval')]</field>
        <field name="context">{'create':False,'edit':False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create A Work Order
            </p>
        </field>


    </record>

    <record id="pr_sale_work_order_accounts_approval_action" model="ir.actions.act_window">
        <field name="name">Work Orders (Accounts)</field>
        <field name="res_model">pr.work.order</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state','=','acc_approval')]</field>
        <field name="context">{'create':False,'edit':False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create A Work Order
            </p>
        </field>


    </record>

    <record id="pr_sale_work_order_final_approval_action" model="ir.actions.act_window">
        <field name="name">Work Orders (Final)</field>
        <field name="res_model">pr.work.order</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state','=','final_approval')]</field>
        <field name="context">{'create':False,'edit':False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create A Work Order
            </p>
        </field>


    </record>

    <menuitem id="work_order_ops_approvals_view_menu"
              parent="menu_my_sales_approvals"
              name="Work Orders"
              action="pr_sale_work_order_ops_approval_action"
              sequence="5"
              groups="pr_work_order.custom_group_work_order_operations"/>

    <menuitem id="work_order_accounts_approvals_view_menu"
              parent="menu_my_sales_approvals"
              name="Work Orders"
              action="pr_sale_work_order_accounts_approval_action"
              sequence="6"
              groups="pr_work_order.custom_group_work_order_accounts"/>

    <menuitem id="work_order_approvals_view_menu"
              parent="menu_my_sales_approvals"
              name="Work Orders"
              action="pr_sale_work_order_final_approval_action"
              sequence="7"
              groups="pr_work_order.custom_group_work_order_management"/>

</odoo>