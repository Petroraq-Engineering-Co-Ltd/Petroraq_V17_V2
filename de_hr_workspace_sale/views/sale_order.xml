<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <record id="pr_sale_workflow_sale_order_manager_action" model="ir.actions.act_window">
        <field name="name">Sale Quotations (Manager)</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('approval_state','=','to_manager')]</field>
        <field name="context">{'create':False,'edit':False}</field>
        <field name="search_view_id" ref="sale.sale_order_view_search_inherit_quotation"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create A New Quotations
            </p>
        </field>


    </record>

    <record id="pr_sale_workflow_sale_order_md_action" model="ir.actions.act_window">
        <field name="name">Sale Quotations (MD)</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('approval_state','=','to_md')]</field>
        <field name="context">{'create':False,'edit':False}</field>
        <field name="search_view_id" ref="sale.sale_order_view_search_inherit_quotation"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create A New Quotations
            </p>
        </field>


    </record>

    <menuitem id="sale_order_approvals_manager_view_menu"
              parent="menu_my_sales_approvals"
              name="Sale Quotations"
              action="pr_sale_workflow_sale_order_manager_action"
              sequence="1"
              groups="petroraq_sale_workflow.group_sale_approval_manager"/>

    <menuitem id="sale_order_approvals_md_view_menu"
              parent="menu_my_sales_approvals"
              name="Sale Quotations"
              action="pr_sale_workflow_sale_order_md_action"
              sequence="2"
              groups="petroraq_sale_workflow.group_sale_approval_md"/>

</odoo>