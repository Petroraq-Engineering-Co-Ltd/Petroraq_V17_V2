<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="de_hr_workspace_account_bank_payment_view_tree" model="ir.ui.view">
        <field name="name">de.hr.workspace.account.bank.payment.view.tree</field>
        <field name="model">pr.account.bank.payment</field>
        <field name="arch" type="xml">
            <tree string="Bank Payments">
                <field name="name" decoration-warning="1" string="Payment Number #"/>
                <field name="account_id" options="{'no_create':True, 'no_create_edit':True, 'no_quick_create':True}"/>
                <field name="account_name"/>
                <field name="description"/>
                <field name="accounting_date"/>
                <field name="company_id" options="{'no_create':True, 'no_create_edit':True, 'no_quick_create':True}"/>
                <field name="currency_id" options="{'no_create':True, 'no_create_edit':True, 'no_quick_create':True}"
                       column_invisible="True"/>
                <field name="total_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="accounting_manager_state" widget="badge" string="Status"
                       decoration-warning="accounting_manager_state == 'draft'"
                       decoration-info="accounting_manager_state in ['submit', 'finance_approve']"
                       decoration-success="accounting_manager_state == 'posted'"
                       decoration-danger="accounting_manager_state == 'cancel'"/>
            </tree>
        </field>
    </record>

    <record id="pr_account_bank_payment_approvals_view_action" model="ir.actions.act_window">
        <field name="name">Bank Payments</field>
        <field name="res_model">pr.account.bank.payment</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'tree', 'view_id': ref('de_hr_workspace_account_bank_payment_view_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('pr_account.pr_account_bank_payment_view_form')})]"/>
        <field name="domain">[]</field>
        <field name="context">{'create': False,'edit': False}</field>
        <field name="search_view_id" ref="pr_account.pr_account_bank_payment_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create A New Bank Payment
            </p>
        </field>
    </record>

    <record id="pr_account_bank_payment_approvals_workspace_action" model="ir.actions.server">
        <field name="name">Bank Payments</field>
        <field name="model_id" ref="pr_account.model_pr_account_bank_payment"/>
        <field name="state">code</field>
        <field name="code">action = model.action_workspace_bank_payment_approvals()</field>
    </record>

    <menuitem id="pr_account_bank_payment_approvals_view_menu"
              parent="menu_my_financial_accounting_approvals"
              name="Bank Payments"
              action="pr_account_bank_payment_approvals_workspace_action"
              sequence="4"
              groups="account.group_account_manager,pr_account.custom_group_accounting_manager,pr_account.custom_group_account_supervisor"/>

    <record id="pr_account_bank_payment_workspace_approval_buttons" model="ir.ui.view">
        <field name="name">pr.account.bank.payment.workspace.approval.buttons</field>
        <field name="model">pr.account.bank.payment</field>
        <field name="inherit_id" ref="pr_account.pr_account_bank_payment_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_finance_approve']" position="attributes">
                <attribute name="groups">account.group_account_manager,pr_account.custom_group_account_supervisor</attribute>
            </xpath>
            <xpath expr="//button[@name='action_approve_remaining_lines']" position="attributes">
                <attribute name="groups">account.group_account_manager,pr_account.custom_group_accounting_manager,pr_account.custom_group_account_supervisor</attribute>
            </xpath>
            <xpath expr="//button[@name='action_reject_remaining_lines']" position="attributes">
                <attribute name="groups">account.group_account_manager,pr_account.custom_group_accounting_manager,pr_account.custom_group_account_supervisor</attribute>
            </xpath>
            <xpath expr="//field[@name='bank_payment_line_ids']//button[@name='action_line_approve']" position="attributes">
                <attribute name="groups">account.group_account_manager,pr_account.custom_group_accounting_manager,pr_account.custom_group_account_supervisor</attribute>
            </xpath>
            <xpath expr="//field[@name='bank_payment_line_ids']//button[@name='action_line_reject']" position="attributes">
                <attribute name="groups">account.group_account_manager,pr_account.custom_group_accounting_manager,pr_account.custom_group_account_supervisor</attribute>
            </xpath>
        </field>
    </record>
</odoo>
