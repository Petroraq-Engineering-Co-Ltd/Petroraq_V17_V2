msgid ""
"<p>Dear HR Supervisor,</p><p><strong>%(document)s</strong> for "
"<strong>%(employee)s</strong> will expire in <strong>%(days)s "
"day(s)</strong>.</p><p>Record: %(record)s<br/>Expiry Date: "
"%(expiry_date)s</p><p>Please review and start the renewal process if it has "
"not already been completed.</p>"
msgstr ""
"<p>عزيزي مشرف الموارد البشرية،</p>"
"<p>ستنتهي صلاحية <strong>%(document)s</strong> الخاصة بالموظف "
"<strong>%(employee)s</strong> خلال <strong>%(days)s يومًا</strong>.</p>"
"<p>السجل: %(record)s<br/>تاريخ الانتهاء: %(expiry_date)s</p>"
"<p>يرجى المراجعة وبدء إجراءات التجديد إذا لم تكن قد اكتملت بالفعل.</p>"

#. module: qiwa_contract_ocr
#. odoo-python
#: code:addons/qiwa_contract_ocr/models/hr_applicant_onboarding.py:0
