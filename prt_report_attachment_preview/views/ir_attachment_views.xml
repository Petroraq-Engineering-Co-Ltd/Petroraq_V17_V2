<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_attachment_preview_tree" model="ir.ui.view">
        <field name="name">ir.attachment.preview.tree</field>
        <field name="model">ir.attachment</field>
        <field name="arch" type="xml">
            <tree string="Attachments" create="false">
                <field name="name"/>
                <field name="mimetype"/>
                <field name="file_size"/>
                <field name="create_uid"/>
                <field name="create_date"/>
                <button name="action_preview_inline"
                        type="object"
                        string="Preview"
                        icon="fa-eye"
                        class="btn-primary"/>
            </tree>
        </field>
    </record>

    <record id="view_attachment_preview_form" model="ir.ui.view">
        <field name="name">ir.attachment.preview.form</field>
        <field name="model">ir.attachment</field>
        <field name="arch" type="xml">
            <form string="Attachment" create="false">
                <header>
                    <button name="action_preview_inline"
                            type="object"
                            string="Preview"
                            icon="fa-eye"
                            class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="mimetype" readonly="1"/>
                            <field name="file_size" readonly="1"/>
                        </group>
                        <group>
                            <field name="type" readonly="1"/>
                            <field name="create_uid" readonly="1"/>
                            <field name="create_date" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
