<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_cleanup_late_machine_attendance" model="ir.cron">
            <field name="name">Cleanup late machine attendance</field>
            <field name="model_id" ref="hr_attendance.model_hr_attendance"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="state">code</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field eval="False" name="doall"/>
            <field name="nextcall" eval="(DateTime.now().replace(hour=20, minute=0, second=0, microsecond=0)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="code">model.cron_cleanup_late_machine_attendance()</field>
        </record>
    </data>
</odoo>