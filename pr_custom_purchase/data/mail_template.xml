<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="purchase_order_custom_email_template" model="mail.template">
            <field name="name">Petroraq Purchase Order</field>
            <field name="model_id" ref="purchase.model_purchase_order"/>
            <field name="email_from">{{ (object.user_id.email_formatted or object.company_id.email_formatted or user.email_formatted) }}</field>
            <field name="email_to">${(object.partner_id.email or '')}</field>
            <field name="partner_to">{{ object.partner_id.id }}</field>
            <field name="subject">Purchase Order: {{ object.name }}</field>
            <field name="auto_delete" eval="True"/>
            <field name="report_template_ids" eval="[(4, ref('pr_custom_purchase.petroraq_purchase_order_action_id'))]"/>
            <field name="body_html"><![CDATA[
                <p style="font-size:13px;">
                    Dear Vendor,<br/><br/>
                    Please find attached Purchase Order <strong><t t-out="object.name"/></strong>.<br/><br/>
                    Regards,
                    <t t-if="user.name"><br/><t t-out="user.name"/></t>
                </p>
            ]]></field>
        </record>
    </data>
</odoo>