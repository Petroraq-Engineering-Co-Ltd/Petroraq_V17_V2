<odoo>
    <record id="view_employee_form_inherit_userid_fix" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.user_id_domain_fix</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='hr_settings']//group[@name='active_group']//field[@name='user_id']"
                   position="replace">
                <field name="user_id"
                       string="Related User"
                       domain="[]"
                       context="{'default_create_employee_id': id}"
                       widget="many2one_avatar_user"/>
            </xpath>
        </field>
    </record>
    <!-- status field on PO -->
    <record id="view_purchase_order_form_inherit_approvals" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.approvals</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <field name="partner_ref" position="after">
                <!-- Hidden computed fields for visibility logic -->
                <field name="show_pe_approved" invisible="1"/>
                <field name="show_pm_approved" invisible="1"/>
                <field name="show_od_approved" invisible="1"/>
                <field name="show_md_approved" invisible="1"/>
                <field name="can_confirm_order" invisible="1"/>
                <field name="approval_status" widget="badge" readonly="1"/>
            </field>
        </field>
    </record>
    <!-- confirm order button -->
    <record id="purchase_order_form_inherit_hide_confirm" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.hide.confirm</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <!-- Add the can_confirm_order field so it can be used in button visibility -->
            <!-- <xpath expr="//field[@name='partner_ref']" position="after"> -->
            <xpath expr="//header" position="before">
                <field name='subtotal' invisible='1'/>
                <field name="can_confirm_order" invisible="1"/>
                <field name="is_rfq_record" invisible="1"/>
            </xpath>
            <!-- Replace Odoo's sent-state Confirm button with an approval Submit button. -->
            <xpath expr="//header/button[@id='bid_confirm']" position="replace">
                <button name="action_submit_for_approval"
                        type="object"
                        string="Submit"
                        class="btn btn-primary"
                        invisible="is_rfq_record or state not in ('draft', 'sent')"
                        groups="pr_custom_purchase.procurement_admin,purchase.group_purchase_manager"/>
            </xpath>
            <!-- Hide Odoo's draft-state Confirm button: PO approval starts from Submit. -->
            <xpath expr="//header/button[@id='draft_confirm']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//header" position="inside">
                <button name="action_open_reject_wizard"
                        type="object"
                        string="Reject"
                        class="btn btn-danger"
                        invisible="state != 'pending' or not show_pe_approved or can_confirm_order"
                        groups="pr_custom_purchase.project_engineer"/>
                <button name="action_open_reject_wizard"
                        type="object"
                        string="Reject"
                        class="btn btn-danger"
                        invisible="state != 'pending' or not show_pm_approved or can_confirm_order"
                        groups="pr_custom_purchase.project_manager"/>
                <button name="action_open_reject_wizard"
                        type="object"
                        string="Reject"
                        class="btn btn-danger"
                        invisible="state != 'pending' or not show_od_approved or can_confirm_order"
                        groups="pr_custom_purchase.operations_director"/>
                <button name="action_open_reject_wizard"
                        type="object"
                        string="Reject"
                        class="btn btn-danger"
                        invisible="state != 'pending' or not show_md_approved or can_confirm_order"
                        groups="pr_custom_purchase.managing_director"/>
                <button name="action_reset_to_draft"
                        type="object"
                        string="Reset to Draft"
                        class="btn btn-secondary"
                        invisible="state in ('draft', 'done')"
                        groups="pr_custom_purchase.procurement_admin,pr_custom_purchase.project_engineer,pr_custom_purchase.project_manager,pr_custom_purchase.operations_director,pr_custom_purchase.managing_director"/>
            </xpath>
        </field>
    </record>
    <!-- states in purhcase order -->
    <record id="purchase_order_form_inherit_pending" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.pending</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <!-- Extend the statusbar to show 'pending' before 'purchase' -->
            <xpath expr="//field[@name='state']" position="attributes">
                <attribute name="statusbar_visible">draft,sent,pending,purchase,done,rejected,cancel</attribute>
            </xpath>
        </field>
    </record>
    <!-- purchase order custom line view -->
    <record id="view_purchase_order_form_inherit_custom" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.custom</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']" position="attributes">
                <attribute name="readonly">state in ('purchase', 'done', 'rejected', 'cancel')</attribute>
            </xpath>
            <!-- Hide the existing Products page -->
            <xpath expr="//page[@name='products']" position="attributes">
                <attribute name="invisible">0</attribute>
            </xpath>
            <!-- Add a new custom page after Products -->
            <xpath expr="//notebook/page[@name='products']" position="after">
                <page string="Products Information" name="custom_lines" invisible="1">
                    <field name="order_line">
                        <tree editable="bottom">
                            <field name="name" readonly="1"/>
                            <field name="product_qty" readonly="1"/>
                            <field name="price_unit" readonly="1"/>
                            <field name="price_subtotal" readonly="1"/>
                        </tree>
                    </field>
                    <div class="total_amount_main">
                        <div class="total_amount_quotation">
                            <div class="total_padding total-amount-highlight">
                                <label for="subtotal">SubTotal</label>
                                <!-- Use computed field on purchase.order -->
                                <field name="subtotal" readonly="1" class="oe_inline"/>
                            </div>
                            <div class="total_padding total-amount-highlight" invisible="state != 'purchase'">
                                <label for="tax_15">15% Tax:</label>
                                <!-- Use computed field on purchase.order -->
                                <field name="tax_15" readonly="1" class="oe_inline"/>
                            </div>
                            <div class="total_padding total-amount-highlight" invisible="state != 'purchase'">
                                <label for="grand_total">Grand Total:</label>
                                <!-- Use computed field on purchase.order -->
                                <field name="grand_total" readonly="1" class="oe_inline"/>
                            </div>
                        </div>
                    </div>
                </page>
            </xpath>
        </field>
    </record>
    <!-- Project Field in purchase order -->
    <record id="view_purchase_order_form_inherit_project" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.project</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="priority">16</field>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <field name="budget_count" invisible="1"/>
                <button class="oe_stat_button"
                        name="action_view_related_budgets"
                        type="object"
                        icon="fa-money"
                        invisible="budget_count == 0">
                    <field name="budget_count" widget="statinfo" string="Budgets"/>
                </button>
            </xpath>
            <xpath expr="//field[@name='partner_ref']" position="after">
                <field name="project_id"/>
                <field name="budget_consumed_amount" readonly="1"/>
                <field name="budget_remaining_amount" readonly="1"/>
            </xpath>
        </field>
    </record>
    <!-- RFQ and PO list view -->
    <record id="purchase_order_inherit_tree" model="ir.ui.view">
        <field name="name">purchase.order.inherit.purchase.order.tree</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_kpis_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree/field[@name='state']" position="after">
                <field name="approval_status" widget="badge" optional="show"
                       decoration-success="approval_status == 'approved'"
                       decoration-danger="approval_status == 'rejected'"
                       decoration-warning="approval_status in ('pending_pe','pending_pm','pending_od','pending_md')"
                       decoration-muted="approval_status == 'not_submitted'"/>
            </xpath>
            <xpath expr="//tree/field[@name='partner_ref']" position="attributes">
                <attribute name="optional">show</attribute>
                <attribute name="string">Vendor Reference</attribute>
            </xpath>
            <xpath expr="//tree/field[@name='amount_total']" position="after">
                <field name="budget_consumed_amount" optional="hide"/>
                <field name="budget_remaining_amount" optional="show"/>
            </xpath>
        </field>
    </record>
    <record id="purchase_order_inherit_tree_custom" model="ir.ui.view">
        <field name="name">purchase.order.inherit.purchase.order.tree.custom</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree/field[@name='state']" position="after">
                <field name="approval_status" widget="badge" optional="show"
                       decoration-success="approval_status == 'approved'"
                       decoration-danger="approval_status == 'rejected'"
                       decoration-warning="approval_status in ('pending_pe','pending_pm','pending_od','pending_md')"
                       decoration-muted="approval_status == 'not_submitted'"/>
            </xpath>
            <xpath expr="//tree/field[@name='partner_ref']" position="attributes">
                <attribute name="optional">show</attribute>
                <attribute name="string">Vendor Reference</attribute>
            </xpath>
            <xpath expr="//tree/field[@name='amount_total']" position="after">
                <field name="budget_consumed_amount" optional="hide"/>
                <field name="budget_remaining_amount" optional="show"/>
            </xpath>
        </field>
    </record>
    <record id="purchase_order_inherit_tree_activity" model="ir.ui.view">
        <field name="name">purchase.order.inherit.purchase.order.tree.activity</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree/field[@name='state']" position="after">
                <field name="approval_status" widget="badge" optional="show"
                       decoration-success="approval_status == 'approved'"
                       decoration-danger="approval_status == 'rejected'"
                       decoration-warning="approval_status in ('pending_pe','pending_pm','pending_od','pending_md')"
                       decoration-muted="approval_status == 'not_submitted'"/>
            </xpath>
            <xpath expr="//tree/field[@name='partner_ref']" position="attributes">
                <attribute name="optional">show</attribute>
                <attribute name="string">Vendor Reference</attribute>
            </xpath>
        </field>
    </record>
    <record id="purchase_order_form_vendor_reference_first" model="ir.ui.view">
        <field name="name">purchase.order.form.vendor.reference.first</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="priority">80</field>
        <field name="arch" type="xml">
            <xpath expr="//group/field[@name='partner_id']" position="before">
                <xpath expr="//field[@name='partner_ref']" position="move"/>
            </xpath>
            <xpath expr="//field[@name='partner_ref']" position="attributes">
                <attribute name="string">Vendor Reference</attribute>
            </xpath>
        </field>
    </record>
    <record id="purchase_order_form_payment_terms_text" model="ir.ui.view">
        <field name="name">purchase.order.form.payment.terms.text</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="priority">82</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='payment_term_id']" position="after">
                <field name="payment_terms_text"
                       required="state not in ('purchase', 'done', 'cancel')"
                       placeholder="Example: 30 days from invoice date, 50% advance / 50% after delivery..."
                       readonly="state in ('purchase', 'done')"/>
            </xpath>
        </field>
    </record>
    <record id="view_purchase_order_form_inherit_grn_ses" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.grn.ses</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/sheet" position="inside">
                <!-- Hidden helper field -->
                <field name="state" invisible="1"/>
            </xpath>
            <header position="inside">
                <button name="create_grn_ses"
                        string="Create GRN"
                        type="object"
                        invisible="1"
                        groups='pr_custom_purchase.inventory_data_entry'/>
            </header>
            <header position="inside">
                <button name="create_grn_ses"
                        string="Create SES"
                        type="object"
                        invisible="1"
                        groups='pr_custom_purchase.inventory_data_entry'/>
            </header>
            <header position="inside">
                <button name="create_grn_ses"
                        string="Create GRN/SES"
                        type="object"
                        invisible="1"
                        groups='pr_custom_purchase.inventory_data_entry'/>
            </header>
        </field>
    </record>
    <record id="purchase_order_form_inherit_approve_button" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.approve.button</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_approve"
                        type="object"
                        string="Approve"
                        class="btn btn-primary"
                        invisible="state != 'pending' or not show_pe_approved or can_confirm_order"
                        groups="pr_custom_purchase.project_engineer"/>
                <button name="action_approve"
                        type="object"
                        string="Approve"
                        class="btn btn-primary"
                        invisible="state != 'pending' or not show_pm_approved or subtotal &lt;= 10000 or can_confirm_order"
                        groups="pr_custom_purchase.project_manager"/>
                <button name="action_approve"
                        type="object"
                        string="Approve"
                        class="btn btn-primary"
                        invisible="state != 'pending' or not show_od_approved or subtotal &lt;= 100000 or can_confirm_order"
                        groups="pr_custom_purchase.operations_director"/>
                <button name="action_approve"
                        type="object"
                        string="Approve"
                        class="btn btn-primary"
                        invisible="state != 'pending' or not show_md_approved or can_confirm_order"
                        groups="pr_custom_purchase.managing_director"/>
            </xpath>
        </field>
    </record>

    <record id="view_purchase_order_reject_wizard_form" model="ir.ui.view">
        <field name="name">purchase.order.reject.wizard.form</field>
        <field name="model">purchase.order.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Purchase Order">
                <group>
                    <field name="purchase_order_id" readonly="1"/>
                    <field name="reason" required="1" placeholder="Enter reason for rejection"/>
                </group>
                <footer>
                    <button name="action_confirm_reject" type="object" string="Reject" class="btn-danger"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
