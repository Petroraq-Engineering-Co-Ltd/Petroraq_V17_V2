<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_account_analytic_account_form_budget_inherit" model="ir.ui.view">
        <field name="name">account.analytic.account.form.budget.inherit.pr.custom.purchase</field>
        <field name="model">account.analytic.account</field>
        <field name="inherit_id" ref="analytic.view_account_analytic_account_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/group" position="inside">
                <group string="Budget">
                    <field name="expense_bucket_id" readonly="1"/>
                    <field name="budget_type" readonly="1"/>
                    <field name="budget_code" readonly="1"/>
                    <field name="budget_allowance" readonly="1"/>
                    <field name="budget_spent" readonly="1"/>
                    <field name="budget_left" readonly="1"/>
                    <field name="budget_expensed" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="view_account_analytic_account_form_budget_line_columns" model="ir.ui.view">
        <field name="name">account.analytic.account.form.budget.line.columns.pr.custom.purchase</field>
        <field name="model">account.analytic.account</field>
        <field name="inherit_id" ref="analytic.view_account_analytic_account_form"/>
        <field name="priority">50</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='crossovered_budget_line']/tree/field[@name='planned_amount']" position="attributes">
                <attribute name="string">Total Amount</attribute>
                <attribute name="sum">Total Amount</attribute>
            </xpath>
            <xpath expr="//field[@name='crossovered_budget_line']/tree/field[@name='planned_amount']" position="after">
                <field name="po_spent_amount" string="Spent Amount" readonly="1" optional="show"/>
                <field name="budget_remaining_amount" string="Remaining Amount" readonly="1" optional="show"/>
            </xpath>
            <xpath expr="//field[@name='crossovered_budget_line']/tree/field[@name='practical_amount']" position="attributes">
                <attribute name="string">Expensed Amount</attribute>
                <attribute name="sum">Expensed Amount</attribute>
                <attribute name="optional">show</attribute>
            </xpath>
            <xpath expr="//field[@name='crossovered_budget_line']/tree/field[@name='percentage']" position="attributes">
                <attribute name="column_invisible">1</attribute>
                <attribute name="optional">hide</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_crossovered_budget_line_tree_metrics" model="ir.ui.view">
        <field name="name">crossovered.budget.line.tree.metrics.pr.custom.purchase</field>
        <field name="model">crossovered.budget.lines</field>
        <field name="inherit_id" ref="account_budget.view_crossovered_budget_line_tree"/>
        <field name="arch" type="xml">
            <field name="planned_amount" position="attributes">
                <attribute name="string">Total Amount</attribute>
            </field>
            <field name="planned_amount" position="after">
                <field name="po_spent_amount" string="Spent Amount" readonly="1"/>
                <field name="budget_remaining_amount" string="Remaining Amount" readonly="1"/>
                <field name="budget_expensed_amount" string="Expensed Amount" readonly="1"/>
            </field>
            <field name="practical_amount" position="attributes">
                <attribute name="string">Odoo Practical Amount</attribute>
                <attribute name="column_invisible">1</attribute>
            </field>
        </field>
    </record>

    <record id="view_crossovered_budget_line_form_metrics" model="ir.ui.view">
        <field name="name">crossovered.budget.line.form.metrics.pr.custom.purchase</field>
        <field name="model">crossovered.budget.lines</field>
        <field name="inherit_id" ref="account_budget.view_crossovered_budget_line_form"/>
        <field name="arch" type="xml">
            <field name="planned_amount" position="attributes">
                <attribute name="string">Total Amount</attribute>
            </field>
            <field name="planned_amount" position="after">
                <field name="po_spent_amount" string="Spent Amount" readonly="1"/>
                <field name="budget_remaining_amount" string="Remaining Amount" readonly="1"/>
                <field name="budget_expensed_amount" string="Expensed Amount" readonly="1"/>
            </field>
            <field name="practical_amount" position="attributes">
                <attribute name="string">Odoo Practical Amount</attribute>
                <attribute name="invisible">1</attribute>
            </field>
        </field>
    </record>
</odoo>
