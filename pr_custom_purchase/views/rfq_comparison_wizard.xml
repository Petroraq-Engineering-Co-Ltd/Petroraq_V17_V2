<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_rfq_comparison_wizard_form" model="ir.ui.view">
        <field name="name">rfq.comparison.wizard.form</field>
        <field name="model">rfq.comparison.wizard</field>
        <field name="arch" type="xml">
            <form string="RFQ Comparison">
                <header>
                    <button name="action_export_excel" string="Export Excel" type="object" class="btn-secondary"/>
                    <button name="action_create_selected_purchase_orders" string="Create Purchase Orders" type="object"
                            class="btn-primary"/>
                </header>
                <sheet>
                    <div style="display: grid; grid-template-columns: repeat(2, 1fr); grid-row-gap: 10px; grid-column-gap: 20px; background: #f4f6fa; padding: 15px; border-radius: 6px; border-left: 4px solid #173b76; margin-bottom: 15px;">
                        <div>
                            <span style="color:#173b76; font-weight:600;">Purchase Requisition:</span>
                            <field name="requisition_id" readonly="1"/>
                        </div>
                        <div>
                            <span style="color:#173b76; font-weight:600;">Suppliers:</span>
                            <field name="vendor_ids" widget="many2many_tags" readonly="1"/>
                        </div>
                    </div>

                    <separator string="Material Requirement (Default Supplier = Lowest Price)"/>
                    <div class="oe_full">
                        <field name="line_ids" nolabel="1">
                            <tree create="0" delete="0" editable="bottom" limit="200">
                                <field name="sequence"/>
                                <field name="description"/>
                                <field name="unit"/>
                                <field name="quantity"/>
                                <field name="selected_vendor_id" domain="[('id', 'in', parent.vendor_ids)]"/>
                            </tree>
                        </field>
                    </div>

                    <separator string="Comparison Matrix"/>
                    <div class="rfq-comparison-matrix-wrap">
                        <field name="comparison_html" widget="html" nolabel="1" readonly="1"/>
                    </div>
                </sheet>
                <footer>
                    <button name="action_export_excel" string="Export Excel" type="object" class="btn-secondary"/>
                    <button name="action_create_selected_purchase_orders" string="Create Purchase Orders" type="object"
                            class="btn-primary"/>
                    <button string="Close" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_rfq_comparison_selection_wizard_form" model="ir.ui.view">
        <field name="name">rfq.comparison.selection.wizard.form</field>
        <field name="model">rfq.comparison.selection.wizard</field>
        <field name="arch" type="xml">
            <form string="Quotations Comparison" create="false" edit="false" delete="false">

                <sheet>
                    <group>
                        <field name="requisition_id" options="{'no_create': True}"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_view_comparison" string="View Comparison" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_rfq_comparison_selection_wizard" model="ir.actions.act_window">
        <field name="name">Quotations Comparison</field>
        <field name="res_model">rfq.comparison.selection.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_rfq_comparison_wizard"
              name="Quotations Comparison"
              parent="purchase.menu_purchase_root"
              action="action_rfq_comparison_selection_wizard"
              sequence="133"
              groups="pr_custom_purchase.procurement_admin,purchase.group_purchase_manager"/>
</odoo>