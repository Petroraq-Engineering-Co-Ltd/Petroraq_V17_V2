<odoo>
    <record id="view_users_form_inherit_pr_supervisor" model="ir.ui.view">
        <field name="name">res.users.form.inherit.pr.supervisor</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='preferences']" position="inside">
                <label for="supervisor_user_id">Supervisor:</label>
                <field name="supervisor_user_id"/>
            </xpath>
        </field>
    </record>
</odoo>
