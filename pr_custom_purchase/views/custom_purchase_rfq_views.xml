<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_custom_purchase_rfq_tree" model="ir.ui.view">
        <field name="name">purchase.order.tree</field>
        <field name="model">purchase.order</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="date_order"/>
                <field name="date_planned"/>
                <field name="origin"/>
                <field name="pr_name"/>
                <field name="amount_total"/>
                <field name="currency_id" optional="hide"/>
                <field name="state" widget="badge"
                       decoration-success="state in ('purchase', 'done')"
                       decoration-danger="state == 'cancel'"
                       decoration-warning="state in ('sent','pending')"
                       decoration-info="state == 'draft'"/>
                <field name="linked_pr_state" widget="badge"
                       decoration-success="linked_pr_state == 'purchase'"
                       decoration-danger="linked_pr_state == 'cancel'"
                       decoration-warning="linked_pr_state in ('rfq_sent','pending')"
                       decoration-muted="linked_pr_state in ('draft','missing')"/>
                <field name="linked_quotation_status" widget="badge"
                       decoration-success="linked_quotation_status == 'po'"
                       decoration-info="linked_quotation_status == 'quote'"
                       decoration-muted="linked_quotation_status == 'missing'"/>
                <field name="linked_po_state" widget="badge"
                       decoration-success="linked_po_state in ('purchase','done')"
                       decoration-danger="linked_po_state == 'cancel'"
                       decoration-warning="linked_po_state == 'pending'"
                       decoration-info="linked_po_state in ('draft','sent')"
                       decoration-muted="linked_po_state == 'missing'"/>
                <field name="quotation_count"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_custom_purchase_rfq_form" model="ir.ui.view">
        <field name="name">purchase.order.form</field>
        <field name="model">purchase.order</field>
        <field name="arch" type="xml">
            <form string="RFQ">
                <header>
                    <button name="action_rfq_send" type="object" string="Send by Email" class="btn-primary"
                            invisible="not is_rfq_record"/>
                    <button name="button_confirm" type="object" string="Confirm Order" class="btn-primary"
                            invisible="is_rfq_record"
                            groups="purchase.group_purchase_user"/>
                    <button name="button_cancel" type="object" string="Cancel" class="btn-secondary"
                            invisible="not is_rfq_record"/>
                    <button name="button_draft" type="object" string="Reset to RFQ" class="btn-secondary"
                            invisible="is_rfq_record"/>
                    <button name="action_view_quotations" type="object" string="Related RFQs"
                            class="btn-primary"
                            groups="pr_custom_purchase.procurement_admin"
                            invisible="is_rfq_record"/>

                    <button name="action_open_rfq_comparison" type="object" string="Compare RFQs"
                            class="btn-secondary"
                            groups="pr_custom_purchase.procurement_admin"
                            invisible="1"/>
                    <button name="action_reset_to_draft" type="object" string="Reset RFQ" class="btn-secondary"
                            invisible="is_rfq_record"
                            groups="pr_custom_purchase.procurement_admin,purchase.group_purchase_manager"/>
                    <field name="is_rfq_record" invisible="1"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,sent,pending,purchase,done,cancel"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_quotations" type="object" class="oe_stat_button" icon="fa-list-alt"
                                invisible="1">
                            <field name="quotation_count" widget="statinfo" string="RFQs"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="partner_ref"/>
                            <field name="name" readonly="1"/>
                            <field name="origin"/>
                            <field name="currency_id"/>
                            <field name="company_id"/>
                        </group>
                        <group>
                            <field name="date_order"/>
                            <field name="date_planned"/>
                            <field name="payment_term_id"/>
                            <field name="fiscal_position_id"/>
                            <field name="incoterm_id"/>
                            <field name="user_id" string="Buyer"/>
                        </group>
                    </group>

                    <group string="RFQ Details">
                        <group>
                            <field name="pr_name" readonly="1"/>
                            <field name="requisition_id" readonly="1"/>
                            <field name="date_request" readonly="1"/>
                        </group>
                        <group>
                            <field name="requested_by" readonly="1"/>
                            <field name="department" readonly="1"/>
                            <field name="supervisor" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Products">

                            <field name="order_line" readonly="1">
                                <tree>
                                    <field name="product_id"/>
                                    <field name="name"/>
                                    <field name="product_qty"/>
                                    <field name="product_uom"/>
                                    <field name="price_unit"/>
                                    <field name="price_subtotal"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Other Information">
                            <group>
                                <group>
                                    <field name="project_id"/>
                                    <field name="notes" placeholder="Terms and conditions..."/>
                                </group>
                                <group>
                                    <field name="linked_pr_state" widget="badge"
                                           decoration-success="linked_pr_state == 'purchase'"
                                           decoration-danger="linked_pr_state == 'cancel'"
                                           decoration-warning="linked_pr_state in ('rfq_sent','pending')"
                                           decoration-muted="linked_pr_state in ('draft','missing')"/>
                                    <field name="linked_quotation_status" widget="badge"
                                           decoration-success="linked_quotation_status == 'po'"
                                           decoration-info="linked_quotation_status == 'quote'"
                                           decoration-muted="linked_quotation_status == 'missing'"/>
                                    <field name="linked_po_state" widget="badge"
                                           decoration-success="linked_po_state in ('purchase','done')"
                                           decoration-danger="linked_po_state == 'cancel'"
                                           decoration-warning="linked_po_state == 'pending'"
                                           decoration-info="linked_po_state in ('draft','sent')"
                                           decoration-muted="linked_po_state == 'missing'"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_custom_purchase_rfq" model="ir.actions.act_window">
        <field name="name">RFQs</field>
        <field name="res_model">purchase.order</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('state','in',['draft','sent','cancel'])]</field>
    </record>

    <menuitem id="menu_custom_purchase_rfq_root"
              name="RFQs"
              parent="purchase.menu_purchase_root"
              sequence="132"
              groups="pr_custom_purchase.procurement_admin,purchase.group_purchase_manager"/>

    <menuitem id="menu_custom_purchase_rfq"
              name="All RFQs"
              parent="menu_custom_purchase_rfq_root"
              action="action_custom_purchase_rfq"
              sequence="10"
              groups="pr_custom_purchase.procurement_admin,purchase.group_purchase_manager"/>


    <record id="action_custom_purchase_order" model="ir.actions.act_window">
        <field name="name">Purchase Orders</field>
        <field name="res_model">purchase.order</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('state','in',['pending','purchase','done'])]</field>
    </record>

    <menuitem id="menu_custom_purchase_order_root"
              name="Purchase Orders"
              parent="purchase.menu_purchase_root"
              sequence="133"
              groups="pr_custom_purchase.procurement_admin,purchase.group_purchase_manager"/>

    <menuitem id="menu_custom_purchase_order"
              name="All Purchase Orders"
              parent="menu_custom_purchase_order_root"
              action="action_custom_purchase_order"
              sequence="10"
              groups="pr_custom_purchase.procurement_admin,purchase.group_purchase_manager"/>

    <!-- Keep Odoo core actions aligned with custom state semantics. -->
    <record id="purchase.purchase_rfq" model="ir.actions.act_window">
        <field name="name">RFQs</field>
        <field name="domain">[('state','in',['draft','sent'])]</field>
    </record>

    <record id="purchase.purchase_form_action" model="ir.actions.act_window">
        <field name="name">Purchase Orders</field>
        <field name="domain">[('state','in',['pending','purchase','done'])]</field>
    </record>

    <!-- Hide Odoo default Purchasing menus to avoid conflicting definitions. -->
    <record id="purchase.menu_purchase_rfq" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('base.group_no_one')])]"/>
    </record>

    <record id="purchase.menu_purchase_form_action" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('base.group_no_one')])]"/>
    </record>

</odoo>