<odoo>
    <!-- Action for Purchase Orders -->
    <record id="action_inventory_purchase_orders" model="ir.actions.act_window">
        <field name="name">Purchase Orders</field>
        <field name="res_model">purchase.order</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="purchase.purchase_order_tree"/>
        <field name="domain">[('state', '=', 'purchase')]</field>
    </record>
    <!-- Menu item under Inventory -->
    <menuitem id="menu_inventory_purchase_orders"
              name="Purchase Orders"
              parent="stock.menu_stock_root"
              action="action_inventory_purchase_orders"
              sequence="10"
              groups="base.group_user"/>
    <!-- GRN/SES -->
    <record id="view_grn_ses_tree" model="ir.ui.view">
        <field name="name">grn.ses.tree</field>
        <field name="model">grn.ses</field>
        <field name="arch" type="xml">
            <tree string="GRN/SES">
                <field name="name"/>
                <field name="partner_ref"/>
                <field name="date_order"/>
                <field name="date_planned"/>
                <field name="stage"/>
            </tree>
        </field>
    </record>
    <!-- Form view -->
    <record id="view_grn_ses_form" model="ir.ui.view">
        <field name="name">grn.ses.form</field>
        <field name="model">grn.ses</field>
        <field name="arch" type="xml">
            <form string="GRN/SES">
                <header>
                    <field name="stage" invisible="1"/>

                    <!-- Review button (only show if not reviewed yet) -->
                    <button name="action_review"
                            string="Review"
                            type="object"
                            class="btn-primary"
                            groups="pr_custom_purchase.inventory_qc"
                            invisible="is_reviewed"/>
                    <!-- Approve button (only visible after review, and if not approved yet) -->
                    <button name="action_approve"
                            string="Approve"
                            type="object"
                            class="btn-primary"
                            groups="pr_custom_purchase.inventory_admin"
                            invisible="not is_reviewed or is_approved"/>
                    <button name="action_create_vendor_bill"
                            string="Create Vendor Bill"
                            type="object"
                            class="btn-secondary"
                            invisible="stage != 'approved'"
                            groups="account.group_account_user,account.group_account_manager"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object" class="oe_stat_button" icon="fa-file-text-o"
                                name="action_view_vendor_bills" invisible="bill_count == 0">
                            <field name="bill_count" widget="statinfo" string="Vendor Bills"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="is_reviewed" invisible="1"/>
                            <field name="is_approved" invisible="1"/>
                            <field name="name" readonly="1"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="purchase_order_id" readonly="1"/>
                            <field name="partner_ref" readonly="1"/>
                            <field name="project" readonly="1"/>
                        </group>
                        <group>
                            <field name="date_order" readonly="1"/>
                            <field name="date_planned" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="GRN/SES">
                            <field name="line_ids" readonly='1'>
                                <tree editable="bottom">
                                    <field name="name" readonly="1"/>
                                    <field name="type" readonly="1"/>
                                    <field name="unit" readonly="1"/>
                                    <field name="quantity" readonly="1"/>
                                    <field name="remarks"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <!-- Action -->
    <record id="action_inventory_grn_ses" model="ir.actions.act_window">
        <field name="name">GRN/SES</field>
        <field name="res_model">grn.ses</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[]</field>
    </record>
    <!-- Menu item -->
    <menuitem id="menu_inventory_grn_ses"
              name="GRN/SES"
              parent="stock.menu_stock_root"
              action="action_inventory_grn_ses"
              sequence="11"
              groups="base.group_user"/>
</odoo>