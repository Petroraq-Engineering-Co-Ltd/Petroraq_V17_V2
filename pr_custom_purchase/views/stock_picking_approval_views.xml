<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_stock_picking_form_inherit_receipt_approval" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.receipt.approval</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/header/field[@name='state']" position="before">
                <button name="action_approve_receipt" type="object" string="Approve Receipt"
                        class="btn-primary"
                        groups="pr_custom_purchase.inventory_admin"
                        invisible="picking_type_code != 'incoming' or state in ('done','cancel') or receipt_approval_state_ui in ('approved','rejected')"/>
                <button name="action_open_receipt_reject_wizard" type="object" string="Reject Receipt"
                        class="btn-danger"
                        groups="pr_custom_purchase.inventory_admin"
                        invisible="picking_type_code != 'incoming' or state in ('done','cancel') or receipt_approval_state_ui in ('approved','rejected')"/>
                <field name="receipt_approval_state_ui" widget="badge"
                       decoration-warning="receipt_approval_state_ui == 'pending'"
                       decoration-success="receipt_approval_state_ui == 'approved'"
                       decoration-danger="receipt_approval_state_ui == 'rejected'"
                       invisible="picking_type_code != 'incoming'"/>
            </xpath>
        </field>
    </record>

    <record id="view_stock_picking_reject_wizard_form" model="ir.ui.view">
        <field name="name">stock.picking.reject.wizard.form</field>
        <field name="model">stock.picking.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Receipt">
                <group>
                    <field name="picking_id" readonly="1"/>
                    <field name="rejection_reason" placeholder="Please provide rejection reason..."/>
                </group>
                <footer>
                    <button name="action_confirm_reject" type="object" string="Reject" class="btn-danger"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>