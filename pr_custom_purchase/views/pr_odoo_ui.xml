<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- List view for Purchase Requisition -->
    <record id="view_purchase_requisition_list" model="ir.ui.view">
        <field name="name">purchase.requisition.list</field>
        <field name="model">purchase.requisition</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="requested_by"/>
                <field name="status" widget="badge"
                       decoration-success="status in ('po', 'completed')"
                       decoration-warning="status == 'rfq'"
                       decoration-info="status == 'pr'"/>
                <field name="approval" widget="badge"
                       decoration-success="approval == 'approved'"
                       decoration-danger="approval == 'rejected'"
                       decoration-info="approval == 'pending'"/>
                <field name="date_request"/>
            </tree>
        </field>
    </record>
    <!-- Form view for Purchase Requisition -->
    <record id="view_purchase_requisition_form" model="ir.ui.view">
        <field name="name">purchase.requisition.form</field>
        <field name="model">purchase.requisition</field>
        <field name="arch" type="xml">
            <form string="Purchase Requisition">
                <header>
                    <button name="action_supervisor_approve"
                            type="object"
                            string="Approve"
                            class="btn-primary"
                            invisible="not is_supervisor or approval != 'pending'"/>
                    <button name="action_supervisor_reject_wizard"
                            type="object"
                            string="Reject"
                            class="btn-secondary"
                            invisible="not is_supervisor or approval != 'pending'"/>
                    <button name="action_request_budget_increase"
                            type="object"
                            string="Request Budget Increase"
                            class="btn-secondary"
                            invisible="not show_request_budget_increase_button"/>
                    <button name="action_create_rfq"
                            type="object"
                            string="Create RFQ"
                            class="btn-primary"
                            groups="pr_custom_purchase.procurement_admin"
                            invisible="not show_create_rfq_button"/>
                    <!-- Show Create Purchase Order button only if pr_type == 'cash' -->
                    <button name="action_create_purchase_order"
                            type="object"
                            string="Create Purchase Order"
                            class="btn-primary"
                            groups="pr_custom_purchase.procurement_admin"
                            invisible="not show_create_po_button"/>
                </header>
                <sheet>
                    <!-- Hidden fields for button visibility logic -->
                    <field name="pr_type" invisible="1"/>
                    <field name="show_create_rfq_button" invisible="1"/>
                    <field name="show_create_po_button" invisible="1"/>
                    <field name="is_supervisor" invisible="1"/>
                    <field name="wo_variance_requires_approval" invisible="1"/>
                    <field name="rfq_count" invisible="1"/>
                    <field name="rfq_sent_count" invisible="1"/>
                    <field name="show_request_budget_increase_button" invisible="1"/>

                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_related_rfqs"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-envelope-open-o"
                                groups="pr_custom_purchase.procurement_admin,purchase.group_purchase_manager">
                            <field name="rfq_count" widget="statinfo" string="RFQs"/>
                        </button>
                    </div>

                    <div class="alert alert-warning"
                         role="alert"
                         invisible="not wo_variance_requires_approval">
                        Quantity or unit cost exceeds Work Order baseline for one or more lines, but total line amount
                        is still within Work Order budget. Supervisor approval is required before RFQ/PO creation.
                    </div>

                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="date_request" readonly="1"/>
                            <field name="department" readonly="1"/>
                            <field name="supervisor" readonly="1"/>
                            <field name="vendor_id" groups="pr_custom_purchase.procurement_admin"/>
                            <field name="expense_bucket_id" readonly="1"/>
                            <field name="expense_scope" readonly="1"/>
                            <field name="expense_type" readonly="1"/>
                            <field name="status" invisible="1"/>
                            <field name="rfq_sent_count" readonly="1"/>
                            <field name="requested_user_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="required_date" readonly="1"/>
                            <field name="priority" readonly="1"/>
                            <field name="approval" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Products">
                            <field name="line_ids" readonly="1">
                                <tree editable="bottom">
                                    <field name="description"/>
                                    <field name="cost_center_id" domain="[('expense_bucket_id', '=', parent.expense_bucket_id)]"/>
                                    <field name="type"/>
                                    <field name="unit"/>
                                    <field name="quantity"/>
                                    <field name="unit_price"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Notes">
                            <group>
                                <field name="notes" readonly="1"/>
                            </group>
                        </page>
                        <page string="Comments">
                            <group>
                                <field name="comments"/>
                            </group>
                        </page>
                        <page string="Reason">
                            <group>
                                <field name="rejection_reason"
                                       invisible="not is_supervisor"/>
                            </group>
                        </page>
                    </notebook>
                    <div class="total_amount_main">
                        <div class="total_amount_quotation">
                            <div class="total_padding total-amount-highlight">
                                <label for="total_excl_vat" style="padding: 0px 8px;"></label>
                                <field name="total_excl_vat" readonly="1" class="oe_inline"/>

                            </div>
                            <!-- <div class="total_padding total-amount-highlight">
                                <label for="vat_amount" style="padding: 0px 8px;"></label>
                                <field name="vat_amount" readonly="1" class="oe_inline"/>
                            </div>
                            <div class="total_padding total-amount-highlight">
                                <label for="total_incl_vat" style="padding: 0px 8px;"></label>
                                <field name="total_incl_vat" readonly="1" class="oe_inline"/>
                            </div> -->
                        </div>
                    </div>
                </sheet>
            </form>
        </field>
    </record>


    <record id="view_purchase_requisition_reject_wizard_form" model="ir.ui.view">
        <field name="name">purchase.requisition.reject.wizard.form</field>
        <field name="model">purchase.requisition.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Purchase Requisition">
                <group>
                    <field name="requisition_id" readonly="1"/>
                    <field name="rejection_reason" placeholder="Please provide rejection reason..."/>
                </group>
                <footer>
                    <button name="action_confirm_reject" type="object" string="Reject" class="btn-danger"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action for Purchase Requisition list -->
    <record id="action_purchase_requisition_list" model="ir.actions.act_window">
        <field name="name">Purchase Requisitions</field>
        <field name="res_model">purchase.requisition</field>
        <field name="view_mode">tree,form</field>
        <field name="type">ir.actions.act_window</field>
        <field name="domain">[('pr_type', '!=', 'cash')]</field>
    </record>
    <!-- Menu item under Purchase -->
    <!-- End User Requisitions (folder, no action) -->
    <menuitem id="menu_purchase_requisition_main"
              name="New Requisition"
              parent="purchase.menu_purchase_root"
              sequence="130"
              groups="pr_custom_purchase.group_custom_pr_end_user"/>
    <!-- Re-parent PR menu -->
    <menuitem id="pr_custom_purchase.menu_pr"
              name="Regular PR"
              parent="pr_custom_purchase.menu_purchase_requisition_main"
              action="pr_custom_purchase.action_custom_pr_standard"
              sequence="10"
              groups="pr_custom_purchase.group_custom_pr_end_user"/>

    <!-- Re-parent Cash PR menu -->
    <menuitem id="pr_custom_purchase.menu_cash_pr"
              name="Cash PR"
              parent="pr_custom_purchase.menu_purchase_requisition_main"
              action="pr_custom_purchase.action_custom_pr_cash"
              sequence="20"
              groups="pr_custom_purchase.group_custom_pr_end_user"/>

    <!-- Requisitions for other users (shows PR lists) -->
    <menuitem id="menu_purchase_requisition_main_others"
              name="Requisitions"
              parent="purchase.menu_purchase_root"
              sequence="131"
              groups="pr_custom_purchase.procurement_admin,purchase.group_purchase_manager,pr_custom_purchase.project_engineer,pr_custom_purchase.project_manager,pr_custom_purchase.operations_director,pr_custom_purchase.managing_director,pr_custom_purchase.inventory_qc,pr_custom_purchase.inventory_data_entry,pr_custom_purchase.inventory_admin,pr_custom_purchase.group_pr_approver"/>

    <menuitem id="pr_custom_purchase.menu_pr_others"
              name="Regular PR"
              parent="pr_custom_purchase.menu_purchase_requisition_main_others"
              action="pr_custom_purchase.action_purchase_requisition_list"
              sequence="10"
              groups="pr_custom_purchase.procurement_admin,purchase.group_purchase_manager,pr_custom_purchase.project_engineer,pr_custom_purchase.project_manager,pr_custom_purchase.operations_director,pr_custom_purchase.managing_director,pr_custom_purchase.inventory_qc,pr_custom_purchase.inventory_data_entry,pr_custom_purchase.inventory_admin,pr_custom_purchase.group_pr_approver"/>

    <menuitem id="pr_custom_purchase.menu_cash_pr_others"
              name="Cash PR"
              parent="pr_custom_purchase.menu_purchase_requisition_main_others"
              action="pr_custom_purchase.action_purchase_requisition_cash"
              sequence="20"
              groups="pr_custom_purchase.procurement_admin,purchase.group_purchase_manager,pr_custom_purchase.project_engineer,pr_custom_purchase.project_manager,pr_custom_purchase.operations_director,pr_custom_purchase.managing_director,pr_custom_purchase.inventory_qc,pr_custom_purchase.inventory_data_entry,pr_custom_purchase.inventory_admin,pr_custom_purchase.group_pr_approver"/>
</odoo>