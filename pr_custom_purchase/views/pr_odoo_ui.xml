<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- List view for Purchase Requisition -->
    <record id="view_purchase_requisition_list" model="ir.ui.view">
        <field name="name">purchase.requisition.list</field>
        <field name="model">purchase.requisition</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="requested_by"/>
                <field name="status" widget="badge"
                       decoration-success="status in ('po', 'completed')"
                       decoration-warning="status == 'rfq'"
                       decoration-info="status in ('pr', 'payment')"/>
                <field name="cash_pr_voucher_state" widget="badge"
                       optional="show"
                       decoration-success="cash_pr_voucher_state == 'posted'"
                       decoration-warning="cash_pr_voucher_state in ('submit', 'finance_approve')"
                       decoration-muted="cash_pr_voucher_state == 'not_created'"
                       decoration-danger="cash_pr_voucher_state == 'cancel'"/>
                <field name="payment_request_state" widget="badge"
                       optional="show"
                       decoration-info="payment_request_state == 'requested'"
                       decoration-success="payment_request_state == 'voucher_created'"
                       decoration-muted="payment_request_state == 'not_requested'"
                       decoration-danger="payment_request_state == 'cancelled'"/>
                <field name="approval" widget="badge"
                       decoration-success="approval == 'approved'"
                       decoration-danger="approval == 'rejected'"
                       decoration-info="approval == 'pending'"/>
                <field name="date_request"/>
            </tree>
        </field>
    </record>
    <!-- Form view for Purchase Requisition -->
    <record id="view_purchase_requisition_form" model="ir.ui.view">
        <field name="name">purchase.requisition.form</field>
        <field name="model">purchase.requisition</field>
        <field name="arch" type="xml">
            <form string="Purchase Requisition">
                <header>
                    <button name="action_supervisor_approve"
                            type="object"
                            string="Approve"
                            class="btn-primary"
                            invisible="not is_supervisor or approval != 'pending'"/>
                    <button name="action_supervisor_reject_wizard"
                            type="object"
                            string="Reject"
                            class="btn-secondary"
                            invisible="not is_supervisor or approval != 'pending'"/>
                    <button name="action_request_budget_increase"
                            type="object"
                            string="Request Budget Revision"
                            class="btn-secondary"
                            invisible="not show_request_budget_increase_button"/>
                    <button name="action_get_all_products"
                            type="object"
                            string="Get All Products"
                            class="btn-secondary"
                            invisible="not expense_bucket_id or approval != 'pending' or status != 'pr'"/>
                    <button name="action_create_rfq"
                            type="object"
                            string="Create RFQ"
                            class="btn-primary"
                            groups="pr_custom_purchase.procurement_admin"
                            invisible="not show_create_rfq_button"/>
                    <button name="action_request_cash_pr_payment"
                            type="object"
                            string="Request Payment"
                            class="btn-primary"
                            invisible="not show_request_payment_button"/>
                </header>
                <sheet>
                    <!-- Hidden fields for button visibility logic -->
                    <field name="pr_type" invisible="1"/>
                    <field name="show_create_rfq_button" invisible="1"/>
                    <field name="show_create_po_button" invisible="1"/>
                    <field name="show_create_payment_voucher_button" invisible="1"/>
                    <field name="show_request_payment_button" invisible="1"/>
                    <field name="is_supervisor" invisible="1"/>
                    <field name="wo_variance_requires_approval" invisible="1"/>
                    <field name="rfq_count" invisible="1"/>
                    <field name="rfq_sent_count" invisible="1"/>
                    <field name="show_request_budget_increase_button" invisible="1"/>
                    <field name="cash_payment_id" invisible="1"/>
                    <field name="bank_payment_id" invisible="1"/>
                    <field name="payment_request_id" invisible="1"/>
                    <field name="legacy_custom_pr_id" invisible="1"/>

                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_related_rfqs"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-envelope-open-o"
                                invisible="pr_type == 'cash'"
                                groups="pr_custom_purchase.procurement_admin,purchase.group_purchase_manager">
                            <field name="rfq_count" widget="statinfo" string="RFQs"/>
                        </button>
                        <button name="action_open_cash_pr_payment_voucher"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-money"
                                invisible="not cash_payment_id and not bank_payment_id"
                                groups="account.group_account_invoice,account.group_account_user,account.group_account_manager">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Payment</span>
                                <span class="o_stat_text">Voucher</span>
                            </div>
                        </button>
                        <button name="action_open_cash_pr_payment_request"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-file-text-o"
                                invisible="not payment_request_id">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Payment</span>
                                <span class="o_stat_text">Request</span>
                            </div>
                        </button>
                    </div>

                    <div class="alert alert-warning"
                         role="alert"
                         invisible="not wo_variance_requires_approval">
                        Quantity or unit cost exceeds Work Order baseline for one or more lines, but total line amount
                        is still within Work Order budget. Supervisor approval is required before RFQ/PO creation.
                    </div>

                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="date_request" readonly="1"/>
                            <field name="department" readonly="1"/>
                            <field name="supervisor" readonly="1"/>
                            <field name="vendor_id"
                                   invisible="pr_type == 'cash'"
                                   groups="pr_custom_purchase.procurement_admin"/>
                            <field name="expense_type"
                                   readonly="approval != 'pending' or status != 'pr'"/>
                            <field name="expense_bucket_id"
                                   domain="[('expense_type', '=', expense_type), ('state', 'in', ['validate', 'done']), ('date_from', '&lt;=', context_today()), ('date_to', '&gt;=', context_today())]"
                                   readonly="approval != 'pending' or status != 'pr'"
                                   options="{'no_create': True, 'no_create_edit': True, 'no_quick_create': True}"/>
                            <field name="expense_scope" readonly="1"/>
                            <field name="status" invisible="1"/>
                            <field name="rfq_sent_count" readonly="1"/>
                            <field name="requested_user_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="required_date" readonly="1"/>
                            <field name="priority"
                                   readonly="approval != 'pending' or status != 'pr'"/>
                            <field name="approval" readonly="1"/>
                            <field name="payment_request_state"
                                   readonly="1"
                                   invisible="pr_type != 'cash'"/>
                            <field name="cash_pr_voucher_state"
                                   readonly="1"
                                   invisible="pr_type != 'cash'"
                                   groups="account.group_account_invoice,account.group_account_user,account.group_account_manager"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Products">
                            <field name="allowed_cost_center_ids" invisible="1"/>
                            <field name="line_ids"
                                   readonly="approval != 'pending' or status != 'pr'">
                                <tree editable="bottom">
                                    <field name="description"/>
                                    <field name="cost_center_id" domain="[('id', 'in', parent.allowed_cost_center_ids)]"/>
                                    <field name="expense_account_id"
                                           optional="hide"
                                           column_invisible="1"
                                           readonly="1"
                                           options="{'no_create': True, 'no_create_edit': True, 'no_quick_create': True}"
                                           groups="account.group_account_invoice,account.group_account_user,account.group_account_manager"/>
                                    <field name="type" readonly="1"/>
                                    <field name="unit" readonly="1"/>
                                    <field name="quantity"/>
                                    <field name="unit_price"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Notes">
                            <group>
                                <field name="notes" readonly="approval != 'pending' or status != 'pr'"/>
                            </group>
                        </page>
                        <page string="Comments">
                            <group>
                                <field name="comments"/>
                            </group>
                        </page>
                        <page string="Reason">
                            <group>
                                <field name="rejection_reason"
                                       invisible="not is_supervisor"/>
                            </group>
                        </page>
                    </notebook>
                    <div class="total_amount_main">
                        <div class="total_amount_quotation">
                            <div class="total_padding total-amount-highlight">
                                <label for="total_excl_vat" style="padding: 0px 8px;"></label>
                                <field name="total_excl_vat" readonly="1" class="oe_inline"/>

                            </div>
                            <!-- <div class="total_padding total-amount-highlight">
                                <label for="vat_amount" style="padding: 0px 8px;"></label>
                                <field name="vat_amount" readonly="1" class="oe_inline"/>
                            </div>
                            <div class="total_padding total-amount-highlight">
                                <label for="total_incl_vat" style="padding: 0px 8px;"></label>
                                <field name="total_incl_vat" readonly="1" class="oe_inline"/>
                            </div> -->
                        </div>
                    </div>
                </sheet>
            </form>
        </field>
    </record>


    <record id="view_purchase_requisition_reject_wizard_form" model="ir.ui.view">
        <field name="name">purchase.requisition.reject.wizard.form</field>
        <field name="model">purchase.requisition.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Purchase Requisition">
                <group>
                    <field name="requisition_id" readonly="1"/>
                    <field name="rejection_reason" placeholder="Please provide rejection reason..."/>
                </group>
                <footer>
                    <button name="action_confirm_reject" type="object" string="Reject" class="btn-danger"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action for Purchase Requisition list -->
    <record id="action_purchase_requisition_list" model="ir.actions.act_window">
        <field name="name">Purchase Requisitions</field>
        <field name="res_model">purchase.requisition</field>
        <field name="view_mode">tree,form</field>
        <field name="type">ir.actions.act_window</field>
        <field name="domain">[('pr_type', '=', 'pr')]</field>
        <field name="context">{'default_pr_type': 'pr'}</field>
    </record>
    <!-- Menu item under Purchase -->
    <!-- End User Requisitions (folder, no action) -->
    <menuitem id="menu_purchase_requisition_main"
              name="New Requisition"
              parent="purchase.menu_purchase_root"
              sequence="130"
              groups="base.group_no_one"/>
    <!-- Re-parent PR menu -->
    <menuitem id="pr_custom_purchase.menu_pr"
              name="Regular PR"
              parent="pr_custom_purchase.menu_purchase_requisition_main"
              action="pr_custom_purchase.action_custom_pr_standard"
              sequence="10"
              groups="pr_custom_purchase.group_custom_pr_end_user"/>

    <!-- Re-parent Cash PR menu -->
    <menuitem id="pr_custom_purchase.menu_cash_pr"
              name="Cash PR"
              parent="pr_custom_purchase.menu_purchase_requisition_main"
              action="pr_custom_purchase.action_custom_pr_cash"
              sequence="20"
              groups="pr_custom_purchase.group_custom_pr_end_user"/>

    <!-- Requisitions for other users (shows PR lists) -->
    <menuitem id="menu_purchase_requisition_main_others"
              name="Requisitions"
              parent="purchase.menu_purchase_root"
              sequence="131"
              groups="pr_custom_purchase.group_custom_pr_end_user,pr_custom_purchase.procurement_admin,purchase.group_purchase_manager,pr_custom_purchase.project_engineer,pr_custom_purchase.project_manager,pr_custom_purchase.operations_director,pr_custom_purchase.managing_director,pr_custom_purchase.inventory_qc,pr_custom_purchase.inventory_data_entry,pr_custom_purchase.inventory_admin,pr_custom_purchase.group_pr_approver,account.group_account_invoice,account.group_account_user,account.group_account_manager"/>

    <menuitem id="pr_custom_purchase.menu_pr_others"
              name="Regular PR"
              parent="pr_custom_purchase.menu_purchase_requisition_main_others"
              action="pr_custom_purchase.action_purchase_requisition_list"
              sequence="10"
              groups="pr_custom_purchase.group_custom_pr_end_user,pr_custom_purchase.procurement_admin,purchase.group_purchase_manager,pr_custom_purchase.project_engineer,pr_custom_purchase.project_manager,pr_custom_purchase.operations_director,pr_custom_purchase.managing_director,pr_custom_purchase.inventory_qc,pr_custom_purchase.inventory_data_entry,pr_custom_purchase.inventory_admin,pr_custom_purchase.group_pr_approver"/>

    <menuitem id="pr_custom_purchase.menu_cash_pr_others"
              name="Cash PR"
              parent="pr_custom_purchase.menu_purchase_requisition_main_others"
              action="pr_custom_purchase.action_purchase_requisition_cash"
              sequence="20"
              groups="pr_custom_purchase.group_custom_pr_end_user,pr_custom_purchase.procurement_admin,purchase.group_purchase_manager,pr_custom_purchase.project_engineer,pr_custom_purchase.project_manager,pr_custom_purchase.operations_director,pr_custom_purchase.managing_director,pr_custom_purchase.inventory_qc,pr_custom_purchase.inventory_data_entry,pr_custom_purchase.inventory_admin,pr_custom_purchase.group_pr_approver,account.group_account_invoice,account.group_account_user,account.group_account_manager"/>

    <menuitem id="menu_legacy_custom_prs"
              name="Legacy Custom PRs"
              parent="pr_custom_purchase.menu_purchase_requisition_main_others"
              action="pr_custom_purchase.action_custom_pr_all"
              sequence="90"
              groups="pr_custom_purchase.procurement_admin,purchase.group_purchase_manager"/>

    <!-- Keep the legacy end-user custom.pr entry fully hidden. group_no_one
         is still visible for technical users, so active=False is the hard gate. -->
    <record id="menu_purchase_requisition_main" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('base.group_no_one')])]"/>
        <field name="active" eval="False"/>
    </record>
    <record id="menu_pr" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>
    <record id="menu_cash_pr" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <record id="view_cash_payment_form_cash_pr_source" model="ir.ui.view">
        <field name="name">pr.account.cash.payment.form.cash.pr.source</field>
        <field name="model">pr.account.cash.payment</field>
        <field name="inherit_id" ref="pr_account.pr_account_cash_payment_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='description']" position="after">
                <field name="purchase_requisition_id" readonly="1"
                       invisible="not purchase_requisition_id"/>
            </xpath>
        </field>
    </record>

    <record id="view_bank_payment_form_cash_pr_source" model="ir.ui.view">
        <field name="name">pr.account.bank.payment.form.cash.pr.source</field>
        <field name="model">pr.account.bank.payment</field>
        <field name="inherit_id" ref="pr_account.pr_account_bank_payment_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='description']" position="after">
                <field name="purchase_requisition_id" readonly="1"
                       invisible="not purchase_requisition_id"/>
            </xpath>
        </field>
    </record>
</odoo>
