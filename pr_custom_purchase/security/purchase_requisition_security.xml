<odoo>
    <record id="purchase_requisition_requester_rule" model="ir.rule">
        <field name="name">PRs visible to requester</field>
        <field name="model_id" ref="model_purchase_requisition"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">[('requested_user_id', '=', user.id)]</field>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>

    <record id="purchase_requisition_supervisor_rule" model="ir.rule">
        <field name="name">PRs visible to assigned Supervisor</field>
        <field name="model_id" ref="model_purchase_requisition"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">[('supervisor_partner_id', '=', str(user.partner_id.id))]</field>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>
    <record id="purchase_requisition_procurement_admin_rule" model="ir.rule">
        <field name="name">Approved PRs for Procurement Admin</field>
        <field name="model_id" ref="model_purchase_requisition"/>
        <field name="domain_force">[]</field>
        <field name="groups" eval="[
        (4, ref('pr_custom_purchase.procurement_admin')),
        (4, ref('pr_custom_purchase.project_engineer')),
        (4, ref('pr_custom_purchase.project_manager')),
        (4, ref('pr_custom_purchase.operations_director')),
        (4, ref('pr_custom_purchase.managing_director')),
        (4, ref('account.group_account_invoice')),
        (4, ref('account.group_account_user')),
        (4, ref('account.group_account_manager'))
    ]"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>

    <record id="purchase_requisition_payment_request_own_rule" model="ir.rule">
        <field name="name">PR Payment Request: own requests</field>
        <field name="model_id" ref="model_purchase_requisition_payment_request"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">['|', ('requested_user_id', '=', user.id), ('purchase_requisition_id.requested_user_id', '=', user.id)]</field>
    </record>

    <record id="purchase_requisition_payment_request_account_rule" model="ir.rule">
        <field name="name">PR Payment Request: accounts see all</field>
        <field name="model_id" ref="model_purchase_requisition_payment_request"/>
        <field name="groups" eval="[
            (4, ref('account.group_account_invoice')),
            (4, ref('account.group_account_user')),
            (4, ref('account.group_account_manager'))
        ]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="purchase_requisition_payment_request_line_own_rule" model="ir.rule">
        <field name="name">PR Payment Request Line: own requests</field>
        <field name="model_id" ref="model_purchase_requisition_payment_request_line"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">[
            '|',
            ('payment_request_id.requested_user_id', '=', user.id),
            ('payment_request_id.purchase_requisition_id.requested_user_id', '=', user.id)
        ]</field>
    </record>

    <record id="purchase_requisition_payment_request_line_account_rule" model="ir.rule">
        <field name="name">PR Payment Request Line: accounts see all</field>
        <field name="model_id" ref="model_purchase_requisition_payment_request_line"/>
        <field name="groups" eval="[
            (4, ref('account.group_account_invoice')),
            (4, ref('account.group_account_user')),
            (4, ref('account.group_account_manager'))
        ]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>
</odoo>
