<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pr_employee_service_request_tree" model="ir.ui.view">
        <field name="name">pr.employee.service.request.tree</field>
        <field name="model">pr.employee.service.request</field>
        <field name="arch" type="xml">
            <tree string="Employee Requests">
                <field name="name"/>
                <field name="request_date"/>
                <field name="request_type"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="requested_amount" optional="show"/>
                <field name="approved_amount" optional="show"/>
                <field name="travel_date" optional="hide"/>
                <field name="return_date" optional="hide"/>
                <field name="payment_voucher_state" optional="show"/>
                <field name="state" widget="badge"
                       decoration-warning="state in ('draft', 'hr_supervisor_approval', 'employee_manager_approval', 'hr_manager_approval', 'md_approval')"
                       decoration-info="state == 'payment_approval'"
                       decoration-success="state in ('issued', 'paid')"
                       decoration-danger="state in ('rejected', 'cancelled')"/>
            </tree>
        </field>
    </record>

    <record id="view_pr_employee_service_request_search" model="ir.ui.view">
        <field name="name">pr.employee.service.request.search</field>
        <field name="model">pr.employee.service.request</field>
        <field name="arch" type="xml">
            <search string="Employee Requests">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="request_type"/>
                <filter name="my_requests" string="My Requests" domain="['|', ('requested_by_id', '=', uid), ('employee_id.user_id', '=', uid)]"/>
                <filter name="reimbursement" string="Reimbursements" domain="[('request_type', '=', 'reimbursement')]"/>
                <filter name="exit_reentry" string="Exit/Re-entry" domain="[('request_type', '=', 'exit_reentry')]"/>
                <separator/>
                <filter name="hr_supervisor_approval" string="HR Supervisor" domain="[('state', '=', 'hr_supervisor_approval')]"/>
                <filter name="employee_manager_approval" string="Employee Manager" domain="[('state', '=', 'employee_manager_approval')]"/>
                <filter name="hr_manager_approval" string="HR Manager" domain="[('state', '=', 'hr_manager_approval')]"/>
                <filter name="md_approval" string="MD Approval" domain="[('state', '=', 'md_approval')]"/>
                <filter name="payment_approval" string="Voucher Approval" domain="[('state', '=', 'payment_approval')]"/>
                <filter name="issued" string="Issued" domain="[('state', '=', 'issued')]"/>
                <filter name="paid" string="Paid" domain="[('state', '=', 'paid')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_type" string="Request Type" context="{'group_by': 'request_type'}"/>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_employee" string="Employee" context="{'group_by': 'employee_id'}"/>
                    <filter name="group_department" string="Department" context="{'group_by': 'department_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_pr_employee_service_request_form" model="ir.ui.view">
        <field name="name">pr.employee.service.request.form</field>
        <field name="model">pr.employee.service.request</field>
        <field name="arch" type="xml">
            <form string="Employee Request">
                <header>
                    <field name="can_hr_supervisor_approve" invisible="1"/>
                    <field name="can_employee_manager_approve" invisible="1"/>
                    <field name="can_hr_manager_approve" invisible="1"/>
                    <field name="can_md_approve" invisible="1"/>
                    <field name="can_issue" invisible="1"/>
                    <field name="can_reject" invisible="1"/>
                    <field name="can_reset_to_draft" invisible="1"/>
                    <field name="can_cancel" invisible="1"/>
                    <button name="action_submit" type="object" string="Submit"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_hr_supervisor_approve" type="object" string="HR Supervisor Approve"
                            class="btn-primary" invisible="not can_hr_supervisor_approve"/>
                    <button name="action_employee_manager_approve" type="object" string="Manager Approve"
                            class="btn-primary" invisible="not can_employee_manager_approve"/>
                    <button name="action_hr_manager_approve" type="object" string="HR Manager Approve"
                            class="btn-primary" invisible="not can_hr_manager_approve"/>
                    <button name="action_md_approve" type="object" string="MD Approve"
                            class="btn-primary" invisible="not can_md_approve"/>
                    <button name="action_issue" type="object" string="Issue"
                            class="btn-primary" invisible="not can_issue"/>
                    <button name="action_reject" type="object" string="Reject"
                            class="btn-secondary" invisible="not can_reject"/>
                    <button name="action_reset_to_draft" type="object" string="Reset to Draft"
                            class="btn-secondary" invisible="not can_reset_to_draft"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            class="btn-secondary" invisible="not can_cancel"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,hr_supervisor_approval,employee_manager_approval,hr_manager_approval,md_approval,payment_approval,paid,issued"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Rejected" bg_color="bg-danger" invisible="state != 'rejected'"/>
                    <widget name="web_ribbon" title="Cancelled" bg_color="bg-secondary" invisible="state != 'cancelled'"/>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="request_type" readonly="state != 'draft'"/>
                            <field name="request_date" readonly="state != 'draft'"/>
                            <field name="requested_by_id" readonly="1"/>
                            <field name="employee_id" readonly="state != 'draft'" options="{'no_create': True, 'no_open': True}"/>
                            <field name="department_id" readonly="1"/>
                            <field name="employee_manager_user_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="company_id" invisible="1"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="rejection_reason" readonly="1" invisible="not rejection_reason"/>
                        </group>
                    </group>

                    <group string="Reimbursement Details" invisible="request_type != 'reimbursement'">
                        <group>
                            <field name="reimbursement_type" readonly="state != 'draft'"/>
                            <field name="expense_date" readonly="state != 'draft'"/>
                            <field name="requested_amount" readonly="state != 'draft'"/>
                        </group>
                    </group>

                    <group string="Exit/Re-entry Details" invisible="request_type != 'exit_reentry'">
                        <group>
                            <field name="destination_country_id" readonly="state != 'draft'" options="{'no_create': True}"/>
                            <field name="travel_date" readonly="state != 'draft'"/>
                            <field name="return_date" readonly="state != 'draft'"/>
                            <field name="duration_days" readonly="1"/>
                            <field name="passport_no" readonly="state != 'draft'"/>
                            <field name="iqama_no" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="visa_number" readonly="state not in ('paid', 'issued')"/>
                            <field name="issue_date" readonly="state not in ('paid', 'issued')"/>
                            <field name="visa_expiry_date" readonly="state not in ('paid', 'issued')"/>
                            <field name="visa_fee" readonly="state in ('draft', 'payment_approval', 'paid', 'issued', 'rejected', 'cancelled')"/>
                        </group>
                    </group>

                    <group string="Payment">
                        <group>
                            <field name="approved_amount" readonly="state in ('payment_approval', 'paid', 'issued', 'rejected', 'cancelled')"/>
                            <field name="payment_method" readonly="state != 'draft'"/>
                            <field name="payment_account_id"
                                   readonly="state in ('payment_approval', 'paid', 'issued', 'rejected', 'cancelled')"
                                   options="{'no_create': True, 'no_create_edit': True}"/>
                            <field name="expense_account_id"
                                   readonly="state in ('payment_approval', 'paid', 'issued', 'rejected', 'cancelled')"
                                   options="{'no_create': True, 'no_create_edit': True}"/>
                        </group>
                        <group>
                            <field name="payment_reference" readonly="1"/>
                            <field name="paid_date" readonly="1"/>
                            <field name="payment_voucher_state" readonly="1" invisible="not payment_voucher_state"/>
                            <field name="cash_payment_id" readonly="1" invisible="not cash_payment_id"/>
                            <field name="bank_payment_id" readonly="1" invisible="not bank_payment_id"/>
                            <button name="action_open_payment_voucher" type="object" string="Open Voucher"
                                    class="btn-secondary" invisible="not cash_payment_id and not bank_payment_id"/>
                        </group>
                    </group>

                    <group>
                        <field name="reason" placeholder="Enter request reason / notes..." readonly="state != 'draft'"/>
                    </group>
                    <notebook>
                        <page string="Attachments" invisible="request_type != 'reimbursement'">
                            <field name="attachment_ids" widget="many2many_binary" readonly="state != 'draft'"/>
                        </page>
                        <page string="Approvals">
                            <group>
                                <group>
                                    <field name="hr_supervisor_approved_by_id" readonly="1"/>
                                    <field name="employee_manager_approved_by_id" readonly="1"/>
                                    <field name="hr_manager_approved_by_id" readonly="1"/>
                                    <field name="md_approved_by_id" readonly="1"/>
                                </group>
                                <group>
                                    <field name="hr_supervisor_approved_date" readonly="1"/>
                                    <field name="employee_manager_approved_date" readonly="1"/>
                                    <field name="hr_manager_approved_date" readonly="1"/>
                                    <field name="md_approved_date" readonly="1"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_pr_employee_service_request_reject_wizard_form" model="ir.ui.view">
        <field name="name">pr.employee.service.request.reject.wizard.form</field>
        <field name="model">pr.employee.service.request.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Employee Request">
                <group>
                    <field name="request_id" readonly="1"/>
                    <field name="rejection_reason" placeholder="Please provide rejection reason..."/>
                </group>
                <footer>
                    <button name="action_confirm_reject" type="object" string="Reject" class="btn-danger"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_pr_employee_reimbursement_my" model="ir.actions.act_window">
        <field name="name">Reimbursements</field>
        <field name="res_model">pr.employee.service.request</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_pr_employee_service_request_search"/>
        <field name="domain">[('request_type', '=', 'reimbursement')]</field>
        <field name="context">{'default_request_type': 'reimbursement', 'search_default_my_requests': 1}</field>
    </record>

    <record id="action_pr_employee_exit_reentry_my" model="ir.actions.act_window">
        <field name="name">Exit/Re-entry Requests</field>
        <field name="res_model">pr.employee.service.request</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_pr_employee_service_request_search"/>
        <field name="domain">[('request_type', '=', 'exit_reentry')]</field>
        <field name="context">{'default_request_type': 'exit_reentry', 'search_default_my_requests': 1}</field>
    </record>

    <record id="action_pr_employee_reimbursement_hr_approvals" model="ir.actions.act_window">
        <field name="name">Reimbursement Requests</field>
        <field name="res_model">pr.employee.service.request</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_pr_employee_service_request_search"/>
        <field name="domain">[('request_type', '=', 'reimbursement'), ('state', 'in', ['hr_supervisor_approval', 'hr_manager_approval'])]</field>
        <field name="context">{'default_request_type': 'reimbursement'}</field>
    </record>

    <record id="action_pr_employee_exit_reentry_hr_approvals" model="ir.actions.act_window">
        <field name="name">Exit/Re-entry Requests</field>
        <field name="res_model">pr.employee.service.request</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_pr_employee_service_request_search"/>
        <field name="domain">[('request_type', '=', 'exit_reentry'), ('state', 'in', ['hr_supervisor_approval', 'hr_manager_approval', 'paid'])]</field>
        <field name="context">{'default_request_type': 'exit_reentry'}</field>
    </record>

    <record id="action_pr_employee_manager_approvals" model="ir.actions.act_window">
        <field name="name">Employee Manager Approvals</field>
        <field name="res_model">pr.employee.service.request</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_pr_employee_service_request_search"/>
        <field name="domain">[('employee_manager_user_id', '=', uid), ('state', '=', 'employee_manager_approval')]</field>
        <field name="context">{'search_default_employee_manager_approval': 1}</field>
    </record>

    <record id="action_pr_employee_md_approvals" model="ir.actions.act_window">
        <field name="name">Employee Request MD Approvals</field>
        <field name="res_model">pr.employee.service.request</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_pr_employee_service_request_search"/>
        <field name="domain">[('state', '=', 'md_approval')]</field>
        <field name="context">{'search_default_md_approval': 1}</field>
    </record>

    <record id="action_pr_employee_payment_tracking" model="ir.actions.act_window">
        <field name="name">Employee Payment Requests</field>
        <field name="res_model">pr.employee.service.request</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_pr_employee_service_request_search"/>
        <field name="domain">[('state', 'in', ['payment_approval', 'paid', 'issued'])]</field>
        <field name="context">{'search_default_payment_approval': 1}</field>
    </record>

    <record id="de_hr_workspace.menu_my_workspace" model="ir.ui.menu">
        <field name="groups_id" eval="[(4, ref('de_hr_workspace.group_hr_employee_workspace'))]"/>
    </record>

    <record id="de_hr_workspace.menu_my_employee_approvals" model="ir.ui.menu">
        <field name="groups_id" eval="[
            (4, ref('hr.group_hr_manager')),
            (4, ref('de_hr_workspace.group_hr_employee_approvals')),
            (4, ref('pr_hr_recruitment_request.group_onboarding_supervisor')),
            (4, ref('pr_hr_recruitment_request.group_onboarding_manager')),
            (4, ref('pr_hr_recruitment_request.group_onboarding_md')),
            (4, ref('account.group_account_manager')),
            (4, ref('pr_account.custom_group_accounting_manager'))
        ]"/>
    </record>

    <record id="de_hr_workspace.hr_approvals_menu_root" model="ir.ui.menu">
        <field name="groups_id" eval="[
            (4, ref('hr.group_hr_manager')),
            (4, ref('de_hr_workspace.group_hr_employee_approvals')),
            (4, ref('pr_hr_recruitment_request.group_onboarding_supervisor')),
            (4, ref('pr_hr_recruitment_request.group_onboarding_manager')),
            (4, ref('pr_hr_recruitment_request.group_onboarding_md'))
        ]"/>
    </record>

    <menuitem id="menu_pr_employee_reimbursement_my"
              name="Reimbursements"
              parent="de_hr_workspace.menu_my_ws_employee"
              action="action_pr_employee_reimbursement_my"
              sequence="30"
              groups="de_hr_workspace.group_hr_employee_workspace"/>

    <menuitem id="menu_pr_employee_exit_reentry_my"
              name="Exit/Re-entry Requests"
              parent="de_hr_workspace.menu_my_ws_employee"
              action="action_pr_employee_exit_reentry_my"
              sequence="31"
              groups="de_hr_workspace.group_hr_employee_workspace"/>

    <menuitem id="menu_pr_employee_reimbursement_hr_approvals"
              name="Reimbursement Requests"
              parent="de_hr_workspace.hr_approvals_menu_root"
              action="action_pr_employee_reimbursement_hr_approvals"
              sequence="20"
              groups="hr.group_hr_manager,de_hr_workspace.group_hr_employee_approvals,pr_hr_recruitment_request.group_onboarding_supervisor,pr_hr_recruitment_request.group_onboarding_manager"/>

    <menuitem id="menu_pr_employee_exit_reentry_hr_approvals"
              name="Exit/Re-entry Requests"
              parent="de_hr_workspace.hr_approvals_menu_root"
              action="action_pr_employee_exit_reentry_hr_approvals"
              sequence="21"
              groups="hr.group_hr_manager,de_hr_workspace.group_hr_employee_approvals,pr_hr_recruitment_request.group_onboarding_supervisor,pr_hr_recruitment_request.group_onboarding_manager"/>

    <menuitem id="menu_pr_employee_manager_approvals"
              name="Employee Manager Approvals"
              parent="de_hr_workspace.menu_my_employee_approvals"
              action="action_pr_employee_manager_approvals"
              sequence="44"
              groups="base.group_user"/>

    <menuitem id="menu_pr_employee_md_approvals"
              name="Employee Request MD Approvals"
              parent="de_hr_workspace.menu_my_employee_approvals"
              action="action_pr_employee_md_approvals"
              sequence="45"
              groups="pr_custom_purchase.managing_director,pr_hr_recruitment_request.group_onboarding_md"/>

    <menuitem id="menu_pr_employee_accounting_approvals"
              name="Employee Accounting"
              parent="de_hr_workspace.menu_my_employee_approvals"
              sequence="46"
              groups="account.group_account_manager,pr_account.custom_group_accounting_manager"/>

    <menuitem id="menu_pr_employee_payment_tracking"
              name="Employee Payment Requests"
              parent="menu_pr_employee_accounting_approvals"
              action="action_pr_employee_payment_tracking"
              sequence="10"
              groups="account.group_account_manager,pr_account.custom_group_accounting_manager"/>

    <record id="view_cash_payment_form_employee_service_request" model="ir.ui.view">
        <field name="name">pr.account.cash.payment.form.employee.service.request</field>
        <field name="model">pr.account.cash.payment</field>
        <field name="inherit_id" ref="pr_account.pr_account_cash_payment_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='description']" position="after">
                <field name="employee_service_request_id" readonly="1"/>
            </xpath>
        </field>
    </record>

    <record id="view_bank_payment_form_employee_service_request" model="ir.ui.view">
        <field name="name">pr.account.bank.payment.form.employee.service.request</field>
        <field name="model">pr.account.bank.payment</field>
        <field name="inherit_id" ref="pr_account.pr_account_bank_payment_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='description']" position="after">
                <field name="employee_service_request_id" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>
