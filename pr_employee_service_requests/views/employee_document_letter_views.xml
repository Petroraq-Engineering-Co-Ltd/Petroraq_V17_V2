<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pr_employee_document_letter_tree" model="ir.ui.view">
        <field name="name">pr.employee.document.letter.tree</field>
        <field name="model">pr.employee.document.letter</field>
        <field name="arch" type="xml">
            <tree string="Employee Letters">
                <field name="name"/>
                <field name="letter_type"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="job_id"/>
                <field name="request_date"/>
                <field name="issue_date"/>
                <field name="requested_by_id"/>
                <field name="sent_email_to" optional="hide"/>
                <field name="state" widget="badge"
                       decoration-warning="state in ('draft', 'hr_manager_approval')"
                       decoration-success="state in ('approved', 'sent')"
                       decoration-danger="state == 'rejected'"
                       decoration-muted="state == 'cancelled'"/>
            </tree>
        </field>
    </record>

    <record id="view_pr_employee_document_letter_search" model="ir.ui.view">
        <field name="name">pr.employee.document.letter.search</field>
        <field name="model">pr.employee.document.letter</field>
        <field name="arch" type="xml">
            <search string="Employee Letters">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="job_id"/>
                <field name="requested_by_id"/>
                <field name="letter_type"/>
                <filter name="my_letters" string="My Letters" domain="['|', ('requested_by_id', '=', uid), ('employee_id.user_id', '=', uid)]"/>
                <separator/>
                <filter name="experience" string="Experience" domain="[('letter_type', '=', 'experience')]"/>
                <filter name="warning" string="Warning" domain="[('letter_type', '=', 'warning')]"/>
                <filter name="appraisal" string="Appraisal" domain="[('letter_type', '=', 'appraisal')]"/>
                <filter name="salary_certificate" string="Salary Certificate" domain="[('letter_type', '=', 'salary_certificate')]"/>
                <filter name="employment_certificate" string="Employment Certificate" domain="[('letter_type', '=', 'employment_certificate')]"/>
                <separator/>
                <filter name="pending_hr_manager" string="Pending HR Manager" domain="[('state', '=', 'hr_manager_approval')]"/>
                <filter name="approved" string="Approved" domain="[('state', '=', 'approved')]"/>
                <filter name="sent" string="Sent" domain="[('state', '=', 'sent')]"/>
                <filter name="rejected" string="Rejected" domain="[('state', '=', 'rejected')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_type" string="Letter Type" context="{'group_by': 'letter_type'}"/>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_employee" string="Employee" context="{'group_by': 'employee_id'}"/>
                    <filter name="group_department" string="Department" context="{'group_by': 'department_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_pr_employee_document_letter_form" model="ir.ui.view">
        <field name="name">pr.employee.document.letter.form</field>
        <field name="model">pr.employee.document.letter</field>
        <field name="arch" type="xml">
            <form string="Employee Letter">
                <header>
                    <field name="can_submit" invisible="1"/>
                    <field name="can_hr_manager_approve" invisible="1"/>
                    <field name="can_send" invisible="1"/>
                    <field name="can_reject" invisible="1"/>
                    <field name="can_reset_to_draft" invisible="1"/>
                    <field name="can_cancel" invisible="1"/>
                    <button name="action_submit" type="object" string="Submit"
                            class="btn-primary" invisible="not can_submit"/>
                    <button name="action_hr_manager_approve" type="object" string="HR Manager Approve"
                            class="btn-primary" invisible="not can_hr_manager_approve"/>
                    <button name="action_open_send_wizard" type="object" string="Send Letter"
                            class="btn-primary" invisible="not can_send"/>
                    <button name="action_reject" type="object" string="Reject"
                            class="btn-secondary" invisible="not can_reject"/>
                    <button name="action_reset_to_draft" type="object" string="Reset to Draft"
                            class="btn-secondary" invisible="not can_reset_to_draft"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            class="btn-secondary" invisible="not can_cancel"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,hr_manager_approval,approved,sent"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Rejected" bg_color="bg-danger" invisible="state != 'rejected'"/>
                    <widget name="web_ribbon" title="Cancelled" bg_color="bg-secondary" invisible="state != 'cancelled'"/>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_attachments"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-paperclip"
                                invisible="attachment_count == 0">
                            <field name="attachment_count" widget="statinfo" string="Attachments"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="letter_type" readonly="state != 'draft'"/>
                            <field name="employee_id" readonly="state != 'draft'" options="{'no_create': True, 'no_open': True}"/>
                            <field name="employee_email" readonly="1"/>
                            <field name="department_id" readonly="1"/>
                            <field name="job_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="company_id" readonly="state != 'draft'"/>
                            <field name="request_date" readonly="state != 'draft'"/>
                            <field name="issue_date" readonly="state not in ('draft', 'hr_manager_approval')"/>
                            <field name="requested_by_id" readonly="1"/>
                            <field name="hr_manager_approved_by_id" readonly="1" invisible="not hr_manager_approved_by_id"/>
                            <field name="hr_manager_approved_date" readonly="1" invisible="not hr_manager_approved_date"/>
                            <field name="sent_by_id" readonly="1" invisible="not sent_by_id"/>
                            <field name="sent_date" readonly="1" invisible="not sent_date"/>
                            <field name="sent_email_to" readonly="1" invisible="not sent_email_to"/>
                        </group>
                    </group>
                    <group>
                        <field name="subject" readonly="state not in ('draft', 'hr_manager_approval')"/>
                    </group>
                    <group string="Letter Content" col="1">
                        <field name="body_html" nolabel="1" widget="html"
                               readonly="state not in ('draft', 'hr_manager_approval')"/>
                    </group>
                    <group>
                        <field name="reason" readonly="state != 'draft'"/>
                        <field name="rejection_reason" invisible="state != 'rejected'"/>
                    </group>
                    <notebook>
                        <page string="Attachments" name="attachments">
                            <field name="attachment_ids" widget="many2many_binary"
                                   readonly="state in ('sent', 'rejected', 'cancelled')"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_pr_employee_letter_send_wizard_form" model="ir.ui.view">
        <field name="name">pr.employee.letter.send.wizard.form</field>
        <field name="model">pr.employee.letter.send.wizard</field>
        <field name="arch" type="xml">
            <form string="Send Employee Letter">
                <sheet>
                    <field name="letter_id" invisible="1"/>
                    <group>
                        <group>
                            <field name="template_id" options="{'no_create': True, 'no_create_edit': True}"/>
                            <field name="recipient_mode" widget="radio"/>
                            <field name="employee_email" readonly="1" invisible="recipient_mode != 'employee'"/>
                            <field name="email_to" readonly="recipient_mode == 'employee'"/>
                            <field name="email_cc"/>
                        </group>
                        <group>
                            <field name="subject"/>
                            <field name="include_letter_attachments"/>
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </group>
                    </group>
                    <group string="Email Body" col="1">
                        <field name="body_html" widget="html" nolabel="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_send" type="object" string="Send" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_pr_employee_document_letter_my" model="ir.actions.act_window">
        <field name="name">Employee Letters</field>
        <field name="res_model">pr.employee.document.letter</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_pr_employee_document_letter_search"/>
        <field name="domain">['|', ('requested_by_id', '=', uid), ('employee_id.user_id', '=', uid)]</field>
        <field name="context">{'search_default_my_letters': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_empty_folder">No employee letters yet.</p>
            <p>Create experience, warning, appraisal, and other employee letters from here.</p>
        </field>
    </record>

    <record id="action_pr_employee_document_letter_hr_approvals" model="ir.actions.act_window">
        <field name="name">Employee Letter Approvals</field>
        <field name="res_model">pr.employee.document.letter</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_pr_employee_document_letter_search"/>
        <field name="domain">[('state', '=', 'hr_manager_approval')]</field>
        <field name="context">{'create': False, 'search_default_pending_hr_manager': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_empty_folder">No employee letters are pending HR Manager approval.</p>
        </field>
    </record>

    <record id="menu_pr_employee_reimbursement_my" model="ir.ui.menu">
        <field name="parent_id" ref="menu_pr_employee_compliance_requests"/>
        <field name="sequence">1</field>
    </record>

    <record id="menu_pr_employee_exit_reentry_my" model="ir.ui.menu">
        <field name="parent_id" ref="menu_pr_employee_compliance_requests"/>
        <field name="sequence">2</field>
    </record>

    <record id="menu_pr_employee_iqama_new_my" model="ir.ui.menu">
        <field name="sequence">3</field>
    </record>

    <record id="menu_pr_employee_iqama_renewal_my" model="ir.ui.menu">
        <field name="sequence">4</field>
    </record>

    <record id="menu_pr_employee_medical_insurance_new_my" model="ir.ui.menu">
        <field name="sequence">5</field>
    </record>

    <record id="menu_pr_employee_medical_insurance_my" model="ir.ui.menu">
        <field name="sequence">6</field>
    </record>

    <menuitem id="menu_pr_employee_document_letter_my"
              name="Employee Letters"
              parent="menu_pr_employee_compliance_requests"
              action="action_pr_employee_document_letter_my"
              sequence="7"
              groups="base.group_user,de_hr_workspace.group_hr_employee_workspace"/>

    <menuitem id="menu_pr_employee_document_letter_hr_approvals"
              name="Employee Letter Approvals"
              parent="de_hr_workspace.hr_approvals_menu_root"
              action="action_pr_employee_document_letter_hr_approvals"
              sequence="28"
              groups="hr.group_hr_manager"/>
</odoo>
