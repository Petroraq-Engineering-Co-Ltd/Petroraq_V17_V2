#. module: pr_employee_service_requests
#. odoo-python
#: code:addons/pr_employee_service_requests/models/employee_document_letter.py:0
#, python-format
msgid ""
"<p>Dear <strong>%(employee)s</strong>,</p><p>Please find the requested "
"employee letter attached.</p><p>Regards,<br/>Human Resources</p>"
msgstr "<p>عزيزي/عزيزتي <strong>%(employee)s</strong>،</p><p>يرجى العثور على خطاب الموظف المطلوب مرفقًا.</p><p>مع التحية،<br/>إدارة الموارد البشرية</p>"

#. module: pr_employee_service_requests
#. odoo-python
#: code:addons/pr_employee_service_requests/models/employee_document_letter.py:0
#, python-format
msgid ""
"<p>Dear <strong>%(employee)s</strong>,</p><p>Please find your appraisal "
"letter attached. We appreciate your contribution and continued "
"commitment.</p><p>Regards,<br/>Human Resources</p>"
msgstr "<p>عزيزي/عزيزتي <strong>%(employee)s</strong>،</p><p>يرجى العثور على خطاب التقييم الخاص بك مرفقًا. نقدر مساهمتك والتزامك المستمر.</p><p>مع التحية،<br/>إدارة الموارد البشرية</p>"

#. module: pr_employee_service_requests
#. odoo-python
#: code:addons/pr_employee_service_requests/models/employee_document_letter.py:0
#, python-format
msgid ""
"<p>Dear <strong>%(employee)s</strong>,</p><p>Please find your employment "
"certificate attached for your official use.</p><p>Regards,<br/>Human "
"Resources</p>"
msgstr "<p>عزيزي/عزيزتي <strong>%(employee)s</strong>،</p><p>يرجى العثور على شهادة التعريف بالراتب مرفقة لاستخدامك الرسمي.</p><p>مع التحية،<br/>إدارة الموارد البشرية</p>"

#. module: pr_employee_service_requests
#. odoo-python
#: code:addons/pr_employee_service_requests/models/employee_document_letter.py:0
#, python-format
msgid ""
"<p>Dear <strong>%(employee)s</strong>,</p><p>Please find your salary "
"certificate attached for your official use.</p><p>Regards,<br/>Human "
"Resources</p>"
msgstr "<p>عزيزي/عزيزتي <strong>%(employee)s</strong>،</p><p>يرجى العثور على شهادة الراتب مرفقة لاستخدامك الرسمي.</p><p>مع التحية،<br/>إدارة الموارد البشرية</p>"

#. module: pr_employee_service_requests
#. odoo-python
#: code:addons/pr_employee_service_requests/models/employee_document_letter.py:0
#, python-format
msgid ""
"<p>Dear <strong>%(employee)s</strong>,</p><p>This letter is issued as a "
"formal warning. Please review the attached document and comply with the "
"required corrective actions.</p><p>Regards,<br/>Human Resources</p>"
msgstr "<p>عزيزي/عزيزتي <strong>%(employee)s</strong>،</p><p>تم إصدار هذا الخطاب كإنذار رسمي. يرجى مراجعة المستند المرفق والالتزام بالإجراءات التصحيحية المطلوبة.</p><p>مع التحية،<br/>إدارة الموارد البشرية</p>"

#. module: pr_employee_service_requests
#. odoo-python
#: code:addons/pr_employee_service_requests/models/employee_document_letter.py:0
#, python-format
msgid ""
"<p>To whom it may concern,</p><p>This is to certify that "
"<strong>%(employee)s</strong> has been employed with "
"<strong>%(company)s</strong>. This letter is issued upon request for "
"official use.</p><p>Regards,<br/>Human Resources</p>"
msgstr "<p>إلى من يهمه الأمر،</p><p>تشهد <strong>%(company)s</strong> بأن <strong>%(employee)s</strong> يعمل لديها. وقد صدر هذا الخطاب بناءً على طلبه للاستخدام الرسمي.</p><p>مع التحية،<br/>إدارة الموارد البشرية</p>"

