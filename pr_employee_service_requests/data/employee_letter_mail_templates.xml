<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="mail_template_employee_letter_experience" model="mail.template">
            <field name="name">Employee Letter: Experience</field>
            <field name="model_id" ref="model_pr_employee_document_letter"/>
            <field name="subject">{{ object.subject or 'Experience Letter' }}</field>
            <field name="email_from">{{ user.email_formatted or object.company_id.partner_id.email_formatted or '' }}</field>
            <field name="email_to">{{ object.employee_email or '' }}</field>
            <field name="body_html" type="html">
                <div>
                    <p>Dear <t t-out="object.employee_id.name or 'Employee'"/>,</p>
                    <p>Please find your experience letter attached.</p>
                    <p>Regards,<br/>Human Resources</p>
                </div>
            </field>
        </record>

