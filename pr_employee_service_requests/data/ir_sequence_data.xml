<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_pr_employee_service_request" model="ir.sequence">
            <field name="name">Employee Service Request</field>
            <field name="code">pr.employee.service.request</field>
            <field name="prefix">ESR-%(year)s-</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_pr_employee_payment_request" model="ir.sequence">
            <field name="name">Employee Payment Request</field>
            <field name="code">pr.employee.payment.request</field>
            <field name="prefix">EPR-%(year)s-</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_pr_employee_document_letter" model="ir.sequence">
            <field name="name">Employee Document Letter</field>
            <field name="code">pr.employee.document.letter</field>
            <field name="prefix">EDL-%(year)s-</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
