<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="rule_pr_employee_service_request_own" model="ir.rule">
            <field name="name">Employee Service Request: own requests</field>
            <field name="model_id" ref="model_pr_employee_service_request"/>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="domain_force">['|', ('requested_by_id', '=', user.id), ('employee_id.user_id', '=', user.id)]</field>
        </record>

        <record id="rule_pr_employee_service_request_employee_manager" model="ir.rule">
            <field name="name">Employee Service Request: employee manager approvals</field>
            <field name="model_id" ref="model_pr_employee_service_request"/>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="domain_force">[('employee_manager_user_id', '=', user.id)]</field>
        </record>

        <record id="rule_pr_employee_service_request_hr_all" model="ir.rule">
            <field name="name">Employee Service Request: HR can see all</field>
            <field name="model_id" ref="model_pr_employee_service_request"/>
            <field name="groups" eval="[
                (4, ref('hr.group_hr_manager')),
                (4, ref('de_hr_workspace.group_hr_employee_approvals')),
                (4, ref('pr_hr_recruitment_request.group_onboarding_supervisor')),
                (4, ref('pr_hr_recruitment_request.group_onboarding_manager'))
            ]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="rule_pr_employee_service_request_md_all" model="ir.rule">
            <field name="name">Employee Service Request: MD can see all</field>
            <field name="model_id" ref="model_pr_employee_service_request"/>
            <field name="groups" eval="[
                (4, ref('pr_custom_purchase.managing_director')),
                (4, ref('pr_hr_recruitment_request.group_onboarding_md'))
            ]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="rule_pr_employee_service_request_accounts_all" model="ir.rule">
            <field name="name">Employee Service Request: Accounts can see payment requests</field>
            <field name="model_id" ref="model_pr_employee_service_request"/>
            <field name="groups" eval="[
                (4, ref('account.group_account_manager')),
                (4, ref('pr_account.custom_group_accounting_manager'))
            ]"/>
            <field name="domain_force">[('state', 'in', ['payment_approval', 'paid', 'issued'])]</field>
        </record>

        <record id="rule_pr_employee_payment_request_own" model="ir.rule">
            <field name="name">Employee Payment Request: own requests</field>
            <field name="model_id" ref="model_pr_employee_payment_request"/>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="domain_force">['|', ('requested_user_id', '=', user.id), ('employee_id.user_id', '=', user.id)]</field>
        </record>

        <record id="rule_pr_employee_payment_request_manager" model="ir.rule">
            <field name="name">Employee Payment Request: employee manager requests</field>
            <field name="model_id" ref="model_pr_employee_payment_request"/>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="domain_force">[('service_request_id.employee_manager_user_id', '=', user.id)]</field>
        </record>

        <record id="rule_pr_employee_payment_request_hr_all" model="ir.rule">
            <field name="name">Employee Payment Request: HR can see all</field>
            <field name="model_id" ref="model_pr_employee_payment_request"/>
            <field name="groups" eval="[
                (4, ref('hr.group_hr_manager')),
                (4, ref('de_hr_workspace.group_hr_employee_approvals')),
                (4, ref('pr_hr_recruitment_request.group_onboarding_supervisor')),
                (4, ref('pr_hr_recruitment_request.group_onboarding_manager'))
            ]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="rule_pr_employee_payment_request_md_all" model="ir.rule">
            <field name="name">Employee Payment Request: MD can see all</field>
            <field name="model_id" ref="model_pr_employee_payment_request"/>
            <field name="groups" eval="[
                (4, ref('pr_custom_purchase.managing_director')),
                (4, ref('pr_hr_recruitment_request.group_onboarding_md'))
            ]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="rule_pr_employee_payment_request_accounts_all" model="ir.rule">
            <field name="name">Employee Payment Request: Accounts can see all</field>
            <field name="model_id" ref="model_pr_employee_payment_request"/>
            <field name="groups" eval="[
                (4, ref('account.group_account_invoice')),
                (4, ref('account.group_account_user')),
                (4, ref('account.group_account_manager')),
                (4, ref('pr_account.custom_group_accounting_manager'))
            ]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="rule_pr_employee_payment_request_line_own" model="ir.rule">
            <field name="name">Employee Payment Request Line: own request lines</field>
            <field name="model_id" ref="model_pr_employee_payment_request_line"/>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="domain_force">['|', '|', ('payment_request_id.requested_user_id', '=', user.id), ('payment_request_id.employee_id.user_id', '=', user.id), ('payment_request_id.service_request_id.employee_manager_user_id', '=', user.id)]</field>
        </record>

        <record id="rule_pr_employee_payment_request_line_hr_all" model="ir.rule">
            <field name="name">Employee Payment Request Line: HR can see all</field>
            <field name="model_id" ref="model_pr_employee_payment_request_line"/>
            <field name="groups" eval="[
                (4, ref('hr.group_hr_manager')),
                (4, ref('de_hr_workspace.group_hr_employee_approvals')),
                (4, ref('pr_hr_recruitment_request.group_onboarding_supervisor')),
                (4, ref('pr_hr_recruitment_request.group_onboarding_manager'))
            ]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="rule_pr_employee_payment_request_line_md_all" model="ir.rule">
            <field name="name">Employee Payment Request Line: MD can see all</field>
            <field name="model_id" ref="model_pr_employee_payment_request_line"/>
            <field name="groups" eval="[
                (4, ref('pr_custom_purchase.managing_director')),
                (4, ref('pr_hr_recruitment_request.group_onboarding_md'))
            ]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="rule_pr_employee_payment_request_line_accounts_all" model="ir.rule">
            <field name="name">Employee Payment Request Line: Accounts can see all</field>
            <field name="model_id" ref="model_pr_employee_payment_request_line"/>
            <field name="groups" eval="[
                (4, ref('account.group_account_invoice')),
                (4, ref('account.group_account_user')),
                (4, ref('account.group_account_manager')),
                (4, ref('pr_account.custom_group_accounting_manager'))
            ]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>
    </data>
</odoo>
