<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="de_hr_workspace.menu_my_employee_approvals" model="ir.ui.menu">
        <field name="groups_id" eval="[(4, ref('pr_hr_recruitment_request.group_onboarding_supervisor')), (4, ref('pr_hr_recruitment_request.group_onboarding_manager')), (4, ref('pr_hr_recruitment_request.group_onboarding_md'))]"/>
    </record>

    <record id="hr_recruitment_request_approvals_view_action" model="ir.actions.act_window">
        <field name="name">Recruitment Requests</field>
        <field name="res_model">hr.recruitment.request</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">['|', '|', ('state', '=', 'hr_approval'), ('state', '=', 'hrm_approval'), ('state', '=', 'md_approval')]</field>
        <field name="context">{'create': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                There Is No Recruitment Requests To Approve
            </p>
        </field>
    </record>

    <menuitem id="hr_recruitment_request_approvals_view_menu"
              parent="de_hr_workspace.hr_approvals_menu_root"
              name="Recruitment Requests"
              action="hr_recruitment_request_approvals_view_action"
              sequence="4"
              groups="de_hr_workspace.group_hr_employee_approvals,pr_hr_recruitment_request.group_onboarding_supervisor,pr_hr_recruitment_request.group_onboarding_manager,pr_hr_recruitment_request.group_onboarding_md"
    />

</odoo>