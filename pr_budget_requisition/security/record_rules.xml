<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="rule_pr_budget_requisition_own_or_department_manager" model="ir.rule">
            <field name="name">Budget Requisition: own or department manager</field>
            <field name="model_id" ref="model_pr_budget_requisition"/>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="domain_force">[
                '|', '|', '|',
                ('requested_by_id', '=', user.id),
                ('department_manager_user_id', '=', user.id),
                ('revision_of_id.requested_by_id', '=', user.id),
                ('revision_of_id.department_manager_user_id', '=', user.id)
            ]</field>
        </record>

        <record id="rule_pr_budget_requisition_approver_all" model="ir.rule">
            <field name="name">Budget Requisition: approvers can see all</field>
            <field name="model_id" ref="model_pr_budget_requisition"/>
            <field name="groups" eval="[
                (4, ref('account.group_account_user')),
                (4, ref('account.group_account_manager')),
                (4, ref('purchase.group_purchase_manager')),
                (4, ref('pr_custom_purchase.procurement_admin')),
                (4, ref('pr_custom_purchase.project_manager')),
                (4, ref('pr_custom_purchase.managing_director')),
                (4, ref('pr_custom_purchase.group_pr_approver'))
            ]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="rule_pr_budget_requisition_line_own_or_department_manager" model="ir.rule">
            <field name="name">Budget Requisition Line: own or department manager</field>
            <field name="model_id" ref="model_pr_budget_requisition_line"/>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="domain_force">[
                '|', '|', '|',
                ('requisition_id.requested_by_id', '=', user.id),
                ('requisition_id.department_manager_user_id', '=', user.id),
                ('requisition_id.revision_of_id.requested_by_id', '=', user.id),
                ('requisition_id.revision_of_id.department_manager_user_id', '=', user.id)
            ]</field>
        </record>

        <record id="rule_pr_budget_requisition_line_approver_all" model="ir.rule">
            <field name="name">Budget Requisition Line: approvers can see all</field>
            <field name="model_id" ref="model_pr_budget_requisition_line"/>
            <field name="groups" eval="[
                (4, ref('account.group_account_user')),
                (4, ref('account.group_account_manager')),
                (4, ref('purchase.group_purchase_manager')),
                (4, ref('pr_custom_purchase.procurement_admin')),
                (4, ref('pr_custom_purchase.project_manager')),
                (4, ref('pr_custom_purchase.managing_director')),
                (4, ref('pr_custom_purchase.group_pr_approver'))
            ]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>
    </data>
</odoo>
