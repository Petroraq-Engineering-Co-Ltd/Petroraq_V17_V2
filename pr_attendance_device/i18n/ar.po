#. module: pr_attendance_device
#: model:mail.template,body_html:pr_attendance_device.email_template_unknown_attendance_status_code
msgid ""
"\n"
"                <div style=\"font-family: 'Lucida Grande', Ubuntu, Arial, Verdana, sans-serif; font-size: 12px; color: rgb(34, 34, 34); background-color: #FFF; \">\n"
"                    <p>Hello <t t-out=\"object.user_id.partner_id.name or ''\"/>,</p>\n"
"                    <p>The system tried to download attendance data from the machine <t t-out=\"object.name\"/> but failed.</p>\n"
"                    <p>We found an unknown attendance status code <t t-out=\"ctx.get('code')\"/> from your machine <t t-out=\"ctx.get('machine_name')\"/> but no such code found in the machine's settings in the system. </p>\n"
"                    <p>Please check it again in your machine <t t-out=\"ctx.get('machine_name')\"/> and add that attendance code to the setting.</p>\n"
"                    <p>Best Regard,</p>\n"
"                </div>\n"
"                \n"
"            "
msgstr ""
"\n"
"                <div style=\"font-family: 'Lucida Grande', Ubuntu, Arial, Verdana, sans-serif; font-size: 12px; color: rgb(34, 34, 34); background-color: #FFF; \">\n"
"                    <p>مرحبًا <t t-out=\"object.user_id.partner_id.name or ''\"/>،</p>\n"
"                    <p>حاول النظام تنزيل بيانات الحضور من جهاز <t t-out=\"object.name\"/> ولكنه فشل.</p>\n"
"                    <p>تم العثور على رمز حالة حضور غير معروف <t t-out=\"ctx.get('code')\"/> من جهاز <t t-out=\"ctx.get('machine_name')\"/>، ولكن هذا الرمز غير موجود في إعدادات الجهاز داخل النظام.</p>\n"
"                    <p>يرجى التحقق من جهاز <t t-out=\"ctx.get('machine_name')\"/> وإضافة رمز الحضور هذا إلى الإعدادات.</p>\n"
"                    <p>مع أطيب التحيات،</p>\n"
"                </div>\n"
"                \n"
"            "

#. module: pr_attendance_device
#: model:mail.template,body_html:pr_attendance_device.email_template_not_safe_to_clear_attendance
msgid ""
"\n"
"<div style=\"font-family: 'Lucida Grande', Ubuntu, Arial, Verdana, sans-serif; font-size: 12px; color: rgb(34, 34, 34); background-color: #FFF; \">\n"
"\n"
"    <p>Hello <t t-out=\"object.user_id.partner_id.name or ''\"/>,</p>\n"
"\n"
"    <p>The system tried to delete attendance data from the machine <t t-out=\"object.name\"/> but it did not find safe condition to delete since the whole data was not downloaded from the machine into the system.</p>\n"
"    <p>Please also ensure that all the machine users have been mapped with System's employees. Otherwise, it is also not safe for attendance data deletion</p>\n"
"    <p>Please check and troubleshoot.</p>\n"
"    <p>In a case, users are checking in/out while the system is downloading data, this message could appear. In such the case, you can ignore this message.</p>\n"
"\n"
"    <p>Best Regard,</p>\n"
"\n"
"</div>\n"
"            "
msgstr ""
"\n"
"<div style=\"font-family: 'Lucida Grande', Ubuntu, Arial, Verdana, sans-serif; font-size: 12px; color: rgb(34, 34, 34); background-color: #FFF; \">\n"
"\n"
"    <p>مرحبًا <t t-out=\"object.user_id.partner_id.name or ''\"/>،</p>\n"
"\n"
"    <p>حاول النظام حذف بيانات الحضور من جهاز <t t-out=\"object.name\"/>، لكنه لم يجد شروطًا آمنة للحذف لأن جميع البيانات لم يتم تنزيلها بالكامل من الجهاز إلى النظام.</p>\n"
"    <p>يرجى أيضًا التأكد من ربط جميع مستخدمي الجهاز بموظفي النظام، وإلا فلن يكون حذف بيانات الحضور آمنًا.</p>\n"
"    <p>يرجى التحقق ومعالجة المشكلة.</p>\n"
"    <p>إذا كان المستخدمون يقومون بتسجيل الدخول أو الخروج أثناء تنزيل البيانات، فقد تظهر هذه الرسالة. في هذه الحالة يمكنك تجاهلها.</p>\n"
"\n"
"    <p>مع أطيب التحيات،</p>\n"
"\n"
"</div>\n"
"            "

#. module: pr_attendance_device
#: model:mail.template,body_html:pr_attendance_device.email_template_attendance_device
msgid ""
"\n"
"<div style=\"font-family: 'Lucida Grande', Ubuntu, Arial, Verdana, sans-serif; font-size: 12px; color: rgb(34, 34, 34); background-color: #FFF; \">\n"
"\n"
"    <p>Hello <t t-out=\"object.user_id.partner_id.name or ''\"/>,</p>\n"
"\n"
"    <p>There are some problems with attendance machine: <t t-out=\"object.name\"/>. </p>\n"
"\n"
"    <p>Please check and troubleshoot.</p>\n"
"    <p>Here is the debugging information: <t t-out=\"ctx.get('error_msg')\"/> </p>\n"
"\n"
"    <p>Best Regard,</p>\n"
"\n"
"</div>\n"
"            "
msgstr ""
"\n"
"<div style=\"font-family: 'Lucida Grande', Ubuntu, Arial, Verdana, sans-serif; font-size: 12px; color: rgb(34, 34, 34); background-color: #FFF; \">\n"
"\n"
"    <p>مرحبًا <t t-out=\"object.user_id.partner_id.name or ''\"/>،</p>\n"
"\n"
"    <p>توجد بعض المشكلات في جهاز الحضور: <t t-out=\"object.name\"/>.</p>\n"
"\n"
"    <p>يرجى التحقق من المشكلة ومعالجتها.</p>\n"
"    <p>معلومات التصحيح: <t t-out=\"ctx.get('error_msg')\"/></p>\n"
"\n"
"    <p>مع أطيب التحيات،</p>\n"
"\n"
"</div>\n"
"            "

#. module: pr_attendance_device
#: model:mail.template,body_html:pr_attendance_device.email_template_error_get_attendance
msgid ""
"\n"
"<div>\n"
"    <p>Hello <t t-out=\"object.user_id.partner_id.name or ''\"/>,</p>\n"
"    <p>The system tried to download attendance data from the machine <t t-out=\"object.name\"/> but failed.</p>\n"
"    <p>NOTE:</p>\n"
"    <p>The machine might not return its whole attendance data when requested which could cause this error.</p>\n"
"    <p>If such the case, please disconnect the machine from the system then download the data with another mean from your local network. After that, reconnect the machine with the system and continue the data synchronization</p>\n"
"    <p>Best Regard,</p>\n"
"</div>\n"
"            "
msgstr ""
"\n"
"<div>\n"
"    <p>مرحبًا <t t-out=\"object.user_id.partner_id.name or ''\"/>،</p>\n"
"    <p>حاول النظام تنزيل بيانات الحضور من جهاز <t t-out=\"object.name\"/> ولكنه فشل.</p>\n"
"    <p><strong>ملاحظة:</strong></p>\n"
"    <p>قد لا يعيد الجهاز جميع بيانات الحضور عند الطلب، مما قد يؤدي إلى ظهور هذا الخطأ.</p>\n"
"    <p>في هذه الحالة، يرجى فصل الجهاز عن النظام وتنزيل البيانات باستخدام وسيلة أخرى من خلال الشبكة المحلية، ثم إعادة توصيل الجهاز بالنظام ومتابعة مزامنة البيانات.</p>\n"
"    <p>مع أطيب التحيات،</p>\n"
"</div>\n"
"            "

