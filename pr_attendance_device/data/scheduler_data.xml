<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_scheduler_sync_attendance" model="ir.cron">
            <field name="name">Synchronize attendances scheduler</field>
            <field name="model_id" ref="model_user_attendance"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="state">code</field>
            <field name="interval_number">30</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field eval="False" name="doall"/>
            <field name="code">model._cron_synch_hr_attendance()</field>
        </record>

        <record id="ir_cron_scheduler_download_attendance" model="ir.cron">
            <field name="name">Download attendances scheduler</field>
            <field name="model_id" ref="model_attendance_device"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="state">code</field>
            <field name="interval_number">30</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field eval="False" name="doall"/>
            <field name="code">model._cron_download_device_attendance()</field>
        </record>

        <record id="ir_cron_scheduler_checkin_leverage" model="ir.cron">
            <field name="name">Sync Attendance Machine Data</field>
            <field name="model_id" ref="model_user_attendance"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="state">code</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field eval="False" name="doall"/>
            <field name="nextcall"
                   eval="((DateTime.now().replace(hour=6, minute=10, second=0, microsecond=0) if DateTime.now() &lt; DateTime.now().replace(hour=6, minute=10, second=0, microsecond=0) else DateTime.now().replace(hour=6, minute=10, second=0, microsecond=0) + relativedelta(days=1)).strftime('%Y-%m-%d %H:%M:%S'))"/>
            <field name="code">model._cron_apply_checkin_leverage()</field>
        </record>


    </data>
</odoo>
