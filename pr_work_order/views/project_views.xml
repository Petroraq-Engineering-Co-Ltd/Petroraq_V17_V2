<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_project_form_inherit_pr_work_order" model="ir.ui.view">
        <field name="name">project.project.form.pr.work.order</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/group/group" position="inside">
                <field name="analytic_account_id"/>
            </xpath>
        </field>
    </record>

    <record id="view_project_milestone_form_inherit_pr_invoice_amount" model="ir.ui.view">
        <field name="name">project.milestone.form.pr.invoice.amount</field>
        <field name="model">project.milestone</field>
        <field name="inherit_id" ref="project.project_milestone_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='deadline']" position="after">
                <field name="petroraq_invoice_amount"/>
            </xpath>
        </field>
    </record>

    <record id="view_project_milestone_tree_inherit_pr_invoice_amount" model="ir.ui.view">
        <field name="name">project.milestone.tree.pr.invoice.amount</field>
        <field name="model">project.milestone</field>
        <field name="inherit_id" ref="project.project_milestone_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='deadline']" position="after">
                <field name="petroraq_invoice_amount" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
