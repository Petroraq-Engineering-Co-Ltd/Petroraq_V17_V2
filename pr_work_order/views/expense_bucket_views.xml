<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_pr_expense_bucket_tree_inherit_work_order" model="ir.ui.view">
        <field name="name">pr.expense.bucket.tree.work.order</field>
        <field name="model">pr.expense.bucket</field>
        <field name="inherit_id" ref="pr_custom_purchase.view_pr_expense_bucket_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='department_id']" position="after">
                <field name="work_order_id" optional="show"/>
                <field name="sale_order_id" optional="show"/>
                <field name="po_reference" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="view_pr_expense_bucket_form_inherit_work_order" model="ir.ui.view">
        <field name="name">pr.expense.bucket.form.work.order</field>
        <field name="model">pr.expense.bucket</field>
        <field name="inherit_id" ref="pr_custom_purchase.view_pr_expense_bucket_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='department_id']" position="after">
                <field name="work_order_id" invisible="scope != 'project'"
                       required="scope == 'project'" readonly="state == 'approved'"/>
                <field name="sale_order_id" invisible="scope != 'trading'"
                       required="scope == 'trading'" readonly="state == 'approved'"/>
                <field name="po_reference" invisible="scope != 'trading'" readonly="state == 'approved'"/>
            </xpath>
        </field>
    </record>

    <record id="view_budget_form_inherit_work_order_source_products" model="ir.ui.view">
        <field name="name">budget.form.inherit.work.order.source.products</field>
        <field name="model">crossovered.budget</field>
        <field name="inherit_id" ref="pr_custom_purchase.view_budget_form_inherit_expense_type"/>
        <field name="arch" type="xml">
            <xpath expr="//page[field[@name='crossovered_budget_line']]" position="after">
                <page string="Products Detail"
                      invisible="not sale_order_id and not work_order_id">
                    <group>
                        <field name="sale_order_id" readonly="1"/>
                        <field name="work_order_id" readonly="1"/>
                        <field name="source_products_total" readonly="1"/>
                    </group>
                    <field name="source_products_html" widget="html" readonly="1"/>
                </page>
            </xpath>
        </field>
    </record>
</odoo>