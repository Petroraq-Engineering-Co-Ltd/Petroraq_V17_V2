<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="paperformat_pr_work_order_landscape" model="report.paperformat">
        <field name="name">Work Order Landscape</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Landscape</field>
        <field name="margin_top">12</field>
        <field name="margin_right">6</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">6</field>
        <field name="header_line" eval="False"/>
        <field name="dpi">90</field>
    </record>

    <record id="action_report_pr_work_order_pdf" model="ir.actions.report">
        <field name="name">Work Order PDF</field>
        <field name="model">pr.work.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">pr_work_order.work_order_pdf</field>
        <field name="report_file">pr_work_order.work_order_pdf</field>
        <field name="binding_model_id" ref="model_pr_work_order"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_pr_work_order_landscape"/>
        <field name="print_report_name">'Work Order - %s' % (object.name)</field>
    </record>

    <record id="action_report_pr_work_order_xlsx" model="ir.actions.report">
        <field name="name">Work Order Excel</field>
        <field name="model">pr.work.order</field>
        <field name="report_type">xlsx</field>
        <field name="report_name">pr_work_order.work_order_xlsx_report</field>
        <field name="report_file">Work Order</field>
        <field name="binding_model_id" ref="model_pr_work_order"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'Work Order - %s' % (object.name)</field>
    </record>

    <template id="work_order_pdf">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <div class="page" style="font-size:12px;">
                    <table style="width:100%; border-collapse:collapse; margin-bottom:10px;">
                        <tr>
                            <td style="background:#173b76; color:#ffffff; text-align:center; font-weight:bold; font-size:20px; padding:8px; border:1px solid #173b76;">
                                <span t-esc="doc.company_id.display_name or doc.env.company.display_name"/>
                            </td>
                        </tr>
                        <tr>
                            <td style="background:#173b76; color:#ffffff; text-align:center; font-weight:bold; font-size:16px; padding:6px; border:1px solid #173b76;">
                                WORK ORDER
                            </td>
                        </tr>
                    </table>

                    <table style="width:100%; border-collapse:collapse; margin-bottom:10px;">
                        <tr>
                            <td style="width:15%; background:#f2f6fa; font-weight:bold; border:1px solid #cccccc; padding:5px;">Work Order</td>
                            <td style="width:35%; border:1px solid #cccccc; padding:5px;"><span t-esc="doc.name"/></td>
                            <td style="width:15%; background:#f2f6fa; font-weight:bold; border:1px solid #cccccc; padding:5px;">Status</td>
                            <td style="width:35%; border:1px solid #cccccc; padding:5px;"><span t-esc="dict(doc._fields['state'].selection).get(doc.state, doc.state or '')"/></td>
                        </tr>
                        <tr>
                            <td style="background:#f2f6fa; font-weight:bold; border:1px solid #cccccc; padding:5px;">Customer</td>
                            <td style="border:1px solid #cccccc; padding:5px;"><span t-esc="doc.partner_id.display_name or ''"/></td>
                            <td style="background:#f2f6fa; font-weight:bold; border:1px solid #cccccc; padding:5px;">Sale Order</td>
                            <td style="border:1px solid #cccccc; padding:5px;"><span t-esc="doc.sale_order_id.name or ''"/></td>
                        </tr>
                        <tr>
                            <td style="background:#f2f6fa; font-weight:bold; border:1px solid #cccccc; padding:5px;">Project</td>
                            <td style="border:1px solid #cccccc; padding:5px;"><span t-esc="doc.project_id.display_name or ''"/></td>
                            <td style="background:#f2f6fa; font-weight:bold; border:1px solid #cccccc; padding:5px;">Cost Center</td>
                            <td style="border:1px solid #cccccc; padding:5px;"><span t-esc="doc.analytic_account_id.display_name or ''"/></td>
                        </tr>
                        <tr>
                            <td style="background:#f2f6fa; font-weight:bold; border:1px solid #cccccc; padding:5px;">Planned Start</td>
                            <td style="border:1px solid #cccccc; padding:5px;"><span t-field="doc.date_start" t-options="{'widget': 'date'}"/></td>
                            <td style="background:#f2f6fa; font-weight:bold; border:1px solid #cccccc; padding:5px;">Planned End</td>
                            <td style="border:1px solid #cccccc; padding:5px;"><span t-field="doc.date_end" t-options="{'widget': 'date'}"/></td>
                        </tr>
                    </table>

                    <table style="width:100%; border-collapse:collapse;">
                        <thead>
                            <tr>
                                <th style="background:#173b76; color:#ffffff; border:1px solid #000; padding:5px; width:4%;">#</th>
                                <th style="background:#173b76; color:#ffffff; border:1px solid #000; padding:5px; width:14%;">Section</th>
                                <th style="background:#173b76; color:#ffffff; border:1px solid #000; padding:5px; width:18%;">Product</th>
                                <th style="background:#173b76; color:#ffffff; border:1px solid #000; padding:5px; width:32%;">Description</th>
                                <th style="background:#173b76; color:#ffffff; border:1px solid #000; padding:5px; width:8%;">Qty</th>
                                <th style="background:#173b76; color:#ffffff; border:1px solid #000; padding:5px; width:8%;">UoM</th>
                                <th style="background:#173b76; color:#ffffff; border:1px solid #000; padding:5px; width:8%;">Unit Cost</th>
                                <th style="background:#173b76; color:#ffffff; border:1px solid #000; padding:5px; width:8%;">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="line_no" t-value="0"/>
                            <t t-foreach="doc.boq_line_ids" t-as="line">
                                <tr t-if="line.display_type == 'line_section'">
                                    <td colspan="8" style="background:#cfe2f3; font-weight:bold; border:1px solid #999999; padding:5px;">
                                        <span t-esc="line.name or line.section_name or ''"/>
                                    </td>
                                </tr>
                                <tr t-elif="line.display_type == 'line_note'">
                                    <td colspan="8" style="font-style:italic; border:1px solid #dddddd; padding:5px;">
                                        <span t-esc="line.name or ''"/>
                                    </td>
                                </tr>
                                <tr t-else="">
                                    <t t-set="line_no" t-value="line_no + 1"/>
                                    <td style="border:1px solid #dddddd; padding:4px; text-align:center;"><span t-esc="line_no"/></td>
                                    <td style="border:1px solid #dddddd; padding:4px;"><span t-esc="line.section_name or ''"/></td>
                                    <td style="border:1px solid #dddddd; padding:4px;"><span t-esc="line.product_id.display_name or ''"/></td>
                                    <td style="border:1px solid #dddddd; padding:4px;"><span t-esc="line.name or ''"/></td>
                                    <td style="border:1px solid #dddddd; padding:4px; text-align:right;"><span t-esc="'{:,.2f}'.format(line.qty or 0.0)"/></td>
                                    <td style="border:1px solid #dddddd; padding:4px;"><span t-esc="line.uom_id.name or ''"/></td>
                                    <td style="border:1px solid #dddddd; padding:4px; text-align:right;"><span t-esc="'{:,.2f}'.format(line.unit_cost or 0.0)"/></td>
                                    <td style="border:1px solid #dddddd; padding:4px; text-align:right;"><span t-esc="'{:,.2f}'.format(line.total or 0.0)"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <table style="width:38%; margin-left:auto; margin-top:10px; border-collapse:collapse;">
                        <tr><td style="background:#173b76; color:#ffffff; font-weight:bold; border:1px solid #000; padding:5px;">Contract Amount</td><td style="border:1px solid #000; padding:5px; text-align:right;"><span t-esc="'{:,.2f}'.format(doc.contract_amount or 0.0)"/></td></tr>
                        <tr><td style="background:#173b76; color:#ffffff; font-weight:bold; border:1px solid #000; padding:5px;">Budgeted Cost</td><td style="border:1px solid #000; padding:5px; text-align:right;"><span t-esc="'{:,.2f}'.format(doc.budgeted_cost or 0.0)"/></td></tr>
                        <tr><td style="background:#173b76; color:#ffffff; font-weight:bold; border:1px solid #000; padding:5px;">Budgeted Margin</td><td style="border:1px solid #000; padding:5px; text-align:right;"><span t-esc="'{:,.2f}'.format(doc.budgeted_margin or 0.0)"/></td></tr>
                        <tr><td style="background:#173b76; color:#ffffff; font-weight:bold; border:1px solid #000; padding:5px;">Total Expected Cost</td><td style="border:1px solid #000; padding:5px; text-align:right;"><span t-esc="'{:,.2f}'.format(doc.total_expected_cost or 0.0)"/></td></tr>
                        <tr><td style="background:#173b76; color:#ffffff; font-weight:bold; border:1px solid #000; padding:5px;">Total With Profit</td><td style="border:1px solid #000; padding:5px; text-align:right;"><span t-esc="'{:,.2f}'.format(doc.total_with_profit or 0.0)"/> <span t-esc="doc.currency_id.name or ''"/></td></tr>
                    </table>

                    <t t-if="doc.cost_center_ids">
                        <h4 style="margin-top:12px; margin-bottom:5px;">Cost Centers</h4>
                        <table style="width:100%; border-collapse:collapse;">
                            <thead>
                                <tr>
                                    <th style="background:#173b76; color:#ffffff; border:1px solid #000; padding:5px;">Section</th>
                                    <th style="background:#173b76; color:#ffffff; border:1px solid #000; padding:5px;">Cost Center</th>
                                    <th style="background:#173b76; color:#ffffff; border:1px solid #000; padding:5px;">Planned</th>
                                    <th style="background:#173b76; color:#ffffff; border:1px solid #000; padding:5px;">Spent</th>
                                    <th style="background:#173b76; color:#ffffff; border:1px solid #000; padding:5px;">Remaining</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="doc.cost_center_ids" t-as="cost_center">
                                    <td style="border:1px solid #dddddd; padding:4px;"><span t-esc="cost_center.section_name or ''"/></td>
                                    <td style="border:1px solid #dddddd; padding:4px;"><span t-esc="cost_center.analytic_account_id.display_name or ''"/></td>
                                    <td style="border:1px solid #dddddd; padding:4px; text-align:right;"><span t-esc="'{:,.2f}'.format(cost_center.estimated_cost or 0.0)"/></td>
                                    <td style="border:1px solid #dddddd; padding:4px; text-align:right;"><span t-esc="'{:,.2f}'.format(cost_center.spent_amount or 0.0)"/></td>
                                    <td style="border:1px solid #dddddd; padding:4px; text-align:right;"><span t-esc="'{:,.2f}'.format(cost_center.remaining_amount or 0.0)"/></td>
                                </tr>
                            </tbody>
                        </table>
                    </t>
                </div>
            </t>
        </t>
    </template>
</odoo>
