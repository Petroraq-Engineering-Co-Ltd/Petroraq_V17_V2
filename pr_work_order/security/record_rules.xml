<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!--
        A Work Order view reads the display name of its linked quotation. Sales
        users restricted to "Own Documents Only" must therefore be able to
        read the quotation behind each Work Order they are allowed to read.
        These rules grant read access only; they do not widen quotation write,
        create, or delete permissions.
    -->
    <record id="rule_sale_order_linked_work_order_own_documents_read" model="ir.rule">
        <field name="name">Quotation: linked to own Work Orders (read only)</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="groups" eval="[(4, ref('pr_work_order.custom_group_work_order_own_documents'))]"/>
        <field name="domain_force">[('work_order_id.create_uid', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_sale_order_linked_work_order_all_documents_read" model="ir.rule">
        <field name="name">Quotation: linked to accessible Work Orders (read only)</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="groups" eval="[(4, ref('pr_work_order.custom_group_work_order_all_documents'))]"/>
        <field name="domain_force">[('work_order_id', '!=', False)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_pr_work_order_own_documents" model="ir.rule">
        <field name="name">Work Order: own documents only</field>
        <field name="model_id" ref="model_pr_work_order"/>
        <field name="groups" eval="[(4, ref('pr_work_order.custom_group_work_order_own_documents'))]"/>
        <field name="domain_force">[('create_uid', '=', user.id)]</field>
    </record>

    <record id="rule_pr_work_order_all_documents" model="ir.rule">
        <field name="name">Work Order: all documents</field>
        <field name="model_id" ref="model_pr_work_order"/>
        <field name="groups" eval="[(4, ref('pr_work_order.custom_group_work_order_all_documents'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="rule_pr_work_order_boq_own_documents" model="ir.rule">
        <field name="name">Work Order BOQ: own documents only</field>
        <field name="model_id" ref="model_pr_work_order_boq"/>
        <field name="groups" eval="[(4, ref('pr_work_order.custom_group_work_order_own_documents'))]"/>
        <field name="domain_force">[('work_order_id.create_uid', '=', user.id)]</field>
    </record>

    <record id="rule_pr_work_order_boq_all_documents" model="ir.rule">
        <field name="name">Work Order BOQ: all documents</field>
        <field name="model_id" ref="model_pr_work_order_boq"/>
        <field name="groups" eval="[(4, ref('pr_work_order.custom_group_work_order_all_documents'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="rule_pr_work_order_cost_center_own_documents" model="ir.rule">
        <field name="name">Work Order Cost Center: own documents only</field>
        <field name="model_id" ref="model_pr_work_order_cost_center"/>
        <field name="groups" eval="[(4, ref('pr_work_order.custom_group_work_order_own_documents'))]"/>
        <field name="domain_force">[('work_order_id.create_uid', '=', user.id)]</field>
    </record>

    <record id="rule_pr_work_order_cost_center_all_documents" model="ir.rule">
        <field name="name">Work Order Cost Center: all documents</field>
        <field name="model_id" ref="model_pr_work_order_cost_center"/>
        <field name="groups" eval="[(4, ref('pr_work_order.custom_group_work_order_all_documents'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="rule_pr_work_order_costing_report_own_documents" model="ir.rule">
        <field name="name">Work Order Costing Report: own documents only</field>
        <field name="model_id" ref="model_pr_work_order_costing_report"/>
        <field name="groups" eval="[(4, ref('pr_work_order.custom_group_work_order_own_documents'))]"/>
        <field name="domain_force">[('work_order_id.create_uid', '=', user.id)]</field>
    </record>

    <record id="rule_pr_work_order_costing_report_all_documents" model="ir.rule">
        <field name="name">Work Order Costing Report: all documents</field>
        <field name="model_id" ref="model_pr_work_order_costing_report"/>
        <field name="groups" eval="[(4, ref('pr_work_order.custom_group_work_order_all_documents'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="rule_pr_work_order_costing_section_report_own_documents" model="ir.rule">
        <field name="name">Work Order Costing Section Report: own documents only</field>
        <field name="model_id" ref="model_pr_work_order_costing_section_report"/>
        <field name="groups" eval="[(4, ref('pr_work_order.custom_group_work_order_own_documents'))]"/>
        <field name="domain_force">[('work_order_id.create_uid', '=', user.id)]</field>
    </record>

    <record id="rule_pr_work_order_costing_section_report_all_documents" model="ir.rule">
        <field name="name">Work Order Costing Section Report: all documents</field>
        <field name="model_id" ref="model_pr_work_order_costing_section_report"/>
        <field name="groups" eval="[(4, ref('pr_work_order.custom_group_work_order_all_documents'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>
</odoo>
