#. module: petroraq_sale_workflow
#: model:mail.template,body_html:petroraq_sale_workflow.petroraq_custom_proforma_email
msgid ""
"\n"
"                \n"
"    <p style=\"font-size:13px;\">\n"
"        <t t-set=\"doc_name\"\n"
"           t-value=\"'Proforma Invoice' if object.state in ('draft','sent') else 'Sales Order'\"/>\n"
"\n"
"        Hello,<br/><br/>\n"
"\n"
"        Please pay <strong t-out=\"object.proforma_dp\"/>% down payment against your\n"
"        <t t-out=\"doc_name\"/>\n"
"        <strong><t t-out=\"object.name\"/></strong>\n"
"        <t t-if=\"object.origin\">\n"
"            (Reference: <t t-out=\"object.origin\"/>)\n"
"        </t>\n"
"        amounting to\n"
"        <strong t-out=\"format_amount(object.amount_untaxed, object.currency_id)\"/>.\n"
"        <br/><br/>\n"
"\n"
"        Do not hesitate to contact us.\n"
"        <t t-if=\"not is_html_empty(object.user_id.signature)\">\n"
"            <br/><br/>\n"
"            <t t-out=\"object.user_id.signature\"/>\n"
"        </t>\n"
"    </p>\n"
"    \n"
"            "
msgstr ""
"\n"
"                \n"
"    <p style=\"font-size:13px;\">\n"
"        <t t-set=\"doc_name\"\n"
"           t-value=\"'الفاتورة الأولية' if object.state in ('draft','sent') else 'أمر البيع'\"/>\n"
"\n"
"        مرحبًا،<br/><br/>\n"
"\n"
"        يرجى سداد دفعة مقدمة بنسبة <strong t-out=\"object.proforma_dp\"/>% مقابل\n"
"        <t t-out=\"doc_name\"/>\n"
"        <strong><t t-out=\"object.name\"/></strong>\n"
"        <t t-if=\"object.origin\">\n"
"            (المرجع: <t t-out=\"object.origin\"/>)\n"
"        </t>\n"
"        بقيمة\n"
"        <strong t-out=\"format_amount(object.amount_untaxed, object.currency_id)\"/>.\n"
"        <br/><br/>\n"
"\n"
"        لا تتردد في التواصل معنا.\n"
"        <t t-if=\"not is_html_empty(object.user_id.signature)\">\n"
"            <br/><br/>\n"
"            <t t-out=\"object.user_id.signature\"/>\n"
"        </t>\n"
"    </p>\n"
"    \n"
"            "

#. module: petroraq_sale_workflow
#: model:mail.template,body_html:petroraq_sale_workflow.petroraq_custom_sale_email
msgid ""
"\n"
"                 <p style=\"font-size:13px;\"> <t t-set=\"doc_name\" t-value=\"'quotation' if object.state in ('draft','sent') else 'order'\"/> Hello,<br/><br/> Your <t t-out=\"doc_name\"/> <strong t-out=\"object.name\"/> <t t-if=\"object.origin\">(Reference: <t t-out=\"object.origin\"/>)</t> amounting to <strong t-out=\"format_amount(object.amount_untaxed, object.currency_id)\"/> is ready for review. <br/><br/> Do not hesitate to contact us. <t t-if=\"not is_html_empty(object.user_id.signature)\"> <br/><br/> <t t-out=\"object.user_id.signature\"/> </t> </p> "
msgstr ""
"\n"
"                 <p style=\"font-size:13px;\"> <t t-set=\"doc_name\" t-value=\"'عرض السعر' if object.state in ('draft','sent') else 'أمر البيع'\"/> مرحبًا،<br/><br/> إن <t t-out=\"doc_name\"/> <strong t-out=\"object.name\"/> <t t-if=\"object.origin\">(المرجع: <t t-out=\"object.origin\"/>)</t> بقيمة <strong t-out=\"format_amount(object.amount_untaxed, object.currency_id)\"/> جاهز للمراجعة. <br/><br/> لا تتردد في التواصل معنا. <t t-if=\"not is_html_empty(object.user_id.signature)\"> <br/><br/> <t t-out=\"object.user_id.signature\"/> </t> </p> "

