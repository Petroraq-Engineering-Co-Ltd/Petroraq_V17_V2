<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="paperformat_payslip_custom_header_footer" model="report.paperformat">
        <field name="name">Petroraq Payslip Report</field>
        <field name="format">custom</field>
        <field name="page_height">370</field>
        <field name="page_width">250</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">55</field>
        <field name="margin_bottom">37</field>
        <field name="margin_left">0</field>
        <field name="margin_right">0</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">55</field>
        <field name="dpi">95</field>
    </record>

    <record id="hr_payroll.action_report_payslip" model="ir.actions.report">
        <field name="paperformat_id" ref="de_hr_workspace_payroll.paperformat_payslip_custom_header_footer"/>
    </record>

    <template id="report_payslip_use_invoice_header_footer" inherit_id="hr_payroll.report_payslip">
        <xpath expr="//t[@t-call='web.external_layout']" position="attributes">
            <attribute name="t-call">pr_tax_Invoice_report_custom.custom_invoice_bridge_layout</attribute>
        </xpath>
    </template>
</odoo>