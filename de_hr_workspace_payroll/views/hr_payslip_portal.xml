<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="portal_employee_payslip" name="Employee Payslips" customize_show="True"
              inherit_id="portal.portal_my_home">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="before">
            <t t-set="portal_employee_user" t-value="request.env['hr.employee'].sudo().search_count([('user_id', '=', request.env.user.id), ('active', '=', True)])"/>
            <t t-if="portal_employee_user" t-set="portal_service_category_enable" t-value="True"/>
        </xpath>
        <div id="portal_service_category" position="inside">
            <t t-if="portal_employee_user" t-call="portal.portal_docs_entry">
                <t t-set="icon" t-value="'/de_hr_workspace_payroll/static/src/img/payslip_portal.png'"/>
                <t t-set="title">Payslips</t>
                <t t-set="url" t-value="'/my/payslips'"/>
                <t t-set="text">Follow your payslips</t>
                <t t-set="placeholder_count" t-value="'my_payslip_count'"/>
            </t>
        </div>
    </template>

    <template id="portal_my_payslips" name="My Attendances">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>

            <t t-call="portal.portal_searchbar">
                <t t-set="title">Payslips</t>
            </t>
            <t t-if="not payslips">
                <div class="alert alert-warning" role="alert">
                    There are no payslips.
                </div>
            </t>
            <t t-if="payslips">
                <t t-call="portal.portal_table">
                    <t t-set="loop_cycle_number" t-value="0"/>
                    <thead>
                        <tr class="active" style="background-color: #009879;color: #ffffff;">
                            <th>Reference</th>
                            <th>From</th>
                            <th>To</th>
                            <th>Net</th>
                            <th colspan="2">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="payslips" t-as="payslip"
                            t-att-style="'background-color: #ffffff' if loop_cycle_number % 2 == 0 else 'background-color: #f2f2f2;color: #009879;'">
                            <t t-set="loop_cycle_number" t-value="loop_cycle_number + 1"/>
                            <td>
                                <span t-esc="payslip.number"/>
                            </td>
                            <td>
                                <span t-field="payslip.date_from"/>
                            </td>
                            <td>
                                <span t-field="payslip.date_to"/>
                            </td>
                            <td>
                                <span t-field="payslip.net_wage"/>
                            </td>
                            <td>
                                <span t-field="payslip.state"
                                      style="color: #fff !important;background-color: #008080 !important;border-color: #008080 !important;border-radius: 8px !important;padding: 6px !important;"/>
                            </td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a class="btn btn-info" t-attf-href="/my/payslips/#{payslip.id}">
                                        <i class="fa fa-eye"/>
                                        Details
                                    </a>
                                    <a class="btn btn-info" t-attf-href="/my/payslips/#{payslip.id}/download" target="_blank">
                                        <i class="fa fa-file-pdf-o"/>
                                        Preview PDF
                                    </a>
                                    <a class="btn btn-secondary" t-attf-href="/my/payslips/#{payslip.id}/download?download=1">
                                        <i class="fa fa-download"/>
                                        Download
                                    </a>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </t>
            </t>
        </t>
    </template>

    <template id="employee_payslip_info_portal" name="Payslip Details">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>

            <t t-call="portal.portal_searchbar">
                <t t-set="title">Payslip Details</t>
            </t>

            <div class="mb-3 d-flex gap-2">
                <a class="btn btn-secondary" href="/my/payslips">
                    <i class="fa fa-chevron-left"/>
                    Back to Payslips
                </a>
                <a class="btn btn-info" t-attf-href="/my/payslips/#{payslip_id.id}/download" target="_blank">
                    <i class="fa fa-file-pdf-o"/>
                    Preview PDF
                </a>
                <a class="btn btn-secondary" t-attf-href="/my/payslips/#{payslip_id.id}/download?download=1">
                    <i class="fa fa-download"/>
                    Download
                </a>
            </div>

            <t t-if="not payslip_id.line_ids_filtered">
                <div class="alert alert-warning" role="alert">
                    There are no payslip lines to display.
                </div>
            </t>
            <t t-if="payslip_id.line_ids_filtered">
                <t t-call="portal.portal_table">
                    <t t-set="loop_cycle_number" t-value="0"/>
                    <thead>
                        <tr class="active" style="background-color: #009879;color: #ffffff;">
                            <th>Name</th>
                            <th>Category</th>
                            <th>Rule</th>
                            <th class="text-end">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="payslip_id.line_ids_filtered" t-as="line"
                            t-att-style="'background-color: #ffffff' if loop_cycle_number % 2 == 0 else 'background-color: #f2f2f2;color: #009879;'">
                            <t t-set="loop_cycle_number" t-value="loop_cycle_number + 1"/>
                            <td>
                                <span t-esc="line.name"/>
                            </td>
                            <td>
                                <span t-field="line.category_id.name"/>
                            </td>
                            <td>
                                <span t-field="line.salary_rule_id.name"/>
                            </td>
                            <td class="text-end">
                                <span t-field="line.total"/>
                            </td>
                        </tr>
                    </tbody>
                </t>
            </t>
        </t>
    </template>
</odoo>
