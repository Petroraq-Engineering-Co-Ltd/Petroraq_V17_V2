<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_pr_customer_credit_limit" model="ir.ui.view">
        <field name="name">res.partner.form.pr.customer.credit.limit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_credit_limit_requests"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-credit-card">
                    <field name="pr_credit_limit_request_count" widget="statinfo" string="Credit Requests"/>
                </button>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Credit Facility">
                    <group>
                        <group string="Approved Facility">
                            <field name="pr_credit_limit_currency_id" invisible="1"/>
                            <field name="pr_credit_limit_enabled" readonly="1"/>
                            <field name="pr_credit_limit_amount" readonly="1"/>
                            <field name="pr_credit_limit_approved_request_id" readonly="1"/>
                            <button name="action_create_credit_limit_request"
                                    string="Create Credit Limit Request"
                                    type="object"
                                    class="btn-primary"/>
                        </group>
                        <group string="Current Exposure">
                            <field name="pr_credit_limit_receivable_exposure"/>
                            <field name="pr_credit_limit_sale_order_exposure"/>
                            <field name="pr_credit_limit_total_exposure"/>
                            <field name="pr_credit_limit_remaining"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
