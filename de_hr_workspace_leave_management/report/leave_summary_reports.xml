<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_leave_report_action" model="ir.actions.report">
        <field name="name">Leave Dashboard PDF</field>
        <field name="model">hr.leave.report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">de_hr_workspace_leave_management.hr_leave_report</field>
        <field name="report_file">de_hr_workspace_leave_management.hr_leave_report</field>
    </record>

    <record id="leave_analytics_pdf_report" model="ir.actions.report">
        <field name="name">Leave Analytics PDF</field>
        <field name="model">de.hr.leave.analytics.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">de_hr_workspace_leave_management.leave_analytics_pdf</field>
        <field name="report_file">de_hr_workspace_leave_management.leave_analytics_pdf</field>
        <field name="print_report_name">'Leave Analytics - %s' % (object.date_to or '')</field>
    </record>

    <record id="leave_analytics_xlsx_report" model="ir.actions.report">
        <field name="name">Leave Analytics Excel</field>
        <field name="model">de.hr.leave.analytics.wizard</field>
        <field name="report_type">xlsx</field>
        <field name="report_name">de_hr_workspace_leave_management.leave_analytics_xlsx</field>
        <field name="report_file">leave_analytics</field>
        <field name="print_report_name">'Leave Analytics - %s' % (object.date_to or '')</field>
    </record>
</odoo>
