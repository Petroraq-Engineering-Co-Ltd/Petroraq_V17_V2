<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dashboard_export_wizard_form" model="ir.ui.view">
        <field name="name">de.hr.leave.dashboard.export.wizard.form</field>
        <field name="model">de.hr.leave.dashboard.export.wizard</field>
        <field name="arch" type="xml">
            <form string="Dashboard Export" create="false" edit="false">
                <group>
                    <field name="duration"/>
                </group>
                <group string="Sections to Export" col="2">
                    <field name="include_absentees"/>
                    <field name="include_leave_availability"/>
                    <field name="include_sick_leaves"/>
                    <field name="include_annual_leaves"/>
                    <field name="include_other_leaves"/>
                    <field name="include_leave_type_metrics"/>
                </group>
                <footer>
                    <button name="action_export_pdf" string="Export PDF" type="object" class="btn-primary"/>
                    <button name="action_export_xlsx" string="Export Excel" type="object"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_dashboard_export_wizard" model="ir.actions.act_window">
        <field name="name">Dashboard Export</field>
        <field name="res_model">de.hr.leave.dashboard.export.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
