<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pr_sign_waiting_for_me_approval_action" model="ir.actions.act_window">
        <field name="name">Documents to Sign</field>
        <field name="res_model">sign.request</field>
        <field name="view_mode">kanban,tree,form,activity</field>
        <field name="search_view_id" ref="sign.sign_request_view_search"/>
        <field name="domain">[
            ('state', '=', 'sent'),
            ('need_my_signature', '=', True)
        ]</field>
        <field name="context">{
            'create': False,
            'edit': False,
            'search_default_waiting_for_me': 1
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No documents are waiting for your signature.
            </p>
        </field>
    </record>

    <menuitem id="pr_sign_approvals_menu"
              name="Documents to Sign"
              parent="de_hr_workspace.menu_my_employee_approvals"
              action="pr_sign_waiting_for_me_approval_action"
              sequence="70"
              groups="sign.group_sign_user"/>
</odoo>

