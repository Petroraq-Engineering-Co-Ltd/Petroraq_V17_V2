<?xml version="1.0" encoding="UTF-8"?>
<odoo noupdate="1">
    <record id="vendor_category_manufacturer" model="pr.vendor.category">
        <field name="name">Manufacturer</field>
        <field name="code">MFG</field>
        <field name="sequence">10</field>
        <field name="description">Produces goods directly or owns the production process.</field>
    </record>
    <record id="vendor_category_oem" model="pr.vendor.category">
        <field name="name">OEM</field>
        <field name="code">OEM</field>
        <field name="sequence">20</field>
        <field name="description">Original equipment manufacturer or approved original source.</field>
    </record>
    <record id="vendor_category_authorized_dealer" model="pr.vendor.category">
        <field name="name">Authorized Dealer</field>
        <field name="code">AUTH</field>
        <field name="sequence">30</field>
        <field name="description">Officially authorized dealer or channel partner.</field>
    </record>
    <record id="vendor_category_distributor" model="pr.vendor.category">
        <field name="name">Distributor</field>
        <field name="code">DIST</field>
        <field name="sequence">40</field>
        <field name="description">Supplies products through distribution channels.</field>
    </record>
    <record id="vendor_category_wholesaler" model="pr.vendor.category">
        <field name="name">Wholesaler</field>
        <field name="code">WHOLE</field>
        <field name="sequence">50</field>
        <field name="description">Supplies products in bulk or wholesale quantities.</field>
    </record>
    <record id="vendor_category_retailer" model="pr.vendor.category">
        <field name="name">Retailer</field>
        <field name="code">RTL</field>
        <field name="sequence">60</field>
        <field name="description">Sells products mainly in retail or small quantities.</field>
    </record>
    <record id="vendor_category_importer" model="pr.vendor.category">
        <field name="name">Importer</field>
        <field name="code">IMP</field>
        <field name="sequence">70</field>
        <field name="description">Imports products from outside the local market.</field>
    </record>
    <record id="vendor_category_agent_broker" model="pr.vendor.category">
        <field name="name">Agent/Broker</field>
        <field name="code">AGT</field>
        <field name="sequence">80</field>
        <field name="description">Acts as an intermediary, broker, or commercial agent.</field>
    </record>
    <record id="vendor_category_service_provider" model="pr.vendor.category">
        <field name="name">Service Provider</field>
        <field name="code">SRV</field>
        <field name="sequence">90</field>
        <field name="description">Provides services rather than physical goods.</field>
    </record>
    <record id="vendor_category_contractor" model="pr.vendor.category">
        <field name="name">Contractor</field>
        <field name="code">CTR</field>
        <field name="sequence">100</field>
        <field name="description">Provides contracted work, project delivery, installation, or site execution.</field>
    </record>
    <record id="vendor_category_system_integrator" model="pr.vendor.category">
        <field name="name">System Integrator</field>
        <field name="code">SI</field>
        <field name="sequence">110</field>
        <field name="description">Combines products, engineering, software, or services into integrated solutions.</field>
    </record>
</odoo>
