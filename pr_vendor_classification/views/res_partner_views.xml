<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_partner_form_vendor_classification" model="ir.ui.view">
        <field name="name">res.partner.form.vendor.classification</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <field name="supplier_rank" invisible="1"/>
                <button class="oe_stat_button"
                        name="action_pr_open_supplierinfo"
                        type="object"
                        icon="fa-cubes"
                        groups="purchase.group_purchase_user"
                        invisible="supplier_rank == 0 and pr_supplied_product_count == 0">
                    <field name="pr_supplied_product_count" widget="statinfo" string="Products"/>
                </button>
                <button class="oe_stat_button"
                        name="action_pr_open_purchase_history_lines"
                        type="object"
                        icon="fa-history"
                        groups="purchase.group_purchase_user"
                        invisible="supplier_rank == 0 and pr_purchase_line_count == 0">
                    <field name="pr_purchase_line_count" widget="statinfo" string="Purchase Lines"/>
                </button>
            </div>

            <group name="purchase" position="inside">
                <separator string="Vendor Classification" colspan="2"/>
                <field name="pr_vendor_category_id" options="{'no_create_edit': False}"/>
                <field name="pr_vendor_category_ids" widget="many2many_tags"/>
            </group>

            <xpath expr="//notebook" position="inside">
                <page name="pr_vendor_products"
                      string="Provided Products"
                      groups="purchase.group_purchase_user">
                    <field name="pr_supplierinfo_ids"
                           context="{'default_partner_id': id, 'visible_product_tmpl_id': False, 'product_template_invisible_variant': False}"
                           mode="tree,form">
                        <tree editable="bottom" string="Provided Products">
                            <field name="sequence" widget="handle"/>
                            <field name="company_id" column_invisible="True"/>
                            <field name="product_tmpl_id" string="Product" required="1" options="{'no_create': False}"/>
                            <field name="product_id" optional="hide" groups="product.group_product_variant"
                                   domain="[('product_tmpl_id', '=', product_tmpl_id)] if product_tmpl_id else []"/>
                            <field name="product_name" optional="hide"/>
                            <field name="product_code" optional="show"/>
                            <field name="min_qty"/>
                            <field name="product_uom" groups="uom.group_uom" optional="hide"/>
                            <field name="price" string="Unit Price"/>
                            <field name="discount" optional="hide"/>
                            <field name="currency_id" groups="base.group_multi_currency"/>
                            <field name="delay" string="Lead Time"/>
                            <field name="date_start" optional="hide"/>
                            <field name="date_end" optional="hide"/>
                        </tree>
                        <form string="Provided Product">
                            <sheet>
                                <group>
                                    <group string="Vendor">
                                        <field name="partner_id" readonly="1"/>
                                        <field name="product_name"/>
                                        <field name="product_code"/>
                                        <label for="delay"/>
                                        <div>
                                            <field name="delay" class="oe_inline"/> days
                                        </div>
                                    </group>
                                    <group string="Product and Price">
                                        <field name="product_tmpl_id" string="Product"/>
                                        <field name="product_id" groups="product.group_product_variant"/>
                                        <label for="min_qty"/>
                                        <div class="o_row">
                                            <field name="min_qty"/>
                                            <field name="product_uom" groups="uom.group_uom"/>
                                        </div>
                                        <label for="price" string="Unit Price"/>
                                        <div class="o_row">
                                            <field name="price" class="oe_inline"/>
                                            <field name="currency_id" groups="base.group_multi_currency"/>
                                        </div>
                                        <label for="date_start" string="Validity"/>
                                        <div class="o_row">
                                            <field name="date_start" class="oe_inline"/> to <field name="date_end" class="oe_inline"/>
                                        </div>
                                        <field name="discount"/>
                                        <field name="company_id" options="{'no_create': True}"/>
                                    </group>
                                </group>
                            </sheet>
                        </form>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_partner_tree_vendor_classification" model="ir.ui.view">
        <field name="name">res.partner.tree.vendor.classification</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree"/>
        <field name="arch" type="xml">
            <field name="complete_name" position="after">
                <field name="pr_vendor_category_id" optional="show"/>
            </field>
        </field>
    </record>

    <record id="view_res_partner_filter_vendor_classification" model="ir.ui.view">
        <field name="name">res.partner.search.vendor.classification</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_res_partner_filter"/>
        <field name="arch" type="xml">
            <field name="category_id" position="after">
                <field name="pr_vendor_category_id"/>
            </field>
            <xpath expr="//group" position="inside">
                <filter string="Vendor Category" name="groupby_pr_vendor_category_id" context="{'group_by': 'pr_vendor_category_id'}"/>
            </xpath>
        </field>
    </record>
</odoo>
