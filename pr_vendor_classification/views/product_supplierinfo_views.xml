<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_product_supplierinfo_tree_vendor_category" model="ir.ui.view">
        <field name="name">product.supplierinfo.tree.vendor.category</field>
        <field name="model">product.supplierinfo</field>
        <field name="inherit_id" ref="product.product_supplierinfo_tree_view"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="pr_vendor_category_id" optional="show"/>
            </field>
        </field>
    </record>

    <record id="view_product_supplierinfo_form_vendor_category" model="ir.ui.view">
        <field name="name">product.supplierinfo.form.vendor.category</field>
        <field name="model">product.supplierinfo</field>
        <field name="inherit_id" ref="product.product_supplierinfo_form_view"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="pr_vendor_category_id"/>
            </field>
        </field>
    </record>

    <record id="view_product_supplierinfo_search_vendor_category" model="ir.ui.view">
        <field name="name">product.supplierinfo.search.vendor.category</field>
        <field name="model">product.supplierinfo</field>
        <field name="inherit_id" ref="product.product_supplierinfo_search_view"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="pr_vendor_category_id"/>
            </field>
            <filter name="groupby_vendor" position="after">
                <filter string="Vendor Category" name="groupby_pr_vendor_category_id" context="{'group_by': 'pr_vendor_category_id'}"/>
            </filter>
        </field>
    </record>

    <record id="action_pr_vendor_products" model="ir.actions.act_window">
        <field name="name">Vendor Products</field>
        <field name="res_model">product.supplierinfo</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="context">{'visible_product_tmpl_id': False, 'search_default_active_products': True}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No vendor products yet
            </p>
            <p>
                Register which products each vendor can provide, along with vendor codes, lead time, quantity, and price.
            </p>
        </field>
    </record>

    <menuitem id="menu_pr_vendor_products"
              name="Vendor Products"
              parent="purchase.menu_purchase_config"
              action="action_pr_vendor_products"
              sequence="32"
              groups="purchase.group_purchase_manager"/>
</odoo>
