<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_pr_vendor_category_tree" model="ir.ui.view">
        <field name="name">pr.vendor.category.tree</field>
        <field name="model">pr.vendor.category</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="description"/>
                <field name="active" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_pr_vendor_category_form" model="ir.ui.view">
        <field name="name">pr.vendor.category.form</field>
        <field name="model">pr.vendor.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="Describe this vendor category..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_pr_vendor_category_search" model="ir.ui.view">
        <field name="name">pr.vendor.category.search</field>
        <field name="model">pr.vendor.category</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="action_pr_vendor_category" model="ir.actions.act_window">
        <field name="name">Vendor Categories</field>
        <field name="res_model">pr.vendor.category</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create vendor categories
            </p>
            <p>
                Use categories such as Manufacturer, Distributor, Wholesaler, Retailer, Contractor, or Service Provider.
            </p>
        </field>
    </record>

    <menuitem id="menu_pr_vendor_category"
              name="Vendor Categories"
              parent="purchase.menu_purchase_config"
              action="action_pr_vendor_category"
              sequence="31"
              groups="purchase.group_purchase_manager"/>
</odoo>
