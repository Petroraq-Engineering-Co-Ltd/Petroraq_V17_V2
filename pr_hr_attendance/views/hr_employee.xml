<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="pr_hr_attendance_view_employee_form_inherit" model="ir.ui.view">
            <field name="name">pr.hr.attendance.view.employee.form.inherit</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">

                <xpath expr="//div[@id='o_work_employee_main']" position="inside">
                    <group name="employee_overtime" string="Overtime">
                        <field name="add_overtime" widget="boolean_toggle"/>
                        <field name="attendance_email_enabled" widget="boolean_toggle"/>
                    </group>
                    <group name="employee_attendance_entry_policy" string="Attendance Entry Policy">
                        <field name="attendance_entry_mode" readonly="1"/>
                        <button name="action_request_attendance_mode_change"
                                type="object"
                                string="Request Mode Change"
                                class="btn-secondary"
                                invisible="not id"
                                groups="hr_attendance.group_hr_attendance_officer,hr_attendance.group_hr_attendance_manager,hr.group_hr_manager"/>
                    </group>
                </xpath>

                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_view_attendance_mode_change_requests"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-exchange"
                            groups="hr_attendance.group_hr_attendance_officer,hr_attendance.group_hr_attendance_manager,hr.group_hr_manager,pr_hr_recruitment_request.group_onboarding_manager,pr_hr_recruitment_request.group_onboarding_md">
                        <field name="attendance_mode_change_request_count"
                               widget="statinfo"
                               string="Mode Requests"/>
                    </button>
                </xpath>

            </field>
        </record>
</odoo>
