<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pr_hr_attendance_view_hr_attendance_form_inherit" model="ir.ui.view">
        <field name="name">pr.hr.attendance.view.hr.attendance.form.inherit</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.hr_attendance_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='overtime_hours']" position="replace">
                <field name="overtime_for_approval" string="Over Time" widget="float_time" readonly="1"/>
            </xpath>

            <xpath expr="//div[hasclass('oe_chatter')]" position="replace">
            </xpath>

        </field>
    </record>

    <record id="pr_hr_attendance_view_hr_attendance_tree_inherit" model="ir.ui.view">
        <field name="name">pr.hr.attendance.view.hr.attendance.tree.inherit</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="gs_hr_attendance_sheet.gs_hr_attendance_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='overtime_for_approval']" position="attributes">
                <attribute name="invisible">0</attribute>
                <attribute name="widget">float_time</attribute>
                <attribute name="string">Over Time</attribute>
            </xpath>
            <xpath expr="//field[@name='overtime_hours']" position="replace"/>
        </field>
    </record>
</odoo>