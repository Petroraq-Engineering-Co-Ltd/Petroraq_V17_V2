<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_daily_attendance_notification_email" model="ir.cron">
            <field name="name">Daily Attendance Notification Emails</field>
            <field name="model_id" ref="model_pr_hr_attendance_notification"/>
            <field name="state">code</field>
            <field name="code">model.cron_send_daily_attendance_notifications()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="nextcall">2026-04-05 21:00:00</field>
        </record>
    </data>

    <data>
        <function model="ir.model.data" name="write">
            <value model="ir.model.data" search="[('module', '=', 'pr_hr_attendance'), ('name', '=', 'ir_cron_auto_management_attendance')]"/>
            <value eval="{'noupdate': False}"/>
        </function>

        <record id="ir_cron_auto_management_attendance" model="ir.cron">
            <field name="name">Auto Management Attendance Check In</field>
            <field name="model_id" ref="hr_attendance.model_hr_attendance"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="state">code</field>
            <field name="code">model.cron_create_auto_management_attendance_check_in()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field eval="False" name="doall"/>
            <field name="active">True</field>
            <field name="nextcall" eval="(DateTime.now().replace(hour=5, minute=0, second=0, microsecond=0)).strftime('%Y-%m-%d %H:%M:%S')"/>
        </record>

        <record id="ir_cron_auto_management_attendance_checkout" model="ir.cron">
            <field name="name">Auto Management Attendance Check Out</field>
            <field name="model_id" ref="hr_attendance.model_hr_attendance"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="state">code</field>
            <field name="code">model.cron_checkout_auto_management_attendance()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field eval="False" name="doall"/>
            <field name="active">True</field>
            <field name="nextcall" eval="(DateTime.now().replace(hour=14, minute=0, second=0, microsecond=0)).strftime('%Y-%m-%d %H:%M:%S')"/>
        </record>
    </data>
</odoo>
