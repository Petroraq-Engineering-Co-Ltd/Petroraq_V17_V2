<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pr_hr_recruitment_request.group_onboarding_manager" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('de_hr_workspace.group_hr_employee_approvals'))]"/>
    </record>

    <record id="pr_hr_recruitment_request.group_onboarding_md" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('de_hr_workspace.group_hr_employee_approvals'))]"/>
    </record>

    <record id="de_hr_workspace.hr_approvals_menu_root" model="ir.ui.menu">
        <field name="groups_id" eval="[
            (4, ref('hr.group_hr_manager')),
            (4, ref('pr_hr_recruitment_request.group_onboarding_manager')),
            (4, ref('pr_hr_recruitment_request.group_onboarding_md'))
        ]"/>
    </record>

    <record id="rule_attendance_mode_request_company" model="ir.rule">
        <field name="name">Attendance mode requests: allowed companies</field>
        <field name="model_id" ref="model_hr_attendance_mode_change_request"/>
        <field name="global" eval="True"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
</odoo>
