<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="email_template_applicant_offer_letter" model="mail.template">
            <field name="name">Applicant Offer Letter</field>
            <field name="model_id" ref="hr_recruitment.model_hr_applicant"/>
            <field name="email_from">{{ (object.user_id.email_formatted or object.company_id.email_formatted or user.email_formatted) }}</field>
            <field name="email_to">{{ object._get_offer_letter_email() }}</field>
            <field name="subject">Offer Letter - {{ object.job_id.name or object.company_id.name or 'Petroraq' }}</field>
            <field name="auto_delete" eval="False"/>
            <field name="body_html"><![CDATA[
                <p>Dear <t t-out="object.partner_name or object.name"/>,</p>
                <p>
                    Congratulations. Please find attached your offer letter for
                    <strong><t t-out="object.job_id.name or 'the offered position'"/></strong>.
                </p>
                <p>
                    Kindly review the attached PDF, sign the acceptance section, and return the signed copy to HR.
                </p>
                <p>
                    Best regards,<br/>
                    <strong>Human Resources Department</strong><br/>
                    <t t-out="object.company_id.name or user.company_id.name"/>
                </p>
            ]]></field>
        </record>
    </data>
</odoo>