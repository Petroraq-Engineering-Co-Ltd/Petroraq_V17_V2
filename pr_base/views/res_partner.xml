<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <record id="pr_base_res_partner_view_form_inherit" model="ir.ui.view">
        <field name="name">pr.base.res.partner.view.form.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="priority">50</field>
        <field name="arch" type="xml">
            <xpath expr="//span[@name='address_name']" position="before">
                <field name="partner_code"/>
            </xpath>
            <xpath expr="//field[@name='vat']" position="attributes">
                <attribute name="required">is_company and not parent_id</attribute>
            </xpath>
            <xpath expr="//field[@name='l10n_sa_additional_identification_scheme']" position="attributes">
                <attribute name="invisible">False</attribute>
                <attribute name="required">False</attribute>
            </xpath>
            <xpath expr="//field[@name='l10n_sa_additional_identification_number']" position="attributes">
                <attribute name="invisible">False</attribute>
                <attribute name="required">False</attribute>
            </xpath>


            <xpath expr="//span[@name='address_name']" position="before">
                <field name="arabic_name"/>
            </xpath>

            <xpath expr="//span[@name='address_name']/following-sibling::div[hasclass('o_address_format')][1]" position="after">
                <label for="arabic_street" string="Arabic Address"/>
                <div name="pr_arabic_address" class="o_pr_arabic_address" dir="rtl" style="width: 100%;">
                    <field name="arabic_street" placeholder="Arabic Street..." class="w-100"/>
                    <field name="arabic_street2" placeholder="Arabic Street 2..." class="w-100"/>
                </div>
            </xpath>

        </field>
    </record>

</odoo>
